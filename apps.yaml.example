# Copy this file to ~/.config/declaroid/apps.yaml (or point --config /
# $DECLAROID_CONFIG at your own copy) and adjust it to your needs.

# Optional. Pulls in apps:/modules:/profiles:/obtainium: from other config file(s) --
# paths relative to this file -- so shared apps/modules don't have to be
# repeated across a config-per-device setup. Merged as: each import's
# entries first (in listed order, recursively), then this file's own --
# plain concatenation, no override/dedup by pkg/id. Only applies to
# apply/uninstall/diff/modules; add/download always read (and add writes)
# this exact file, ignoring imports:. See README.md for the full writeup.
# imports:
#   - common-apps.yaml
#   - common-modules.yaml

# enforce:/grant_permissions:/store: (see below) cascade in from imports
# as an override instead -- this file's own value wins if it sets the key
# at all, else the last import that sets it does. Lets a shared
# imports/base.yaml carry a default for every device config that imports
# it, without repeating it everywhere.

# Optional. Matched as a case-insensitive substring against each connected
# device's serial, USB path, product, model, and codename. Can be overridden
# with --device or $TARGET_DEVICE. Omit entirely to be prompted interactively
# when more than one device is connected.
device: redfin

# Optional top-level default store for apps that don't set their own.
# One of: gplay (default), fdroid, github, local.
store: gplay

# Optional top-level default Android user/profile to install for (apply
# only). A user id (e.g. 0), or the literal "all" or "current". Omit this
# entirely unless the device actually has more than one profile (a Work
# Profile, Island, a second full user account) -- declaroid otherwise
# auto-detects the device's current profile, which is what you want.
# profile: 0

# Optional. start_cmd runs once (if no device is connected at all, or none
# match) to bring the adb connection up, then device resolution is retried
# exactly once more. Useful for a wireless-adb device that isn't reliably
# already connected. auto_stop/stop_cmd are the teardown mirror -- if
# auto_stop is true, stop_cmd runs once a command's real device work is
# done (apply/uninstall/diff/modules), e.g. to disconnect wireless adb
# again afterward. auto_stop defaults to false.
# adb:
#   start_cmd: "zhj adb::connect px5.lan"
#   auto_stop: true
#   stop_cmd: "adb disconnect px5.lan:5555"

# Optional, default false (apply only). Same as always passing --enforce:
# also uninstalls any device app that isn't in this config at all.
# enforce: true

# Optional, default false (apply only). Same as always passing
# -g/--grant-permissions: grants every runtime permission at install time
# instead of prompting later. No effect on store: fdroid/izzyondroid apps.
# grant_permissions: true

apps:
  - name: DB Navigator
    pkg: de.hafas.android.db

  - name: Google Maps
    pkg: com.google.android.apps.maps

  - name: Aurora Store
    pkg: com.aurora.store
    store: fdroid

  - name: Findroid Plus
    pkg: dev.pschmitt.findroidplus
    store: github
    repo: pschmitt/findroidplus
    # Narrow down to exactly one release asset -- this repo publishes
    # per-ABI, per-flavor, debug/release builds all in one release.
    asset: 'phone-arm64-v8a-release\.apk$'

  - name: Company Portal
    pkg: com.microsoft.windowsintune.companyportal
    # Only this one app needs to land in the Work Profile too.
    profile: all

  - name: Facebook
    pkg: com.facebook.katana
    # Keep it around (data/settings preserved) but disabled -- apply installs
    # it if missing, then runs `pm disable-user` on it. Flip this back to
    # false/remove it to have apply re-enable it again.
    state:
      disabled: true

  - name: Bloatware I Don't Want Anymore
    pkg: com.example.bloat
    # Not desired at all -- apply uninstalls it if present, unconditionally
    # (unlike --enforce, this doesn't require anything else in the config).
    state:
      installed: false

  - name: Obtainium
    pkg: dev.imranr.obtainium.fdroid
    store: fdroid

# Optional (apply only). Repos for Obtainium (installed above) to track --
# requires root; errors out if root is enabled but Obtainium itself isn't
# installed, skipped entirely (no error) if root.enabled is false. Only
# adds missing entries; already-tracked ones are left untouched. See
# README.md for the full writeup, including the optional settings: map.
# obtainium:
#   - pkg: com.kieronquinn.app.smartspacer
#     url: "https://github.com/KieronQuinn/Smartspacer"
