cmd_clear_cache() {
  local assume_yes=""
  local DRY_RUN=""
  local -a pkgs=()

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -y|--yes|--noconfirm|--no-confirm)
        assume_yes=1
        shift
        ;;
      -k|--dry-run|--dryrun)
        DRY_RUN=1
        shift
        ;;
      -*)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
      *)
        pkgs+=("$1")
        shift
        ;;
    esac
  done

  if [[ ! -d "$CACHE_ROOT" ]]
  then
    log_step "Cache is already empty ($CACHE_ROOT)"
    return 0
  fi

  if [[ ${#pkgs[@]} -eq 0 ]]
  then
    if [[ -n "$DRY_RUN" ]]
    then
      printf '  would remove entire cache: %s\n' "$CACHE_ROOT"
      return 0
    fi

    if [[ -z "$assume_yes" ]]
    then
      printf '%sThis will remove the entire APK cache at %s%s\n' "$C_BOLD" "$CACHE_ROOT" "$C_RESET"
      local reply
      read -rp "Continue? [y/N] " reply
      case "$reply" in
        y|Y|yes|YES)
          ;;
        *)
          log_step "Aborted"
          return 0
          ;;
      esac
    fi

    rm -rf "$CACHE_ROOT"
    log_ok "Cache cleared: $CACHE_ROOT"
    return 0
  fi

  local pkg dir
  for pkg in "${pkgs[@]}"
  do
    dir="$(cache_dir_for "$pkg")"

    if [[ ! -d "$dir" ]]
    then
      log_skip "$pkg (nothing cached)"
      continue
    fi

    if [[ -n "$DRY_RUN" ]]
    then
      printf '  would remove %s cache: %s\n' "$pkg" "$dir"
      continue
    fi

    rm -rf "$dir"
    log_ok "$pkg cache cleared"
  done
}

# Strips leading/trailing whitespace with pure bash parameter expansion --
# no subshell/external process needed for something this hot-pathed (called
# once per search result row).
trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s\n' "$s"
}

# OSC 8 terminal hyperlink: wraps $2 (visible text) so clicking it opens $1
# (kitty, wezterm, iTerm2, and VTE-based terminals like foot/gnome-terminal
# all support this). Gated on the pre-computed $HYPERLINKS (see the top-
# level `-t 1`/NO_COLOR check) rather than testing `-t 1` here directly --
# `search` calls this from inside `$(...)` to build up a row string, and fd
# 1 inside a command substitution is always the capturing pipe, never the
# real terminal, so a live `-t 1` test here would always read "not a tty"
# and never emit a link even when stdout genuinely is one.
hyperlink() {
  local url="$1"
  local text="$2"

  if [[ -n "$HYPERLINKS" ]]
  then
    # shellcheck disable=SC1003
    # Not an escaped quote -- \\ is printf's own escape for a literal
    # backslash, needed here to close the OSC 8 sequence with the ESC-\
    # "ST" terminator (BEL also works but ST is the more portable choice).
    printf '\e]8;;%s\e\\%s\e]8;;\e\\' "$url" "$text"
  else
    printf '%s' "$text"
  fi
}

gplay_app_url() {
  printf 'https://play.google.com/store/apps/details?id=%s\n' "$1"
}

fdroid_app_url() {
  printf 'https://f-droid.org/packages/%s/\n' "$1"
}

izzyondroid_app_url() {
  printf 'https://apt.izzysoft.de/fdroid/index/apk/%s\n' "$1"
}

# Runs `gplaydl search`, whose only output is a Rich-rendered table (no
# --json/plain-text mode) with a fixed 3-column layout: "#", "Title",
# "Package". Rich disables ANSI color automatically once stdout isn't a
# terminal (true here, since this always runs inside a pipe/mapfile), so
# there's no color codes to strip -- but it still draws the table with box-
# drawing characters, and by default sizes columns to the *detected*
# terminal width, which is 80 in a non-tty pipe and can wrap a long title
# across multiple lines, breaking the "one data row = one output line"
# assumption entirely. Forcing COLUMNS to something absurdly wide (Rich
# reads it via shutil.get_terminal_size, confirmed empirically) avoids that
# in all realistic cases. Data rows are distinguished from the title/header/
# border lines by starting with the *light* vertical bar "│" (U+2502) --
# the header row uses the *heavy* "┃" instead, and border lines start with
# "┏"/"┡"/"└" -- so splitting only "│"-prefixed lines on that same character
# reliably yields [prefix, idx, name, pkg, suffix] with no ambiguity, since
# Rich always draws this exact box style for a 3-column table.
search_gplay() {
  local query="$1"
  local limit="$2"

  local -a lines
  mapfile -t lines < <(COLUMNS=1000 gplaydl search "$query" --limit "$limit" 2>/dev/null)

  local line name pkg
  for line in "${lines[@]}"
  do
    [[ "$line" == '│'* ]] || continue

    IFS='│' read -r _ _ name pkg _ <<< "$line"
    name="$(trim "$name")"
    pkg="$(trim "$pkg")"

    [[ -z "$pkg" || "$pkg" == "Package" ]] && continue

    printf '%s\t%s\tgplay\t\n' "$name" "$pkg"
  done
}

# `fdroidcl search` has no --limit/-l flag at all (checked --help), so the
# cap is enforced client-side. Each result is two lines: an unindented
# "<pkgid>   <title> - <version> (<versioncode>)" line, then a 4-space-
# indented summary line -- distinguished by leading whitespace, and the
# summary line is simply skipped (search's TSV output doesn't have a
# description column). <title> itself can legitimately contain " - "
# (e.g. "WhatsApp Web To Go - Mobile Client for WhatsApp We - 1.7.5 (39)"),
# so splitting naively on the first " - " would cut the title short --
# bash's `=~` is greedy, so `(.*) - (.+)$` backtracks from the end and
# always finds the *last* " - ", giving the right split regardless of how
# many dashes the title itself contains.
# The query is matched as a Go regexp (its own --help says so) and is
# case-sensitive by default -- confirmed empirically: "signal" finds
# matches, "SIGNAL"/"SiGnAl" find zero, even though the exact same content
# matches lowercase. gplaydl's Play Store search is already
# case-insensitive server-side (also confirmed empirically), so only this
# side needs a fix: prefixing with Go regexp's inline `(?i)` flag turns on
# case-insensitive matching without otherwise changing how the rest of the
# query is interpreted.
search_fdroid() {
  local query="$1"
  local limit="$2"
  local count=0

  local -a lines
  mapfile -t lines < <(fdroidcl search "(?i)$query" 2>/dev/null)

  local line pkg rest name
  for line in "${lines[@]}"
  do
    [[ "$line" =~ ^[[:space:]] ]] && continue
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^([^[:space:]]+)[[:space:]]+(.*)$ ]] || continue

    pkg="${BASH_REMATCH[1]}"
    rest="${BASH_REMATCH[2]}"

    name="$rest"
    [[ "$rest" =~ ^(.*)\ -\ (.+)$ ]] && name="${BASH_REMATCH[1]}"

    printf '%s\t%s\tfdroid\t\n' "$name" "$pkg"

    count=$((count + 1))
    [[ $count -ge $limit ]] && break
  done
}

# Same shape as search_fdroid, but through izzyondroid_fdroidcl's isolated,
# IzzyOnDroid-only config -- since nothing else is enabled there, results
# are naturally scoped to just that repo, no per-result `fdroidcl show`
# filtering needed (unlike a naive approach layered on the user's real,
# multi-repo fdroidcl config would require).
search_izzyondroid() {
  local query="$1"
  local limit="$2"
  local count=0

  ensure_izzyondroid_repo >&2

