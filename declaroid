  done
}

cmd_search() {
  local query=""
  local store="any"
  local limit=10

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      --store)
        store="$2"
        shift 2
        ;;
      -l|--limit)
        limit="$2"
        shift 2
        ;;
      -k|--dry-run|--dryrun)
        # Accepted everywhere for scriptability, but this command is
        # already read-only -- nothing to preview, so it's a no-op here.
        shift
        ;;
      -*)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
      *)
        if [[ -n "$query" ]]
        then
          query="$query $1"
        else
          query="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$query" ]]
  then
    log_error "search requires a query"
    usage >&2
    return 2
  fi

  case "$store" in
    gplay | fdroid | izzyondroid | any)
      ;;
    *)
      log_error "Invalid --store value: $store (expected gplay, fdroid, izzyondroid, or any)"
      return 2
      ;;
  esac

  if [[ "$store" == gplay || "$store" == any ]]
  then
    check_deps gplaydl
  fi

  if [[ "$store" == fdroid || "$store" == izzyondroid || "$store" == any ]]
  then
    check_deps fdroidcl
  fi

  # Collect both stores' results into one flat list before rendering
  # anything, so the two searches come out as a single merged table (like
  # `devices`/`diff`) instead of two separate blocks. STORE is colorized
  # *after* render_table, via colorize_word, the same way cmd_diff colors
  # installed/missing/extra -- that keeps column alignment correct
  # regardless of renderer (tsvtool or the column -t fallback), since
  # colorize_word only touches already-aligned text and doesn't change any
  # cell's width. NAME's OSC 8 hyperlink can't use that trick (each row
  # links to a different URL, not a fixed word), so it's embedded before
  # rendering; tsvtool measures visible width around OSC 8/ANSI codes
  # (checked its source), so this aligns correctly there, but the column -t
  # fallback doesn't understand OSC 8 and can misalign the NAME column
  # slightly when hyperlinks are active and tsvtool isn't installed --
  # accepted since tsvtool is always available in this project's own
  # environment.
  # izzyondroid is deliberately not part of "any" -- it's a separate,
  # explicit opt-in (registering/updating its isolated fdroidcl config has
  # real cost the first time), not something every search should pay for.
  local -a all_rows=()
  local -a rows
  local row name pkg app_store

  if [[ "$store" == gplay || "$store" == any ]]
  then
    log_step "Searching Google Play for \"$query\""
    mapfile -t rows < <(search_gplay "$query" "$limit")
    for row in "${rows[@]}"
    do
      IFS=$'\t' read -r name pkg app_store _ <<< "$row"
      all_rows+=("$(hyperlink "$(gplay_app_url "$pkg")" "$name")"$'\t'"$pkg"$'\t'"$app_store")
    done
  fi

  if [[ "$store" == fdroid || "$store" == any ]]
  then
    log_step "Searching F-Droid for \"$query\""
    mapfile -t rows < <(search_fdroid "$query" "$limit")
    for row in "${rows[@]}"
    do
      IFS=$'\t' read -r name pkg app_store _ <<< "$row"
      all_rows+=("$(hyperlink "$(fdroid_app_url "$pkg")" "$name")"$'\t'"$pkg"$'\t'"$app_store")
    done
  fi

  if [[ "$store" == izzyondroid ]]
  then
    log_step "Searching IzzyOnDroid for \"$query\""
    mapfile -t rows < <(search_izzyondroid "$query" "$limit")
    for row in "${rows[@]}"
    do
      IFS=$'\t' read -r name pkg app_store _ <<< "$row"
      all_rows+=("$(hyperlink "$(izzyondroid_app_url "$pkg")" "$name")"$'\t'"$pkg"$'\t'"$app_store")
    done
  fi

  if [[ ${#all_rows[@]} -eq 0 ]]
  then
    log_step "No results found for \"$query\""
    return 0
  fi

  {
    printf 'NAME\tPKG\tSTORE\n'
    printf '%s\n' "${all_rows[@]}"
  } | render_table | colorize_word gplay "$C_BLUE" | colorize_word fdroid "$C_GREEN" | colorize_word izzyondroid "$C_CYAN"
}

# Searches gplay/fdroid/izzyondroid per $store ("gplay"/"fdroid"/
# "izzyondroid"/"any") and prints matched rows as "name\tpkg\tstore" (one
# per line) to stdout -- the plain, non-hyperlinked row shape `add`/
# `download` both act on (unlike cmd_search's own inline accumulation,
# which additionally embeds OSC 8 hyperlinks for display and so isn't
# reused here). Shared by cmd_add and cmd_download.
search_stores() {
  local query="$1"
  local limit="$2"
  local store="$3"

  local -a rows
  local row name pkg app_store

  if [[ "$store" == gplay || "$store" == any ]]
  then
    log_step "Searching Google Play for \"$query\""
    mapfile -t rows < <(search_gplay "$query" "$limit")
    for row in "${rows[@]}"
    do
      IFS=$'\t' read -r name pkg app_store _ <<< "$row"
      printf '%s\t%s\t%s\n' "$name" "$pkg" "$app_store"
    done
  fi

  if [[ "$store" == fdroid || "$store" == any ]]
  then
    log_step "Searching F-Droid for \"$query\""
    mapfile -t rows < <(search_fdroid "$query" "$limit")
    for row in "${rows[@]}"
    do
      IFS=$'\t' read -r name pkg app_store _ <<< "$row"
      printf '%s\t%s\t%s\n' "$name" "$pkg" "$app_store"
    done
  fi

  if [[ "$store" == izzyondroid ]]
  then
    log_step "Searching IzzyOnDroid for \"$query\""
    mapfile -t rows < <(search_izzyondroid "$query" "$limit")
    for row in "${rows[@]}"
    do
      IFS=$'\t' read -r name pkg app_store _ <<< "$row"
      printf '%s\t%s\t%s\n' "$name" "$pkg" "$app_store"
    done
  fi
}

# Interactive fzf picker for `add`/`download`'s search matches: one line per
# match in the list, a preview pane showing the app's info plus an
# action-specific footer ($mode "add": the exact YAML that would be
# appended to $context, a config path; $mode "download": the directory
# it'll download to, $context). $default_store is only meaningful for
# "add" (decides whether the preview shows an explicit store: line) --
# "download" passes it empty, unused. Colors/bold/italic are emitted
# unconditionally here (not gated on $C_*/-t 1 like the rest of the
# script) because fzf itself requires a real controlling terminal to run at
# all, so by the time this function is reached we already know stdout is
# interactive. Prints the chosen row as "name\tpkg\tstore" on success;
# returns 1 with no output if the user cancels (Esc/Ctrl-C).
pick_search_result() {
  local mode="$1"
  local context="$2"
  local default_store="$3"
  shift 3
  local -a match_rows=("$@")

  local max_name=0 max_pkg=0
  local row name pkg store
  for row in "${match_rows[@]}"
  do
    IFS=$'\t' read -r name pkg store <<< "$row"
    [[ ${#name} -gt $max_name ]] && max_name=${#name}
    [[ ${#pkg} -gt $max_pkg ]] && max_pkg=${#pkg}
  done

  local -a fzf_lines=()
  local display store_colored
  for row in "${match_rows[@]}"
  do
    IFS=$'\t' read -r name pkg store <<< "$row"
    case "$store" in
      gplay)
        store_colored=$'\e[34m'"$store"$'\e[0m'
        ;;
      fdroid)
        store_colored=$'\e[32m'"$store"$'\e[0m'
        ;;
      izzyondroid)
        store_colored=$'\e[36m'"$store"$'\e[0m'
        ;;
      *)
        store_colored="$store"
        ;;
    esac
    display="$(printf '%-*s  %-*s  %s' "$max_name" "$name" "$max_pkg" "$pkg" "$store_colored")"
    fzf_lines+=("$display"$'\t'"$name"$'\t'"$pkg"$'\t'"$store")
  done

  # Written to an executable temp file rather than inlined as a quoted
  # string in --preview -- the preview script's own printf calls need
  # single-quoted format strings (to keep \033 etc literal), and nesting
  # those inside an outer `bash -c '...'` wrapper breaks immediately: the
  # first single quote *inside* the script prematurely closes the outer
  # one, spilling the rest of the script out as unquoted text for
  # fzf's/zsh's own top-level parser to choke on (confirmed: this produced
  # "bad pattern"/"command not found" errors from zsh when tried inline).
  # A temp file sidesteps quoting nesting entirely -- fzf just executes it
  # with args, no shell re-parsing of its contents involved.
  # A non-quoted heredoc so $context/$default_store expand *now* (fixed for
  # the whole picker); \$1/\$2/\$3 are escaped so they stay literal, to be
  # filled in from argv when fzf invokes this file with {2} {3} {4}
  # (fzf shell-quotes those substitutions safely, even if a title has
  # spaces/quotes in it).
  local preview_file
  preview_file="$(mktemp)"
  cat > "$preview_file" <<EOF
#!/usr/bin/env bash
name="\$1"
pkg="\$2"
store="\$3"
printf '\033[1m\033[36mApp\033[0m\n'
printf '  Name:  %s\n' "\$name"
printf '  Pkg:   %s\n' "\$pkg"
case "\$store" in
  gplay)
    printf '  Store: \033[34m%s\033[0m\n' "\$store"
    ;;
  fdroid)
    printf '  Store: \033[32m%s\033[0m\n' "\$store"
    ;;
  izzyondroid)
    printf '  Store: \033[36m%s\033[0m\n' "\$store"
    ;;
esac
EOF
  if [[ "$mode" == add ]]
  then
    cat >> "$preview_file" <<EOF
printf '\n\033[1m\033[36mWill append to $context:\033[0m\n'
printf '\033[3m  - name: "%s"\033[0m\n' "\$name"
printf '\033[3m    pkg: %s\033[0m\n' "\$pkg"
if [[ "\$store" != "$default_store" ]]
then
  printf '\033[3m    store: %s\033[0m\n' "\$store"
fi
EOF
  else
    cat >> "$preview_file" <<EOF
printf '\n\033[1m\033[36mWill download to $context:\033[0m\n'
EOF
  fi
  chmod +x "$preview_file"

  local header='Multiple matches -- Enter to add, Esc to cancel'
  local prompt='Add> '
  if [[ "$mode" == download ]]
  then
    header='Multiple matches -- Enter to download, Esc to cancel'
    prompt='Download> '
  fi

  local selection
  selection="$(printf '%s\n' "${fzf_lines[@]}" | fzf \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --preview="$preview_file {2} {3} {4}" \
    --preview-window=right:60%:wrap \
    --header="$header" \
    --prompt="$prompt")"

  rm -f "$preview_file"

  if [[ -z "$selection" ]]
  then
    return 1
  fi

  local chosen_name chosen_pkg chosen_store
  IFS=$'\t' read -r _ chosen_name chosen_pkg chosen_store <<< "$selection"
  printf '%s\t%s\t%s\n' "$chosen_name" "$chosen_pkg" "$chosen_store"
}

# Appends a search-selected app to $config's `apps:` list via a plain
# structural `.apps += [...]` yq mutation, not a text-based insert --
# verified empirically against this project's own real generated configs
# (header comments, `profiles:`, commented-out `# TODO` entries) that this
# leaves every other byte of the file untouched; yq's go-yaml-based comment
# model round-trips it cleanly (confirmed via `diff` against the original).
# `name` is forced to double-quoted style explicitly (`style="double"`) to
# match generate-config's own quoting convention (yaml_quote_scalar quotes
# name, never pkg/store) -- left to yq's default, a freshly-appended scalar
# comes out unquoted, which would look inconsistent next to the rest of a
# generate-config-produced file.
add_app_to_config() {
  local config="$1"
  local name="$2"
  local pkg="$3"
  local store="$4"

  # This yq (mikefarah/yq-go) has no jq-style `--arg NAME value` flag at
  # all -- confirmed the hard way (`Error: unknown flag: --arg`), after
  # wrongly assuming jq-compatible arg-passing without checking first. The
  # correct mechanism here is yq's `env(VAR)` expression function, reading
  # an actual process environment variable; `VAR="$val" yq '...env(VAR)...'`
  # (a command-prefix assignment) scopes it to just that one invocation
  # without polluting the shell's environment. Names are prefixed
  # DECLAROID_ to avoid any chance of colliding with an unrelated
  # already-set env var.
  local existing
  existing="$(DECLAROID_PKG="$pkg" yq -r '[.apps[] | select(.pkg == env(DECLAROID_PKG)) | .pkg] | .[0] // ""' "$config")"

  if [[ -n "$existing" ]]
  then
    log_skip "$name ($pkg) already in $config"
    return 0
  fi

  local default_store
  default_store="$(yq -r '.store // "gplay"' "$config")"

  if [[ -n "$DRY_RUN" ]]
  then
    log_step "Would append to $config:"
    printf -- '- name: "%s"\n  pkg: %s\n' "$name" "$pkg"
    if [[ "$store" != "$default_store" ]]
    then
      printf '  store: %s\n' "$store"
    fi
    return 0
  fi

  if [[ "$store" == "$default_store" ]]
  then
    DECLAROID_NAME="$name" DECLAROID_PKG="$pkg" yq -i \
      '.apps += [{"name": env(DECLAROID_NAME), "pkg": env(DECLAROID_PKG)}] | .apps[-1].name style="double"' \
      "$config"
  else
    DECLAROID_NAME="$name" DECLAROID_PKG="$pkg" DECLAROID_STORE="$store" yq -i \
      '.apps += [{"name": env(DECLAROID_NAME), "pkg": env(DECLAROID_PKG), "store": env(DECLAROID_STORE)}] | .apps[-1].name style="double"' \
      "$config"
  fi

  log_ok "Added $name ($pkg) to $config"
}

cmd_add() {
  local config="$DEFAULT_CONFIG"
  local store="any"
  local limit=10
  local query=""
  local DRY_RUN=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      --store)
        store="$2"
        shift 2
        ;;
      -l|--limit)
        limit="$2"
        shift 2
        ;;
      -k|--dry-run|--dryrun)
        DRY_RUN=1
        shift
        ;;
      -*)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
      *)
        if [[ -n "$query" ]]
        then
          query="$query $1"
        else
          query="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$query" ]]
  then
    log_error "add requires a query"
    usage >&2
    return 2
  fi

  case "$store" in
    gplay | fdroid | izzyondroid | any)
      ;;
    *)
      log_error "Invalid --store value: $store (expected gplay, fdroid, izzyondroid, or any)"
      return 2
      ;;
  esac

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  check_deps yq fzf

  if [[ "$store" == gplay || "$store" == any ]]
  then
    check_deps gplaydl
  fi

  if [[ "$store" == fdroid || "$store" == izzyondroid || "$store" == any ]]
  then
    check_deps fdroidcl
  fi

  local -a all_rows
  mapfile -t all_rows < <(search_stores "$query" "$limit" "$store")

  if [[ ${#all_rows[@]} -eq 0 ]]
  then
    log_error "No results found for \"$query\""
    return 1
  fi

  local chosen_name chosen_pkg chosen_store

  if [[ ${#all_rows[@]} -eq 1 ]]
  then
    IFS=$'\t' read -r chosen_name chosen_pkg chosen_store <<< "${all_rows[0]}"
    log_step "Found: $chosen_name ($chosen_pkg) [$chosen_store]"
  else
    local default_store
    default_store="$(yq -r '.store // "gplay"' "$config")"

    local chosen
    if ! chosen="$(pick_search_result add "$config" "$default_store" "${all_rows[@]}")"
    then
      log_step "Cancelled"
      return 0
    fi
    IFS=$'\t' read -r chosen_name chosen_pkg chosen_store <<< "$chosen"
  fi

  add_app_to_config "$config" "$chosen_name" "$chosen_pkg" "$chosen_store"
}

# `download`/`dl`/`fetch`: same search+pick flow as `add` (search_stores,
# pick_search_result in "download" mode), but saves the actual APK file(s)
# to $output instead of writing a config entry -- no device, no config
# file required at all (matching `search`'s own "no device or config
# needed" positioning), since gplay/fdroid/izzyondroid are the only stores
# `search` can ever surface results from in the first place (github/local/
# url apps are only ever *configured* by hand, never searched).
#
# gplay reuses fetch_app verbatim by shadowing CURRENT_PKG/FORCE_DOWNLOAD
# locally (same trick resolve_module_zip already uses to reuse
# fetch_github_release for modules) -- the cache dir it returns may contain
# multiple split APKs, all of which get copied out. fdroid/izzyondroid go
# through fetch_fdroid_apk instead (a single APK, fdroidcl doesn't do
# splits) -- --force-download has no effect there since fdroidcl does its
# own download caching internally, out of declaroid's control.
cmd_download() {
  local store="any"
  local limit=10
  local query=""
  local output="."
  local FORCE_DOWNLOAD=""
  local DRY_RUN=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      --store)
        store="$2"
        shift 2
        ;;
      -l|--limit)
        limit="$2"
        shift 2
        ;;
      -o|--output)
        output="$2"
        shift 2
        ;;
      -f|--force-download)
        FORCE_DOWNLOAD=1
        shift
        ;;
      -k|--dry-run|--dryrun)
        DRY_RUN=1
        shift
        ;;
      -*)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
      *)
        if [[ -n "$query" ]]
        then
          query="$query $1"
        else
          query="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$query" ]]
  then
    log_error "download requires a query"
    usage >&2
    return 2
  fi

  case "$store" in
    gplay | fdroid | izzyondroid | any)
      ;;
    *)
      log_error "Invalid --store value: $store (expected gplay, fdroid, izzyondroid, or any)"
      return 2
      ;;
  esac

  check_deps fzf

  if [[ "$store" == gplay || "$store" == any ]]
  then
    check_deps gplaydl
  fi

  if [[ "$store" == fdroid || "$store" == izzyondroid || "$store" == any ]]
  then
    check_deps fdroidcl
  fi

  local -a all_rows
  mapfile -t all_rows < <(search_stores "$query" "$limit" "$store")

  if [[ ${#all_rows[@]} -eq 0 ]]
  then
    log_error "No results found for \"$query\""
    return 1
  fi

  local chosen_name chosen_pkg chosen_store

  if [[ ${#all_rows[@]} -eq 1 ]]
  then
    IFS=$'\t' read -r chosen_name chosen_pkg chosen_store <<< "${all_rows[0]}"
    log_step "Found: $chosen_name ($chosen_pkg) [$chosen_store]"
  else
    local chosen
    if ! chosen="$(pick_search_result download "$output" "" "${all_rows[@]}")"
    then
      log_step "Cancelled"
      return 0
    fi
    IFS=$'\t' read -r chosen_name chosen_pkg chosen_store <<< "$chosen"
  fi

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would download %s (%s) [%s] to %s\n' "$chosen_name" "$chosen_pkg" "$chosen_store" "$output"
    return 0
  fi

  mkdir -p "$output"

  local -a src_files=()
  case "$chosen_store" in
    gplay)
      local CURRENT_PKG="$chosen_pkg"
      local cache_dir
      if ! cache_dir="$(fetch_app)"
      then
        return 1
      fi
      mapfile -t src_files < <(find "$cache_dir" -maxdepth 1 -iname '*.apk' | sort)
      ;;
    fdroid)
      local path
      if ! path="$(fetch_fdroid_apk "$chosen_pkg" "")"
      then
        return 1
      fi
      src_files=("$path")
      ;;
    izzyondroid)
      local path
      if ! path="$(fetch_fdroid_apk "$chosen_pkg" "1")"
      then
        return 1
      fi
      src_files=("$path")
      ;;
  esac

  if [[ ${#src_files[@]} -eq 0 ]]
  then
    log_error "No APK file(s) found for $chosen_pkg"
    return 1
  fi

  local f
  for f in "${src_files[@]}"
  do
    cp -f "$f" "$output/"
    log_ok "$(basename "$f") -> $output/"
  done
}

cmd_devices() {
  local sort_by="serial"

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      --sort-by)
        sort_by="$2"
        shift 2
        ;;
      -k|--dry-run|--dryrun)
        # Accepted everywhere for scriptability, but this command is
        # already read-only -- nothing to preview, so it's a no-op here.
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  local sort_field
  case "$sort_by" in
    serial) sort_field=1 ;;
    model) sort_field=2 ;;
    codename) sort_field=3 ;;
    connection) sort_field=4 ;;
    *)
      log_error "Invalid --sort-by value: $sort_by (expected serial, model, codename, or connection)"
      return 2
      ;;
  esac

  check_deps adb

  local -a lines
  mapfile -t lines < <(list_device_lines)

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_step "No adb devices connected"
    return 0
  fi

  {
    printf 'SERIAL\tMODEL\tCODENAME\tCONNECTION\n'
    {
      local line serial usb model codename connection
      for line in "${lines[@]}"
      do
        serial="${line%% *}"
        usb=""
        model=""
        codename=""
        [[ "$line" =~ usb:([^[:space:]]+) ]] && usb="${BASH_REMATCH[1]}"
        [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
        [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"
        connection="network"
        [[ -n "$usb" ]] && connection="usb:$usb"
        printf '%s\t%s\t%s\t%s\n' "$serial" "${model:-?}" "${codename:-?}" "$connection"
      done
    } | sort -t $'\t' -k"${sort_field},${sort_field}" -f
  } | render_table
}

# Packages installed on the device (third-party, not GMS/AOSP plumbing --
# see is_system_plumbing_pkg) that have no matching `pkg:` entry anywhere in
# the config. Prints one package id per line; no output means nothing extra.
# Shared by `diff --full` (surfaces them) and `apply --enforce` (offers to
# uninstall them). Deliberately a single `pm list packages -3` call with no
# --user -- unlike generate-config, this isn't trying to be precise about
# which profile an app lives in, just "is this pkg configured at all".
list_extra_pkgs() {
  local config="$1"
  local device="$2"

  # obtainium: entries declare a pkg Obtainium should track, not one
  # declaroid itself installs/manages -- but the whole point of tracking it
  # is that it's expected to be present on the device (side-loaded via
  # Obtainium), so it must count as "configured" here too, or --enforce/
  # `diff` would flag it as unconfigured and offer to uninstall it right
  # out from under Obtainium (confirmed as a real bug: a device with
  # com.kieronquinn.app.smartspacer only in obtainium:, not apps:, had it
  # uninstalled by --enforce).
  local -a configured_pkgs
  mapfile -t configured_pkgs < <(yq -r '.apps[].pkg, (.obtainium // [])[].pkg' "$config")

  local -A configured=()
  local p
  for p in "${configured_pkgs[@]}"
  do
    configured["$p"]=1
  done

  local -a lines
  mapfile -t lines < <(adb -s "$device" shell pm list packages -3 </dev/null 2>/dev/null | tr -d '\r')

  local line pkg
  for line in "${lines[@]}"
  do
    [[ "$line" =~ ^package:([^[:space:]]+)$ ]] || continue
    pkg="${BASH_REMATCH[1]}"

    is_system_plumbing_pkg "$pkg" && continue
    [[ -n "${configured[$pkg]:-}" ]] && continue

    printf '%s\n' "$pkg"
  done
}

cmd_diff() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local bulk=""
  local sort_by="name"
  local full=""
  local DRY_RUN=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      --sort-by)
        sort_by="$2"
        shift 2
        ;;
      --full)
        full=1
        shift
        ;;
      -k|--dry-run|--dryrun)
        # This command itself is already read-only (nothing to preview),
        # but still tracked so maybe_run_adb_stop_cmd at the end can
        # respect it (see its comment).
        DRY_RUN=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  local sort_field
  case "$sort_by" in
    name) sort_field=1 ;;
    pkg) sort_field=2 ;;
    *)
      log_error "Invalid --sort-by value: $sort_by (expected name or pkg)"
      return 2
      ;;
  esac

  check_deps adb yq

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local resolved_config
  if ! resolved_config="$(resolve_config "$config")"
  then
    return 2
  fi
  # Immediate expansion is intentional here, not the mistake SC2064
  # usually flags: $resolved_config is a `local` that won't exist in any
  # active scope by the time an EXIT trap actually fires (confirmed
  # empirically -- a single-quoted, truly deferred version threw
  # "resolved_config: unbound variable" under this script's set -u,
  # since traps evaluate in whatever scope is active when they fire, not
  # the scope `trap` was called from). Baking the resolved path in as a
  # literal string now is the whole point.
  # shellcheck disable=SC2064
  [[ "$resolved_config" != "$config" ]] && trap "rm -f '$resolved_config'" EXIT
  config="$resolved_config"

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  local DEVICE_SERIAL CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH CURRENT_PROFILE CURRENT_URL CURRENT_STATE_INSTALLED CURRENT_STATE_DISABLED
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"

    {
      printf 'NAME\tPKG\tSTORE\tSTATUS\n'
      {
        while IFS='§' read -r CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH CURRENT_PROFILE CURRENT_URL CURRENT_STATE_INSTALLED CURRENT_STATE_DISABLED <&3
        do
          # See for_each_app's comment on the same guard.
          [[ -z "$CURRENT_PKG" ]] && continue

          if [[ "$CURRENT_STATE_INSTALLED" == false ]]
          then
            if is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
            then
              printf '%s\t%s\t%s\tunwanted\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
            else
              printf '%s\t%s\t%s\tremoved\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
            fi
          elif ! is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
          then
            printf '%s\t%s\t%s\tmissing\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
          elif is_pkg_disabled "$DEVICE_SERIAL" "$CURRENT_PKG"
          then
            printf '%s\t%s\t%s\tdisabled\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
          else
            printf '%s\t%s\t%s\tinstalled\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
          fi
        done 3< <(app_rows "$config")

        if [[ -n "$full" ]]
        then
          local -a extra_pkgs
          mapfile -t extra_pkgs < <(list_extra_pkgs "$config" "$DEVICE_SERIAL")

          local extra_pkg
          for extra_pkg in "${extra_pkgs[@]}"
          do
            printf '%s\t%s\t%s\textra\n' "$extra_pkg" "$extra_pkg" "?"
          done
        fi
      } | sort -t $'\t' -k"${sort_field},${sort_field}" -f
    } | render_table | colorize_word installed "$C_GREEN" | colorize_word missing "$C_YELLOW" | colorize_word extra "$C_RED" | colorize_word disabled "$C_CYAN" | colorize_word unwanted "$C_RED" | colorize_word removed "$C_GREEN"
  done

  maybe_run_adb_stop_cmd "$config" "$DRY_RUN"
}

# Read-only, same shape as cmd_diff but for root modules (APatch APModules
# / Magisk modules -- same on-disk convention, one command covers either)
# instead of apps: shows each configured module's install/enabled state on
# the device, `--full` also lists installed-but-unconfigured modules as
# "extra". Does not install/enable/disable/uninstall anything -- that's
# deliberately out of scope for now (see AGENTS.md for why: module state
# changes only take effect on next boot for both frameworks, and APatch's
# own `module install` has a documented CLI-only failure mode the GUI
# doesn't hit, neither of which this codebase has a good answer for yet).
cmd_modules() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local cli_framework=""
  local bulk=""
  local full=""
  local DRY_RUN=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --root-framework)
        cli_framework="$2"
        shift 2
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      --full)
        full=1
        shift
        ;;
      -k|--dry-run|--dryrun)
        # This command itself is already read-only (nothing to preview),
        # but still tracked so maybe_run_adb_stop_cmd at the end can
        # respect it (see its comment).
        DRY_RUN=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  case "$cli_framework" in
    ""|apatch|magisk)
      ;;
    *)
      log_error "Invalid --root-framework value: $cli_framework (expected apatch or magisk)"
      return 2
      ;;
  esac

  check_deps adb yq jq

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local resolved_config
  if ! resolved_config="$(resolve_config "$config")"
  then
    return 2
  fi
  # Immediate expansion is intentional here, not the mistake SC2064
  # usually flags: $resolved_config is a `local` that won't exist in any
  # active scope by the time an EXIT trap actually fires (confirmed
  # empirically -- a single-quoted, truly deferred version threw
  # "resolved_config: unbound variable" under this script's set -u,
  # since traps evaluate in whatever scope is active when they fire, not
  # the scope `trap` was called from). Baking the resolved path in as a
  # literal string now is the whole point.
  # shellcheck disable=SC2064
  [[ "$resolved_config" != "$config" ]] && trap "rm -f '$resolved_config'" EXIT
  config="$resolved_config"

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  local -a configured_rows
  mapfile -t configured_rows < <(yq -r '(.modules // [])[] | [.id, (.name // .id)] | join("§")' "$config")

  local DEVICE_SERIAL framework
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"

    if ! framework="$(resolve_root_framework "$config" "$cli_framework" "$DEVICE_SERIAL")"
    then
      log_ok "Root not enabled/detected on $DEVICE_SERIAL"
      continue
    fi

    local -a device_rows
    mapfile -t device_rows < <(list_root_modules "$DEVICE_SERIAL" "$framework")

    {
      printf 'NAME\tID\tVERSION\tENABLED\tSTATUS\n'
      {
        local crow cid cname drow did dname dversion denabled found
        for crow in "${configured_rows[@]}"
        do
          IFS='§' read -r cid cname <<< "$crow"
          found=""

          for drow in "${device_rows[@]}"
          do
            IFS=$'\t' read -r did dname dversion denabled <<< "$drow"
            if [[ "$did" == "$cid" ]]
            then
              printf '%s\t%s\t%s\t%s\tinstalled\n' "$dname" "$did" "$dversion" "$denabled"
              found=1
              break
            fi
          done

          [[ -z "$found" ]] && printf '%s\t%s\t%s\t%s\tmissing\n' "$cname" "$cid" "-" "-"
        done

        if [[ -n "$full" ]]
        then
          for drow in "${device_rows[@]}"
          do
            IFS=$'\t' read -r did dname dversion denabled <<< "$drow"
            found=""
            for crow in "${configured_rows[@]}"
            do
              IFS='§' read -r cid cname <<< "$crow"
              [[ "$did" == "$cid" ]] && found=1 && break
            done
            [[ -n "$found" ]] && continue
            printf '%s\t%s\t%s\t%s\textra\n' "$dname" "$did" "$dversion" "$denabled"
          done
        fi
      } | sort -t $'\t' -k1,1 -f
    } | render_table | colorize_word installed "$C_GREEN" | colorize_word missing "$C_YELLOW" | colorize_word extra "$C_RED"
  done

  maybe_run_adb_stop_cmd "$config" "$DRY_RUN"
}

# `pm list packages -i` reports the installer attribution package, which is
# a decent (if imperfect) signal for where an app actually came from:
#   com.android.vending           -> the Play Store app itself       -> gplay
#   org.fdroid.fdroid             -> the F-Droid client itself       -> fdroid
#   *obtainium*                   -> Obtainium (GitHub-release apps) -> github
#   com.google.android.packageinstaller / com.android.packageinstaller / null
#                                  -> a raw APK was opened/installed directly
#                                     (adb install, a browser download, ...),
#                                     including declaroid-installed github/
#                                     local apps and split (install-multiple)
#                                     gplay apps -- see install_apk_files's
#                                     comment for why those can't set -i
#                                  -> unknown; declaroid can't recover repo/
#                                     asset/path from this alone
store_for_installer() {
  case "$1" in
    com.android.vending)
      printf 'gplay\n'
      ;;
    org.fdroid.fdroid)
      printf 'fdroid\n'
      ;;
    *obtainium*)
      printf 'github\n'
      ;;
    *)
      printf '\n'
      ;;
  esac
}

# Some well-known packages have one true, stable install source regardless
# of how *this* device's copy actually got there -- installer attribution
# can't tell us that (they're typically sideloaded, ending up installer=
# packageinstaller/null just like any manually-installed APK). Used by
# generate-config to emit a concrete, working entry for these specific
# packages instead of the usual "store unknown"/empty-repo placeholder.
# Emits store§url§repo§asset (unused fields for a given store are empty).
known_pkg_override() {
  case "$1" in
    org.fdroid.fdroid)
      printf 'url§https://f-droid.org/F-Droid.apk§§\n'
      ;;
    dev.imranr.obtainium.fdroid | dev.imranr.obtainium)
      # jq/yq test() matches this as a substring of the filename, not
      # required to match the whole thing, so this can't accidentally
      # match e.g. app-arm64-v8a-release.apk -- verified against a real
      # release (github.com/ImranR98/Obtainium, tag v1.6.10): matches
      # exactly app-release.apk, nothing else, out of ~30 assets.
      printf 'github§§ImranR98/Obtainium§app-release\\.apk$\n'
      ;;
    com.topjohnwu.magisk)
      # Magisk itself is never on Google Play or F-Droid -- it's normally
      # sideloaded (installer=null/packageinstaller either way), so without
      # this it'd always come out as a "store unknown" TODO. Can't rely on
      # the default '\.apk$' asset pattern here: every release also ships
      # an "app-debug.apk" alongside the real "Magisk-vX.Y.apk" (checked
      # the last 5 releases, both assets present every time), so the
      # default would match both and error out at install time -- this
      # pattern narrows it to just the versioned release build.
      printf 'github§§topjohnwu/Magisk§^Magisk-v.*\\.apk$\n'
      ;;
    *)
      return 1
      ;;
  esac
}

# Package IDs that are GMS/AOSP system plumbing rather than user-facing
# apps -- these routinely leak into `pm list packages -3` ("third-party")
# because they've been updated via the Play Store at some point, which is
# enough for Android to stop counting them as system packages even though
# they're not something you'd ever want to declaratively "install". This is
# a best-effort denylist, not an exhaustive one -- add to it as needed.
is_system_plumbing_pkg() {
  case "$1" in
    com.android.vending | \
    com.google.android.gms | \
    com.google.android.gsf | \
    com.google.android.gsf.login | \
    com.google.android.webview | \
    com.google.android.trichromelibrary | \
    com.google.android.modulemetadata | \
    com.google.android.safetycore | \
    com.google.android.contactkeys | \
    com.android.providers.contactkeys | \
    com.google.android.apps.work.clouddpc | \
    com.google.android.ims | \
    com.google.android.packageinstaller | \
    com.android.packageinstaller | \
    com.google.android.partnersetup | \
    com.google.android.settings.intelligence | \
    com.google.android.as | \
    com.google.android.printservice.recommendation | \
    com.google.android.tag | \
    com.google.android.feedback | \
    com.google.android.onetimeinitializer | \
    com.google.android.configupdater | \
    com.google.android.ext.services | \
    com.google.android.ext.shared | \
    com.google.android.federatedcompute | \
    com.google.android.odad | \
    com.google.android.captiveportallogin | \
    com.google.android.cellbroadcastreceiver | \
    com.google.android.cellbroadcastservice | \
    com.google.android.networkstack | \
    com.google.android.networkstack.permissionconfig | \
    com.google.android.euicc | \
    com.google.android.hotspot2.osulogin | \
    com.google.android.wfcactivation | \
    com.google.android.apps.accessibility.voiceaccess | \
    com.google.android.apps.healthdata | \
    com.google.ar.core)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# Wraps a string as a double-quoted YAML scalar, escaping backslashes and
# double quotes. Used for `name`, since it's an arbitrary human-readable
# string (unlike `pkg`, which is always a safe bare identifier).
yaml_quote_scalar() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '"%s"\n' "$s"
}

# Runs $2 through a root shell on device $1. The whole `su -c '...'` must
# reach `adb shell` as ONE argument, not as several bare words split across
# `shell su -c '...'` -- confirmed empirically: `su -c` execs its argument
# directly (no shell involved) when handed multiple separate words, so
# shell syntax (`;`, `for`/`do`/`done`, glob expansion) only works when the
# whole command reaches it as a single string. `adb shell "su -c 'X'"`
# (this function's exact form) gives it that single string; `adb shell su
# -c 'X'` does not -- it silently reconstructs the remote command by
# rejoining `su`/`-c`/`X` with spaces, which either drops X's quoting
# entirely or (for anything with shell keywords in it) fails outright with
# `syntax error: unexpected 'do'` from the remote shell. Wrapped in a
# timeout since, unlike every other adb call in this script, this one can
# genuinely hang forever if root was never granted to Shell and the
# framework's app is sitting on an unanswered superuser prompt on-screen.
# $3 overrides the default 15s timeout -- too short for an actual module
# install (extracting/running a module's own scripts can take longer than
# a quick `command -v`/`module list` probe).
run_root_shell() {
  local device="$1"
  local cmd="$2"
  local secs="${3:-15}"

  timeout "$secs" adb -s "$device" shell "su -c '$cmd'" </dev/null 2>/dev/null | tr -d '\r'
}

# Prints "apatch" or "magisk" (whichever's CLI binary is reachable through
# a root shell) and returns 0, or returns 1 with no output if neither is.
# Deliberately does NOT check for the frameworks' own app packages
# (`me.bmax.apatch`/`com.topjohnwu.magisk`) as a shortcut -- Magisk
# explicitly supports hiding/repackaging its own manager app under a
# random package id specifically to evade exactly this kind of check
# (confirmed against a real device: Magisk was fully installed and
# running, but `pm list packages com.topjohnwu.magisk` found nothing) --
# so probing the root shell directly is the only way that's actually
# reliable for both.
detect_root_framework() {
  local device="$1"

  if [[ -n "$(run_root_shell "$device" 'command -v apd')" ]]
  then
    printf 'apatch\n'
    return 0
  fi

  if [[ -n "$(run_root_shell "$device" 'command -v magisk')" ]]
  then
    printf 'magisk\n'
    return 0
  fi

  return 1
}

# Resolves which root framework applies, in priority order: an explicit
# --root-framework always wins; otherwise the config's `root.framework` is
# used, unless `root.enabled` is explicitly `false` (in which case root
# module handling is skipped entirely, no auto-detection attempted);
# falling back to detect_root_framework against the device if the config
# doesn't pin one down either. Prints the framework name and returns 0, or
# prints nothing and returns 1 if root module handling doesn't apply here
# (explicitly disabled, or nothing usable found).
resolve_root_framework() {
  local config="$1"
  local cli_framework="$2"
  local device="$3"
  local explicitly_disabled cfg_framework

  if [[ -n "$cli_framework" ]]
  then
    printf '%s\n' "$cli_framework"
    return 0
  fi

  if [[ -n "$config" && -f "$config" ]]
  then
    # NOT `.root.enabled // ""` -- jq/yq's `//` treats a `false` *value* the
    # same as a *missing* key (both are falsy), so that would've silently
    # thrown away an explicit `root.enabled: false` and fed it right back
    # into the auto-detect path below, doing the opposite of what the
    # config asked for. Comparing directly against `false` sidesteps `//`
    # entirely -- confirmed against a real config with `root.enabled: false`
    # set, which this second form correctly short-circuits on.
    explicitly_disabled="$(yq -r '.root.enabled == false' "$config")"
    [[ "$explicitly_disabled" == "true" ]] && return 1

    cfg_framework="$(yq -r '.root.framework // ""' "$config")"
    if [[ -n "$cfg_framework" ]]
    then
      printf '%s\n' "$cfg_framework"
      return 0
    fi
  fi

  detect_root_framework "$device"
}

# Emits configured Obtainium-tracked repos as one row per entry: pkg, url,
# settings (a compact JSON object of Obtainium `additionalSettings`
# overrides, defaulting to "{}") -- joined with U+00A7, same convention as
# app_rows/module_rows. `settings:` keys are passed straight through
# verbatim, using Obtainium's own upstream setting names as-is (e.g.
# `includePrereleases`) -- deliberately not translated/renamed into a
# declaroid-specific vocabulary, which would just be an extra layer to
# keep in sync as Obtainium adds/renames settings over time, for no real
# benefit over just documenting the setting name in a comment/example.
# `to_json(0)` (not the bare `to_json`, which pretty-prints across
# multiple lines and would break the one-row-per-line convention every
# row-consuming loop in this file relies on) gives compact single-line
# JSON.
obtainium_rows() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.obtainium // [])[] | [.pkg, .url, (.settings // {} | to_json(0))] | join("§")' "$config"
}

# Combines explicit obtainium: rows (obtainium_rows, always included and
# always winning on a pkg collision) with ones auto-derived from apps:
# store: github entries -- for an app with no per-app obtainium: override,
# whether it's included at all depends on the top-level
# obtainium_auto_track: default; an app's own obtainium: true forces it in
# even with that default off, obtainium: false forces it out even with
# that default on. Explicit obtainium: entries always win over an
# auto-derived one for the same pkg (checked first, added to `seen`
# before the apps: scan even starts) -- an app that's both explicitly
# listed under obtainium: (with its own settings:) and also
# apps:-eligible for auto-tracking only ever gets that one
# explicit, settings-carrying row, never a second, settings-less
# auto-derived duplicate for the same pkg.
effective_obtainium_rows() {
  local config="$1"

  local -A seen=()
  local -a explicit_rows
  mapfile -t explicit_rows < <(obtainium_rows "$config")

  local row pkg
  for row in "${explicit_rows[@]}"
  do
    [[ -z "$row" ]] && continue
    IFS='§' read -r pkg _ _ <<< "$row"
    seen["$pkg"]=1
    printf '%s\n' "$row"
  done

  local auto_track
  auto_track="$(yq -r '.obtainium_auto_track == true' "$config")"

  local -a github_apps
  # shellcheck disable=SC2016
  mapfile -t github_apps < <(yq -r '.apps[] | select(.store == "github") | [.pkg, .repo, has("obtainium"), (.obtainium // false)] | join("§")' "$config")

  local repo has_override override_val effective
  for row in "${github_apps[@]}"
  do
    [[ -z "$row" ]] && continue
    IFS='§' read -r pkg repo has_override override_val <<< "$row"
    [[ -n "${seen[$pkg]:-}" ]] && continue
    [[ -z "$repo" ]] && continue

    if [[ "$has_override" == true ]]
    then
      effective="$override_val"
    else
      effective="$auto_track"
    fi
    [[ "$effective" != true ]] && continue

    seen["$pkg"]=1
    printf '%s§https://github.com/%s§{}\n' "$pkg" "$repo"
  done
}

# Obtainium (an app-update-tracking app) self-updates whatever it tracks by
# reading/writing one JSON file per tracked app under its own external
# app-storage dir -- `/storage/emulated/0/Android/data/<obtainium
# pkg>/files/app_data/<tracked pkg>.json`.
#
# **Does NOT actually require root**, despite this feature originally
# being built assuming it did -- confirmed live against a real non-rooted
# device (zf10, a stock `user` build with `run-as` refusing outright:
# "package not debuggable"). Plain, unprivileged `adb shell` (uid 2000,
# gid 2000, NOT root) is still, by stock AOSP default, a *supplementary*
# member of both `sdcard_rw` and `ext_data_rw` -- the exact groups that
# own every app's `Android/data/<pkg>` tree (confirmed via `id` and via
# `ls -la` on that path: `drwxrws--- ... ext_data_rw`). The `s` in
# `rws` is SGID: any file plain `adb shell` creates under that directory
# automatically inherits the directory's group, regardless of shell's own
# primary group -- so a file plain shell writes there ends up
# `shell:ext_data_rw` (or `shell:sdcard_rw`), group-readable, which is all
# Obtainium itself (running with that same group as one of *its* own
# supplementary groups) needs to read it back. No `su`, no `run-as`,
# no owner-uid match required at all. Live-verified end to end on zf10:
# seeded a real entry via plain `adb shell`/`adb push`, no `su` anywhere,
# and a screenshot of Obtainium's own Apps list afterward showed it
# picked up immediately with full metadata already resolved.
#
# Root is still preferred *when available* (checked via
# resolve_root_framework, not required) purely because it lets the
# written file be `chown`'d to the app's own exact UID instead of relying
# on SGID group inheritance -- a marginally more faithful match to what
# Obtainium would produce writing the file itself, not something the
# non-root path is missing out on functionally. use_root below picks
# between the two purely on that basis; either one is a fully supported,
# equally real code path, not a root-preferred-with-a-degraded-fallback.
#
# This only ever *seeds* a missing entry, never touches one that's
# already tracked -- Obtainium's own next update check (background,
# ~15min via WorkManager, or whenever the user next opens the app) fills
# in everything else (name, author, latestVersion, apkUrls, ...) on its
# own; there's no clean way to force that check immediately from adb
# (checked Obtainium's own source: only interactive deep-links exist,
# `obtainium://add/...` and `obtainium://app/...`, both requiring a
# confirmation tap, not something declaroid should fake via blind
# screen-coordinate taps).
#
# The minimal JSON that follows was confirmed by reading Obtainium's own
# `App.fromJson`/`App` model (source_provider.dart): `id`/`url`/`author`/
# `name`/`additionalSettings` are the only fields it requires outright
# (author/name may be empty strings; additionalSettings must be *a* JSON
# string, "{}" is fine); everything else (latestVersion, apkUrls,
# preferredApkIndex, lastUpdateCheck, categories, ...) has an in-code
# fallback and can be omitted entirely. Verified against a real rooted
# device (mp4, previously-empty Obtainium install) and again against a
# real non-rooted one (zf10): the seeded entry showed up immediately in
# Obtainium's own app list as a trackable, not-yet-installed app with the
# correct URL/pkg, confirmed via a real screenshot in both cases -- not
# vendoring Obtainium's full per-app JSON blob (much of which is its own
# live-refreshed cache state) was a hard requirement here, not a
# nice-to-have.
#
# Runs $cmd via su if $use_root, else via plain, unprivileged adb shell.
obtainium_shell() {
  local device="$1"
  local use_root="$2"
  local cmd="$3"

  if [[ -n "$use_root" ]]
  then
    run_root_shell "$device" "$cmd"
  else
    timeout 15 adb -s "$device" shell "$cmd" </dev/null 2>/dev/null | tr -d '\r'
  fi
}

sync_obtainium_repos() {
  local config="$1"
  local device="$2"
  local cli_root_framework="$3"

  local -a rows
  mapfile -t rows < <(effective_obtainium_rows "$config")
  [[ ${#rows[@]} -eq 0 ]] && return 0
  [[ ${#rows[@]} -eq 1 && -z "${rows[0]}" ]] && return 0

  local use_root=""
  resolve_root_framework "$config" "$cli_root_framework" "$device" >/dev/null 2>&1 && use_root=1

  # Obtainium ships (at least) two package id variants -- the plain GitHub
  # release build (dev.imranr.obtainium) and F-Droid's own separately-built
  # flavor (dev.imranr.obtainium.fdroid, confirmed via aapt2 dump badging
  # to be a genuinely different package, not just a config typo -- see
  # AGENTS.md). Each has its own, entirely separate Android/data storage,
  # so this only works against whichever variant is actually installed;
  # .fdroid is preferred if somehow both are present.
  local obtainium_pkg
  if is_installed "$device" dev.imranr.obtainium.fdroid
  then
    obtainium_pkg=dev.imranr.obtainium.fdroid
  elif is_installed "$device" dev.imranr.obtainium
  then
    obtainium_pkg=dev.imranr.obtainium
  else
    # A real (non-dry-run) apply installs configured apps -- including
    # Obtainium itself, if it's one of them -- before ever reaching this
    # function, so "not installed yet" here is a real, immediate error
    # there. --dry-run never actually installs anything, though, so a
    # config that both installs Obtainium via apps: and configures
    # obtainium: repos would spuriously error on a fresh device's very
    # first preview, even though the real run right after it would work
    # fine (confirmed live: exactly this happened on a real device with
    # Obtainium not yet installed but present in apps:). Softened for
    # --dry-run only: if Obtainium is configured to be installed at all,
    # this is expected, not a misconfiguration -- note it and move on
    # rather than erroring. A config that configures obtainium: without
    # installing Obtainium via apps: anywhere still correctly errors even
    # in --dry-run, since no future real run would fix that either.
    local -a would_install_pkgs
    mapfile -t would_install_pkgs < <(yq -r '.apps[] | select(.pkg == "dev.imranr.obtainium" or .pkg == "dev.imranr.obtainium.fdroid") | select((.state.installed == false) | not) | .pkg' "$config")

    if [[ -n "$DRY_RUN" && ${#would_install_pkgs[@]} -gt 0 ]]
    then
      log_ok "Obtainium (${would_install_pkgs[0]}) isn't installed on $device yet, but this apply would install it -- skipping the Obtainium repo(s) preview until then"
      return 0
    fi

    log_error "obtainium: entries are configured but neither dev.imranr.obtainium nor dev.imranr.obtainium.fdroid is installed on $device"
    return 1
  fi

  local storage_dir="/storage/emulated/0/Android/data/$obtainium_pkg"
  local app_data_dir="$storage_dir/files/app_data"

  # Only needed for a real write below -- dry-run only ever checks
  # already-tracked-or-not via a plain file existence test further down,
  # so it doesn't need $owner (or a storage dir that might not exist yet)
  # at all.
  local owner=""
  if [[ -z "$DRY_RUN" ]]
  then
    if [[ -z "$(obtainium_shell "$device" "$use_root" "[ -d '$app_data_dir' ] && echo yes")" ]]
    then
      # A fresh install has no scoped-storage dir at all yet -- Android
      # only creates Android/data/<pkg> the first time the app itself
      # runs, not at install time (confirmed against a real device: apply
      # installed dev.imranr.obtainium.fdroid earlier in the very same
      # run, and its storage dir didn't exist until launched once).
      # `monkey`'s LAUNCHER-category launch works headlessly (no need to
      # resolve/hardcode a main activity name); neither it nor
      # `am force-stop` need root either way. `files/app_data` itself is
      # created by Obtainium's own Dart init code partway through startup
      # -- not by Android at process start, and not instantly -- so a
      # single fixed sleep is unreliable (confirmed against a real device:
      # 2s was enough once, not enough on a later run against the same
      # app). Poll for it instead, up to 10s, then force-stop the app
      # right back either way -- it's only needed running long enough to
      # create its own directory once.
      log_step "Launching $obtainium_pkg once to create its storage directory"
      adb -s "$device" shell monkey -p "$obtainium_pkg" -c android.intent.category.LAUNCHER 1 >/dev/null 2>&1

      local waited=0
      while [[ -z "$(obtainium_shell "$device" "$use_root" "[ -d '$app_data_dir' ] && echo yes")" && "$waited" -lt 10 ]]
      do
        sleep 1
        waited=$((waited + 1))
      done

      adb -s "$device" shell am force-stop "$obtainium_pkg" >/dev/null 2>&1

      if [[ -z "$(obtainium_shell "$device" "$use_root" "[ -d '$app_data_dir' ] && echo yes")" ]]
      then
        log_error "$obtainium_pkg's app_data directory never appeared on $device after launching it, skipping configured Obtainium repo(s)"
        return 1
      fi
    fi

    if [[ -n "$use_root" ]]
    then
      # The new file ends up owned by Obtainium's own app UID/GID (not
      # root's) when root is available -- confirmed by matching a real
      # device's existing app_data files (owner u0_a197:sdcard_rw there,
      # but the exact uid varies per device/user, so this reads it from
      # the app's own storage dir rather than hardcoding a name). Not
      # strictly required for Obtainium to read the file back (see the
      # non-root SGID-group path above), just a closer match to what
      # Obtainium would produce writing it itself.
      owner="$(obtainium_shell "$device" "$use_root" "stat -c '%U:%G' '$storage_dir'")"

      if [[ -z "$owner" ]]
      then
        log_error "Could not determine $obtainium_pkg's storage owner on $device (even after launching it once), skipping configured Obtainium repo(s)"
        return 1
      fi
    elif [[ -z "$(obtainium_shell "$device" "" "[ -w '$app_data_dir' ] && echo yes")" ]]
    then
      # No root, and plain adb shell isn't a member of this dir's group
      # either (confirmed possible in principle, just not seen on any
      # real device tested so far -- every one had shell in sdcard_rw/
      # ext_data_rw by stock default). A real, if apparently rare,
      # failure mode -- not treated as a bug, just nothing more
      # declaroid can do without root.
      log_error "Neither root nor plain adb shell can write to $app_data_dir on $device, skipping configured Obtainium repo(s)"
      return 1
    fi
  fi

  local row pkg url settings_json rc=0
  for row in "${rows[@]}"
  do
    [[ -z "$row" ]] && continue
    IFS='§' read -r pkg url settings_json <<< "$row"

    if [[ -n "$(obtainium_shell "$device" "$use_root" "[ -e '$app_data_dir/$pkg.json' ] && echo yes")" ]]
    then
      [[ -n "$VERBOSE" ]] && log_skip "Obtainium repo $pkg already tracked"
      continue
    fi

    log_step "Adding Obtainium repo $pkg ($url)"

    if [[ -n "$DRY_RUN" ]]
    then
      printf '  would seed Obtainium tracking for %s\n' "$pkg"
      continue
    fi

    local json_file
    json_file="$(mktemp --suffix=.json)"
    if ! jq -n --arg id "$pkg" --arg url "$url" --argjson settings "$settings_json" \
      '{id: $id, url: $url, author: "", name: "", additionalSettings: ($settings | tojson)}' \
      > "$json_file"
    then
      log_error "Failed to build Obtainium JSON for $pkg"
      rm -f "$json_file"
      rc=1
      continue
    fi

    local remote_tmp="/data/local/tmp/declaroid-obtainium-$pkg.json"
    if ! adb -s "$device" push "$json_file" "$remote_tmp" >/dev/null 2>&1
    then
      log_error "Failed to push Obtainium JSON for $pkg"
      rm -f "$json_file"
      rc=1
      continue
    fi
    rm -f "$json_file"

    local write_cmd="cp '$remote_tmp' '$app_data_dir/$pkg.json'"
    [[ -n "$use_root" ]] && write_cmd+=" && chown $owner '$app_data_dir/$pkg.json'"
    write_cmd+=" && chmod 660 '$app_data_dir/$pkg.json'"

    if obtainium_shell "$device" "$use_root" "$write_cmd" >/dev/null
    then
      log_ok "Obtainium repo $pkg added"
    else
      log_error "Failed to install Obtainium JSON for $pkg"
      rc=1
    fi

    adb -s "$device" shell "rm -f '$remote_tmp'" >/dev/null 2>&1
  done

  return "$rc"
}

# apd's own `module list` JSON is the source of truth for which modules
# APatch actually recognizes -- a raw module.prop directory scan would
# also pick up modules apd itself skips (seen for real: a "TA_utl"
# companion module directory whose module.prop is permission-denied even
# to a root shell; apd's list simply omits it). All fields in this JSON
# are emitted as strings by apd itself, "true"/"false" included -- not
# JSON booleans, confirmed against a real device's output.
# Emits id\tname\tversion\tenabled(yes/no) rows.
list_apatch_modules() {
  local device="$1"
  local json

  json="$(run_root_shell "$device" 'apd module list')"
  [[ -z "$json" ]] && return 0

  printf '%s' "$json" | jq -r '.[] | [.id, .name, .version, (if .enabled == "true" then "yes" else "no" end)] | @tsv'
}

# Unlike APatch, this build of Magisk has no `--list-modules` (or any
# module-listing) subcommand at all -- checked `magisk --help` against a
# real device: only --install-module/--remove-modules exist for modules,
# nothing that lists them. Falls back to the traditional method every
# Magisk module itself relies on: read module.prop out of each
# /data/adb/modules/<id>/ directory, and check for a `disable` marker file
# (Magisk's own "installed but disabled" convention -- a module is fully
# removed via a `remove` marker instead, but that's a pending-uninstall
# state that shouldn't matter for what this reports, so it isn't checked).
# Pushes a small script to the device and runs it via su rather than
# inlining the for-loop directly through run_root_shell: that would need
# the loop's own single quotes (for module.prop's path) nested inside the
# `su -c '...'` single-quoting run_root_shell already needs, which is
# exactly the kind of escaping-inside-escaping this codebase avoids
# elsewhere (see pick_search_result's preview script, same reasoning).
# Emits id\tname\tversion\tenabled(yes/no) rows.
list_magisk_modules() {
  local device="$1"
  local script remote_path

  script="$(mktemp)"
  cat > "$script" <<'MAGISK_SCAN_EOF'
#!/system/bin/sh
for d in /data/adb/modules/*/
do
  printf '===MODULE===\n'
  cat "${d}module.prop" 2>/dev/null
  [ -f "${d}disable" ] && printf 'declaroid_disabled=1\n'
done
MAGISK_SCAN_EOF

  remote_path="/data/local/tmp/declaroid-list-magisk-modules.sh"
  if ! adb -s "$device" push "$script" "$remote_path" >/dev/null 2>&1
  then
    rm -f "$script"
    return 1
  fi
  rm -f "$script"

  local -a lines
  mapfile -t lines < <(run_root_shell "$device" "sh $remote_path")
  adb -s "$device" shell "rm -f $remote_path" >/dev/null 2>&1

  local line key val id="" name="" version="" enabled="yes" have_module=""

  for line in "${lines[@]}"
  do
    if [[ "$line" == "===MODULE===" ]]
    then
      if [[ -n "$have_module" && -n "$id" ]]
      then
        [[ -z "$name" ]] && name="$id"
        printf '%s\t%s\t%s\t%s\n' "$id" "$name" "$version" "$enabled"
      fi
      id="" name="" version="" enabled="yes"
      have_module=1
      continue
    fi

    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    val="${line#*=}"

    case "$key" in
      id) id="$val" ;;
      name) name="$val" ;;
      version) version="$val" ;;
      declaroid_disabled) enabled="no" ;;
    esac
  done

  if [[ -n "$have_module" && -n "$id" ]]
  then
    [[ -z "$name" ]] && name="$id"
    printf '%s\t%s\t%s\t%s\n' "$id" "$name" "$version" "$enabled"
  fi
}

list_root_modules() {
  local device="$1"
  local framework="$2"

  case "$framework" in
    apatch)
      list_apatch_modules "$device"
      ;;
    magisk)
      list_magisk_modules "$device"
      ;;
    *)
      log_error "Unknown root framework '$framework' (expected apatch or magisk)"
      return 1
      ;;
  esac
}

# Cached alongside per-package APK downloads under $CACHE_ROOT/<pkg>/ --
# `declaroid clear-cache [pkg]` already wipes that whole directory, so label
# caching gets cache invalidation for free without any extra bookkeeping.
label_cache_file_for() {
  printf '%s/.label\n' "$(cache_dir_for "$1")"
}

# Pulls a package's base.apk and reads its default (unlocalized)
# application-label via aapt2. Slow (transfers the whole APK -- can be
# 100+ MB) and best-effort: prints nothing and returns non-zero on any
# failure, so callers should fall back to the package id as the name.
# Checks/populates the label cache; see label_cache_file_for.
resolve_app_label() {
  local device="$1"
  local pkg="$2"
  local apk_path tmp_apk label cache_file

  cache_file="$(label_cache_file_for "$pkg")"

  if [[ -s "$cache_file" ]]
  then
    cat "$cache_file"
    return 0
  fi

  apk_path="$(adb -s "$device" shell pm path "$pkg" </dev/null 2>/dev/null | head -1 | tr -d '\r')"
  apk_path="${apk_path#package:}"

  if [[ -z "$apk_path" ]]
  then
    return 1
  fi

  tmp_apk="$(mktemp --suffix=.apk)"

  if ! adb -s "$device" pull "$apk_path" "$tmp_apk" >/dev/null 2>&1
  then
    rm -f "$tmp_apk"
    return 1
  fi

  label="$(aapt2 dump badging "$tmp_apk" 2>/dev/null | grep -m1 "^application-label:")"
  rm -f "$tmp_apk"

  if [[ "$label" =~ ^application-label:\'(.*)\'$ ]]
  then
    label="${BASH_REMATCH[1]}"
    mkdir -p "$(dirname "$cache_file")"
    printf '%s\n' "$label" > "$cache_file"
    printf '%s\n' "$label"
    return 0
  fi

  return 1
}

cmd_generate_config() {
  local cli_device=""
  local output=""
  local include_system=""
  local resolve_names=1
  local jobs=6
  local cli_root_framework=""
  local DRY_RUN=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      -o|--output)
        output="$2"
        shift 2
        ;;
      -k|--dry-run|--dryrun)
        DRY_RUN=1
        shift
        ;;
      --system)
        include_system=1
        shift
        ;;
      --no-labels|--fast)
        resolve_names=""
        shift
        ;;
      -j|--jobs)
        jobs="$2"
        shift 2
        ;;
      --root-framework)
        cli_root_framework="$2"
        shift 2
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  case "$cli_root_framework" in
    ""|apatch|magisk)
      ;;
    *)
      log_error "Invalid --root-framework value: $cli_root_framework (expected apatch or magisk)"
      return 2
      ;;
  esac

  check_deps adb

  local device
  if ! device="$(resolve_devices "$cli_device" "" "")"
  then
    return 2
  fi

  if [[ -n "$resolve_names" ]] && ! command -v aapt2 >/dev/null 2>&1
  then
    log_warn "aapt2 not found, app names will default to the package id (install aapt2 or pass --no-labels/--fast to silence this)"
    resolve_names=""
  fi

  log_step "Generating config from $device"

  local -a scope_flags=(-3)
  [[ -n "$include_system" ]] && scope_flags=()

  # Enumerate every Android user/profile on the device (the personal one,
  # plus any Work Profile / Island / secondary full user -- there can be
  # more than one of the latter) so each app's install scope can be checked
  # against all of them, not just assumed. Falls back to just "0" if this
  # can't be determined (no multi-user support, older Android).
  local -a profile_ids=()
  local -a profile_names=()
  local -a user_lines
  mapfile -t user_lines < <(adb -s "$device" shell pm list users </dev/null 2>/dev/null | tr -d '\r')
  local uline
  for uline in "${user_lines[@]}"
  do
    [[ "$uline" =~ UserInfo\{([0-9]+): ]] && profile_ids+=("${BASH_REMATCH[1]}")
  done
  [[ ${#profile_ids[@]} -eq 0 ]] && profile_ids=(0)

  local current_profile
  current_profile="$(resolve_target_user "$device")"

  # Give every profile a short alias name for the generated `profiles:`
  # section: the auto-detected current one is always "main"; others get a
  # slugified version of their actual name (from `pm list users`), falling
  # back to "profileN" if that's empty, reserved, or a duplicate.
  local -A used_alias_names=()
  local pid pname raw_name slug
  for pid in "${profile_ids[@]}"
  do
    if [[ "$pid" == "$current_profile" ]]
    then
      pname="main"
    else
      raw_name=""
      for uline in "${user_lines[@]}"
      do
        if [[ "$uline" =~ UserInfo\{${pid}:([^:]*): ]]
        then
          raw_name="${BASH_REMATCH[1]}"
          break
        fi
      done
      slug="$(printf '%s' "${raw_name,,}" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
      if [[ -z "$slug" || "$slug" == "main" || "$slug" == "all" || "$slug" == "current" || -n "${used_alias_names[$slug]:-}" ]]
      then
        slug="profile${pid}"
      fi
      pname="$slug"
    fi
    used_alias_names["$pname"]=1
    profile_names+=("$pname")
  done

  local -A id_to_name=()
  local pidx
  for pidx in "${!profile_ids[@]}"
  do
    id_to_name["${profile_ids[$pidx]}"]="${profile_names[$pidx]}"
  done

  # Gather packages+installer per profile (one bulk `pm list packages` call
  # per profile, not per app) so each app's profile field can be set from
  # which profile(s) it actually turned up in, instead of just guessing.
  local -A pkg_installer=()
  local -A pkg_profiles=()
  local pid line pkg installer
  for pid in "${profile_ids[@]}"
  do
    local -a lines
    mapfile -t lines < <(adb -s "$device" shell pm list packages "${scope_flags[@]}" -i --user "$pid" </dev/null 2>/dev/null | tr -d '\r')

    for line in "${lines[@]}"
    do
      [[ "$line" =~ ^package:([^[:space:]]+)[[:space:]]+installer=(.*)$ ]] || continue
      pkg="${BASH_REMATCH[1]}"
      installer="${BASH_REMATCH[2]}"

      is_system_plumbing_pkg "$pkg" && continue

      [[ -z "${pkg_installer[$pkg]:-}" ]] && pkg_installer["$pkg"]="$installer"
      pkg_profiles["$pkg"]+="$pid "
    done
  done

  local -a keep_pkgs
  mapfile -t keep_pkgs < <(printf '%s\n' "${!pkg_installer[@]}" | sort)

  if [[ ${#keep_pkgs[@]} -eq 0 ]]
  then
    log_error "No packages found on $device"
    return 1
  fi

  # Resolving names one at a time (one adb pull + one aapt2 call per app,
  # each easily a few seconds) is the slow part of this command, and it's
  # entirely I/O-bound, so it parallelizes well. This pass runs up to $jobs
  # of them concurrently and throws its own output away -- the point is
  # purely to populate resolve_app_label's on-disk cache (see
  # label_cache_file_for) so the sequential pass below that actually builds
  # the YAML gets fast cache hits instead of doing the work twice.
  if [[ -n "$resolve_names" ]]
  then
    log_step "Resolving ${#keep_pkgs[@]} app name(s) (up to $jobs at a time)"
    local running=0
    for pkg in "${keep_pkgs[@]}"
    do
      resolve_app_label "$device" "$pkg" >/dev/null 2>&1 &
      running=$((running + 1))
      if [[ $running -ge $jobs ]]
      then
        # wait -n returns the exit status of whichever job just finished --
        # resolve_app_label failing for a given app is normal/expected, not
        # a script error, so this must not trip `set -e`.
        wait -n || true
        running=$((running - 1))
      fi
    done
    wait

    # Reorder keep_pkgs by resolved app name (not package id) so the
    # generated config reads name-sorted, human-browsable order --
    # resolve_app_label's on-disk cache was just warmed above, so this
    # second pass is all cache hits (a plain `cat`), not re-downloading
    # anything. Falls back to the package id per-entry exactly like the
    # main loop below does, so the sort key always matches what actually
    # ends up in each entry's `name:` field. Skipped when --no-labels/
    # --fast is in effect: name always equals the package id then, and
    # keep_pkgs is already pkg-sorted above, which is the same order.
    local -a name_pkg_pairs
    local sort_name resolved
    for pkg in "${keep_pkgs[@]}"
    do
      sort_name="$pkg"
      if resolved="$(resolve_app_label "$device" "$pkg")" && [[ -n "$resolved" ]]
      then
        sort_name="$resolved"
      fi
      name_pkg_pairs+=("$sort_name"$'\t'"$pkg")
    done
    # LC_ALL=C: under a UTF-8 locale's collation rules, GNU coreutils'
    # `sort -f` can order "Firefox Nightly" before "Firefox" (confirmed
    # against the packaged binary's bundled coreutils 9.11) -- a locale-
    # collation quirk around how a trailing space is weighted, not
    # something a case-insensitive ASCII sort should be at the mercy of.
    # Forcing plain C/byte-order collation (still with -f for case-
    # insensitivity) makes this deterministic everywhere.
    mapfile -t keep_pkgs < <(printf '%s\n' "${name_pkg_pairs[@]}" | LC_ALL=C sort -f | cut -f2)
  fi

  local yaml
  yaml="$(
    printf '# Generated by declaroid generate-config from %s\n' "$device"
    if [[ -n "$resolve_names" ]]
    then
      printf '# App names were read from each APK (aapt2); rename any that came out\n'
      printf '# wrong or unhelpful.\n'
    else
      printf '# App names default to the package id -- edit them to something readable.\n'
    fi
    printf '# store is detected from the installer attribution (pm list packages -i):\n'
    printf '#   com.android.vending -> gplay, org.fdroid.fdroid -> fdroid, Obtainium -> github.\n'
    printf '# A few well-known packages (the F-Droid/Obtainium clients, Magisk) get\n'
    printf '# a concrete, working store/url or store/repo/asset regardless of installer,\n'
    printf '# since their real source is always the same no matter how they got here.\n'
    printf '# The top-level default below covers the common case (gplay); only apps that\n'
    printf '# differ from it get their own store: line.\n'
    printf '# profiles: gives each detected Android user/profile a short name (the\n'
    printf '# auto-detected current one is always "main"); apps get a profile: <name> only\n'
    printf '# if installed somewhere other than just that current profile -- "all" if\n'
    printf '# installed for every profile found, or a specific profile name if installed\n'
    printf '# for exactly one other one. profile: also accepts a bare id or "all"/"current"\n'
    printf '# directly, with no need for a profiles: entry to back it.\n'
    printf '# Entries marked with a "# TODO" are commented out: reinstalling from this\n'
    printf '# config as-is would fail for them (store could not be determined, or a\n'
    printf '# github repo/asset could not be recovered) -- fix them up and uncomment.\n'
    printf 'device: %s\n' "$device"
    printf 'store: gplay\n'
    printf 'profiles:\n'
    local pidx2
    for pidx2 in "${!profile_ids[@]}"
    do
      printf '  - name: %s\n' "${profile_names[$pidx2]}"
      printf '    id: %s\n' "${profile_ids[$pidx2]}"
    done

    local root_framework
    if root_framework="$(resolve_root_framework "" "$cli_root_framework" "$device")"
    then
      printf 'root:\n'
      printf '  enabled: true\n'
      printf '  framework: %s\n' "$root_framework"

      local -a module_rows
      mapfile -t module_rows < <(list_root_modules "$device" "$root_framework")

      if [[ ${#module_rows[@]} -gt 0 ]]
      then
        printf 'modules:\n'
        local mrow mid mname mversion menabled
        for mrow in "${module_rows[@]}"
        do
          # mversion isn't written to the config (only id/name/enabled
          # are) -- it's runtime info, shown by `modules`, not declared intent.
          # shellcheck disable=SC2034
          IFS=$'\t' read -r mid mname mversion menabled <<< "$mrow"
          printf '  - id: %s\n' "$mid"
          printf '    name: %s\n' "$(yaml_quote_scalar "$mname")"
          [[ "$menabled" == "no" ]] && printf '    enabled: false\n'
        done
      fi
    fi

    printf 'apps:\n'

    local store name resolved todo profile_field override store_url store_repo store_asset
    local -a entry_lines app_profiles
    for pkg in "${keep_pkgs[@]}"
    do
      installer="${pkg_installer[$pkg]}"
      store_url=""
      store_repo=""
      store_asset=""
      if override="$(known_pkg_override "$pkg")"
      then
        IFS='§' read -r store store_url store_repo store_asset <<< "$override"
      else
        store="$(store_for_installer "$installer")"
      fi

      name="$pkg"
      if [[ -n "$resolve_names" ]] && resolved="$(resolve_app_label "$device" "$pkg")" && [[ -n "$resolved" ]]
      then
        name="$resolved"
      fi

      # shellcheck disable=SC2206
      app_profiles=(${pkg_profiles[$pkg]})
      profile_field=""
      # A device with only one enumerated profile has nothing to distinguish
      # -- every app trivially "is in every profile", so app_profiles is
      # always length 1 there and profile_field must stay unset. Without
      # this guard, ${#app_profiles[@]} -ge ${#profile_ids[@]} is vacuously
      # true whenever profile_ids has length 1, marking almost every app
      # profile: all on single-profile devices (confirmed on a real device
      # with no secondary user/Work Profile: 24 of 25 apps got profile: all).
      if [[ ${#profile_ids[@]} -gt 1 ]]
      then
        if [[ ${#app_profiles[@]} -ge ${#profile_ids[@]} ]]
        then
          profile_field="all"
        elif [[ ${#app_profiles[@]} -gt 1 ]]
        then
          # In more than one profile but (per the check above) not literally
          # every enumerated one -- "all" is the closest value expressible via
          # a single --user flag; worst case a reinstall also lands in an
          # extra profile that happened not to have it, which is an
          # acceptable simplification for a "review before use" starting point.
          profile_field="all"
        elif [[ ${#app_profiles[@]} -eq 1 && "${app_profiles[0]}" != "$current_profile" ]]
        then
          profile_field="${id_to_name[${app_profiles[0]}]:-${app_profiles[0]}}"
        fi
      fi

      todo=""
      entry_lines=("  - name: $(yaml_quote_scalar "$name")" "    pkg: $pkg")
      case "$store" in
        github)
          entry_lines+=("    store: github")
          if [[ -n "$store_repo" ]]
          then
            entry_lines+=("    repo: $store_repo")
            # Only emit asset: when known_pkg_override actually gave one --
            # app_rows/the config schema both treat a *missing* asset key as
            # "default to '\.apk$'", but an empty string is present, not
            # missing (`.asset // "\.apk$"` in jq/yq only substitutes on
            # null/false, so `asset: ''` -- which this used to always write
            # whenever store_asset was empty -- became a regex matching
            # every asset in the release, not "let it default". Emitting no
            # asset: line at all when there's nothing to override is the
            # only way to actually mean "use the default".
            [[ -n "$store_asset" ]] && entry_lines+=("    asset: '$store_asset'")
          else
            entry_lines+=('    repo: ""')
            todo="installed via Obtainium -- set repo/asset by hand, original repo is unknown"
          fi
          ;;
        url)
          entry_lines+=("    store: url" "    url: $store_url")
          ;;
        "")
          todo="store unknown (installer=${installer:-none}) -- set store by hand"
          ;;
        gplay)
          # matches the top-level default, no need to repeat it
          ;;
        *)
          entry_lines+=("    store: $store")
          ;;
      esac
      [[ -n "$profile_field" ]] && entry_lines+=("    profile: $profile_field")

      if [[ -n "$todo" ]]
      then
        printf '  # TODO: %s\n' "$todo"
        local eline
        for eline in "${entry_lines[@]}"
        do
          printf '  # %s\n' "${eline#  }"
        done
      else
        printf '%s\n' "${entry_lines[@]}"
      fi
    done
  )"

  if [[ -n "$output" && -z "$DRY_RUN" ]]
  then
    printf '%s\n' "$yaml" > "$output"
    log_ok "Wrote config to $output"
  else
    [[ -n "$output" ]] && log_step "Would write config to $output"
    printf '%s\n' "$yaml"
  fi
}

main() {
  if [[ -z "${1:-}" ]]
  then
    usage >&2
    return 2
  fi

  local command="$1"
  shift

  case "$command" in
    -h|--help)
      usage
      return 0
      ;;
    apply)
      cmd_apply "$@"
      ;;
    uninstall)
      cmd_uninstall "$@"
      ;;
    clear-cache)
      cmd_clear_cache "$@"
      ;;
    devices|list)
      cmd_devices "$@"
      ;;
    diff)
      cmd_diff "$@"
      ;;
    modules)
      cmd_modules "$@"
      ;;
    search)
      cmd_search "$@"
      ;;
    add)
      cmd_add "$@"
      ;;
    download|dl|fetch)
      cmd_download "$@"
      ;;
    generate-config|dump)
      cmd_generate_config "$@"
      ;;
    *)
      log_error "Unknown command: $command"
      usage >&2
      return 2
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
  main "$@"
fi

