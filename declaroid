#!/usr/bin/env bash

set -euo pipefail

DEFAULT_CONFIG="${DECLAROID_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/declaroid/apps.yaml}"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/declaroid"

# Populated by load_profile_aliases from the config's top-level `profiles:`
# list (name -> id). Declared here (not just inside load_profile_aliases)
# so effective_target_user can safely reference it even before it's been
# loaded, or when a config has no `profiles:` section at all.
declare -A PROFILE_ALIASES=()

# Computed once, here, at the top level -- not re-checked inside hyperlink()
# itself. `-t 1` tests file descriptor 1 of *whatever process is currently
# running*; once hyperlink() is called from inside a `$(...)` command
# substitution (as search does, to capture its output into a variable),
# fd 1 there is the pipe feeding the substitution, never the real terminal,
# so a `-t 1` check inside hyperlink() would always see "not a tty" and
# silently never emit a link. HYPERLINKS (like the C_* vars) is safe to read
# from inside a subshell since it's an ordinary variable, not a live fd test.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]
then
  C_RESET=$'\e[0m'
  C_BOLD=$'\e[1m'
  C_RED=$'\e[31m'
  C_GREEN=$'\e[32m'
  C_YELLOW=$'\e[33m'
  C_BLUE=$'\e[34m'
  C_CYAN=$'\e[36m'
  HYPERLINKS=1
else
  C_RESET=''
  C_BOLD=''
  C_RED=''
  C_GREEN=''
  C_YELLOW=''
  C_BLUE=''
  C_CYAN=''
  HYPERLINKS=''
fi

# Prefix style mirrors this author's echo_info/echo_success/echo_warning/
# echo_error zsh helpers (see e.g. secrets/sops-init.sh in nixos-config):
# bold + color + a bare label (no brackets), not padded to a common width.
log_step() {
  printf '%s%sINF%s %s\n' "$C_BOLD" "$C_BLUE" "$C_RESET" "$1" >&2
}

log_skip() {
  printf '%s%sSKP%s %s\n' "$C_BOLD" "$C_YELLOW" "$C_RESET" "$1" >&2
}

log_ok() {
  printf '%s%sOK%s %s\n' "$C_BOLD" "$C_GREEN" "$C_RESET" "$1" >&2
}

log_warn() {
  printf '%s%sWRN%s %s\n' "$C_BOLD" "$C_YELLOW" "$C_RESET" "$1" >&2
}

log_error() {
  printf '%s%sERR%s %s\n' "$C_BOLD" "$C_RED" "$C_RESET" "$1" >&2
}

usage() {
  cat <<EOF
${C_BOLD}Usage:${C_RESET} ${C_GREEN}declaroid${C_RESET} COMMAND [OPTIONS]

Declarative Android app provisioning: define apps in YAML, apply/uninstall
them onto a device via adb, fetching from Google Play (gplaydl), F-Droid or
IzzyOnDroid (fdroidcl), a GitHub repo's release assets, or a local APK file.

${C_BOLD}Commands:${C_RESET}
  ${C_CYAN}apply${C_RESET}       Download (if not already cached) and install configured apps
              and root modules (APatch/Magisk); shows a plan of what's
              actually pending first, then prompts for confirmation
              (see -y and -v below)
  ${C_CYAN}uninstall${C_RESET}   Uninstall configured apps (no download)
  ${C_CYAN}diff${C_RESET}        Show which configured apps are installed vs missing, no changes made
              (--full also lists device apps that aren't in the config)
  ${C_CYAN}modules${C_RESET}     Show configured root modules (APatch APModules/Magisk modules)
              vs what's actually on the device, read-only, no changes made
              (--full also lists device modules that aren't in the config;
              use "apply" to actually install a missing one)
  ${C_CYAN}search${C_RESET} QUERY
              Search Google Play and/or F-Droid, print a colored table with
              clickable (OSC 8) links, no device or config needed
  ${C_CYAN}add${C_RESET} QUERY
              Search, then append the picked app to the config (fzf picker
              with a preview of the YAML to be added, if more than one match)
  ${C_CYAN}download${C_RESET} QUERY (aliases: ${C_CYAN}dl${C_RESET}, ${C_CYAN}fetch${C_RESET})
              Search, then download the picked app's APK(s) to -o/--output
              (default: the current directory) -- no device or config
              needed, same fzf picker as add
  ${C_CYAN}devices${C_RESET}, ${C_CYAN}list${C_RESET}
              List connected adb devices (serial, model, codename, connection)
  ${C_CYAN}clear-cache${C_RESET} [PKG...]
              Remove cached APK downloads (all of them, or just PKG(s) given)
  ${C_CYAN}generate-config${C_RESET}, ${C_CYAN}dump${C_RESET}
              Print a YAML config seeded from what's installed on a device

${C_BOLD}Options:${C_RESET}
  ${C_YELLOW}-c, --config FILE${C_RESET}       Path to the apps YAML config (default: ${DEFAULT_CONFIG})
  ${C_YELLOW}-d, --device QUERY${C_RESET}      Target device (also settable via \$TARGET_DEVICE)
  ${C_YELLOW}-k, --dry-run, --dryrun${C_RESET} Accepted by every command; print what would happen instead of
                          doing it (apply/uninstall/clear-cache: what would be installed/
                          removed; add: the YAML entry instead of writing it; download:
                          what would be downloaded; generate-config with -o: print instead
                          of writing the file). A no-op on commands that are already
                          read-only (devices/diff/modules/search).
  ${C_YELLOW}-f, --force-download${C_RESET}    (apply, download) Re-download even if a cached copy exists
                          (gplay only for download -- fdroid/izzyondroid cache on
                          fdroidcl's own terms, outside declaroid's control)
      ${C_YELLOW}--enforce${C_RESET}           (apply only) Also uninstall device apps that aren't in the config
                          (prompts once per device; see -y below)
  ${C_YELLOW}-g, --grant, --grant-permissions${C_RESET}
                          (apply only) Pass -g to adb install/install-multiple, granting
                          every runtime permission at install time instead of prompting
                          later (gplay/github/url/local only -- fdroidcl's own install has
                          no equivalent, so this is a no-op for fdroid/izzyondroid)
      ${C_YELLOW}--reboot${C_RESET}            (apply only) Reboot the target device(s) at the end if any
                          module(s) were installed (no-op otherwise)
  ${C_YELLOW}-y, --yes, --noconfirm, --no-confirm${C_RESET}
                          (apply/apply --enforce/uninstall/clear-cache) Skip the confirmation prompt
  ${C_YELLOW}-v, --verbose${C_RESET}           (apply only) Also log each already-installed app as it's
                          skipped, instead of just a count in the plan
  ${C_YELLOW}-o, --output FILE|DIR${C_RESET}   (generate-config) Write to FILE instead of stdout;
                          (download) DIR to save the downloaded APK(s) in (default: .)
      ${C_YELLOW}--system${C_RESET}            (generate-config only) Include system apps too (default: third-party only)
      ${C_YELLOW}--no-labels, --fast${C_RESET} (generate-config only) Skip resolving app names via aapt2, use the package id instead (faster)
  ${C_YELLOW}-j, --jobs N${C_RESET}          (generate-config only) Resolve up to N app names in parallel (default: 6)
      ${C_YELLOW}--full${C_RESET}              (diff, modules) Also list device apps/modules that aren't in the
                          config, as "extra"
      ${C_YELLOW}--root-framework apatch|magisk${C_RESET}
                          (apply, modules, generate-config) Force which root framework to
                          use instead of the config's root.framework/auto-detection
      ${C_YELLOW}--store gplay|fdroid|izzyondroid|any${C_RESET}
                          (search, add, download) Which store(s) to search (default: any;
                          izzyondroid is opt-in, not part of "any")
  ${C_YELLOW}-l, --limit N${C_RESET}          (search, add, download) Max results per store (default: 10)
      ${C_YELLOW}--sort-by KEY${C_RESET}       (diff, devices) Sort output, case-insensitively.
                          diff: name (default) or pkg. devices: serial
                          (default), model, codename, or connection.
      ${C_YELLOW}--bulk, --all-devices, --all${C_RESET}
                          Target every device that matches (see below), instead
                          of erroring out on an ambiguous match
  ${C_YELLOW}-h, --help${C_RESET}              Show this help

${C_BOLD}Config resolution order:${C_RESET} --config, \$DECLAROID_CONFIG,
${XDG_CONFIG_HOME:-\$HOME/.config}/declaroid/apps.yaml

${C_BOLD}Device resolution order:${C_RESET} --device, \$TARGET_DEVICE, .device in the config.
The value is matched as a case-insensitive substring against each connected
device's serial, USB path, product, model, and codename (e.g. "redfin",
"clover", an IP, or part of a serial) -- so it doesn't need to be exact. Run
${C_CYAN}declaroid devices${C_RESET} to see what's connected and matchable.
If it matches more than one connected device, declaroid errors out unless
--bulk/--all-devices/--all is given, in which case every match is used.
If nothing resolves at all, you'll be prompted to pick from connected
devices (or, with --bulk, every connected device is used).

If no device is connected at all, or none match, and the config sets
${C_CYAN}adb.start_cmd${C_RESET}, that command is run once (via \`bash -c\`) and device
resolution is retried exactly once more -- e.g. \`zhj adb::connect
px5.lan\` to bring up a wireless-adb device that isn't currently
connected. No further retries: if it still doesn't resolve, this fails the
same way it would without a start_cmd configured at all.

If ${C_CYAN}adb.auto_stop${C_RESET} is true, ${C_CYAN}adb.stop_cmd${C_RESET} is run (also via \`bash -c\`) once a
command's real device work is done -- the teardown mirror of start_cmd,
e.g. to disconnect wireless adb again afterward. Applies to apply,
uninstall, diff, and modules (whichever command actually resolved a
device via the config); best-effort, a failing stop_cmd only logs, it
never fails the command itself.

${C_BOLD}Config schema:${C_RESET}
  imports:                                    # optional; other config file(s) to pull apps:/
                                               # modules:/profiles:/obtainium: from, paths
                                               # relative to this file. Merged in as: every
                                               # import's entries first (in listed order,
                                               # recursively -- an import may itself have
                                               # imports:), then this file's own -- pure
                                               # concatenation, no override/dedup by pkg/id.
                                               # enforce:/grant_permissions:/store:/
                                               # obtainium_auto_track: cascade in
                                               # from imports differently (override, not
                                               # concatenation): this file's own value wins if
                                               # set at all, else the last import that sets it
                                               # does -- lets a shared imports/base.yaml carry
                                               # a default for every device that imports it.
                                               # device:/adb:/root:/profile: never cascade this
                                               # way. Applies to apply/uninstall/diff/modules
                                               # only -- add/download always read and write the
                                               # file as-is, ignoring imports:.
    - <path, e.g. common-apps.yaml>
  device: <adb serial or substring query>   # optional, see device resolution above
  store: gplay|fdroid|izzyondroid|github|local|url  # optional top-level default, defaults to gplay
  profile: <name>|<user id>|all|current       # optional top-level default (apply only)
  adb:                                        # optional
    start_cmd: <shell command>                 # optional; run (via \`bash -c\`) to bring up the
                                                 # adb connection when device resolution fails,
                                                 # see above
    auto_stop: true|false                       # optional, default false; run stop_cmd once
                                                 # a command's device work is done, see above
    stop_cmd: <shell command>                   # optional; run (via \`bash -c\`) to tear the
                                                 # adb connection back down, only if auto_stop
                                                 # is true
  enforce: true|false                         # optional, default false (apply only); equivalent
                                               # to always passing --enforce. The CLI flag and
                                               # this OR together.
  grant_permissions: true|false               # optional, default false (apply only); equivalent
                                               # to always passing -g/--grant-permissions. The
                                               # CLI flag and this OR together. No effect on
                                               # store: fdroid/izzyondroid apps (see -g above).
  obtainium_auto_track: true|false            # optional, default false (apply only); auto-adds
                                               # every apps: entry with store: github to
                                               # Obtainium's tracked repos (see obtainium: below),
                                               # as if it also had its own obtainium: entry, no
                                               # settings:. An app's own
                                               # obtainium: true/false (see apps: below) overrides
                                               # this default just for that one app either way. A
                                               # pkg that already has an explicit obtainium: entry
                                               # of its own is never duplicated, regardless of
                                               # this setting.
  profiles:                                   # optional, gives profile: short aliases
    - name: <alias, e.g. work>
      id: <user id, e.g. 10>
  root:                                        # optional; root/module management (see modules: below)
    enabled: true|false                        # optional; false skips root entirely, no
                                                # auto-detection attempted. Omit to auto-detect
                                                # whether the device has APatch or Magisk at all.
    framework: apatch|magisk                   # optional; which one, if you already know (skips
                                                # auto-detection). --root-framework overrides both
                                                # of these for a single invocation.
  modules:                                     # optional; root modules (APatch APModules and
                                                # Magisk modules use the same on-disk format)
    - id: <module id>                          # matches the module's module.prop id= field
      name: <display name>                     # optional, cosmetic only (shown by "modules")
      source: github|url|local                  # optional, defaults to github; where to fetch
                                                 # the module zip from when installing it
      repo: <owner>/<repo>                       # required when source is github
      asset: <regex>                              # (github only) selects the release zip;
                                                   # default: '\\.zip\$'. Must match exactly one
                                                   # asset, same caveat as apps' asset: above.
      url: <http(s) URL>                           # required when source is url
      path: <file, glob, or dir>                   # required when source is local
      enabled: false                                # optional; informational only for now
                                                      # (declaroid never enables/disables a module,
                                                      # only installs it if missing -- see below)
  apps:
    - name: <display name>
      pkg: <package id>
      store: gplay|fdroid|izzyondroid|github|local|url  # optional, overrides the top-level default
      repo: <owner>/<repo>          # required when store is github
      asset: <regex>                # (github only) selects the release asset;
                                     # default: '\\.apk\$'. Must match exactly one
                                     # asset -- narrow it for multi-arch/multi-flavor
                                     # releases (e.g. debug vs release, per-ABI apks).
      path: <file, glob, or dir>    # required when store is local; a single apk
                                     # file, a glob matching one or more splits, or
                                     # a directory (every *.apk directly inside it).
      url: <http(s) URL>            # required when store is url; a direct link to
                                     # a single apk file, fetched at install time.
      obtainium: true|false         # optional (store: github only); overrides
                                     # obtainium_auto_track: for just this one app --
                                     # true tracks it in Obtainium even with that
                                     # default off, false excludes it even with that
                                     # default on. Unset means: follow the default.
      profile: <name>|<user id>|all|current
                                     # optional, overrides the top-level default;
                                     # which Android user/profile to install for
                                     # (e.g. a Work Profile). A name here is looked
                                     # up against profiles: above if present, else
                                     # used literally (a bare id needs no profiles:
                                     # entry at all). Unset means: use whatever the
                                     # device reports as its current profile --
                                     # never defaults to "all".
      state:                        # optional
        installed: true|false        # optional, default true. false means this
                                       # app is *not* desired: apply skips
                                       # installing it and uninstalls it if it's
                                       # present, unconditionally (no --enforce
                                       # needed -- it's an explicit per-app
                                       # choice, unlike --enforce's "anything
                                       # undeclared").
        disabled: true|false          # optional, default false. true means
                                       # apply installs it if missing, then
                                       # disables it (pm disable-user) --
                                       # "present but dormant", not "don't
                                       # install". Flipping it back to
                                       # false/unset re-enables it (pm enable)
                                       # on the next apply.
  obtainium:                                   # optional; repos for the Obtainium app itself
                                                 # to track (apply only; root not required, but
                                                 # used when available -- see below)
    - pkg: <package id>                          # the tracked app's own package id
      url: <repo URL>                            # e.g. a GitHub repo URL, whatever Obtainium's
                                                   # own "Add App" would accept
      settings:                                   # optional; merged into Obtainium's own
                                                    # additionalSettings for this entry, using
                                                    # Obtainium's own setting names verbatim (see
                                                    # its "Add App"/per-app settings UI for the
                                                    # available keys) -- not translated into a
                                                    # declaroid-specific vocabulary. e.g.
                                                    # includePrereleases: true is needed for a repo
                                                    # whose only release(s) are marked prerelease on
                                                    # GitHub (otherwise invisible to Obtainium,
                                                    # surfacing as its own "Could not find a
                                                    # suitable release" error)
        <key>: <value>

github releases are queried via the GitHub API; set \$GITHUB_TOKEN to raise
the unauthenticated rate limit or access private repos. If a repo has no
non-prerelease release, the most recent release (including prereleases) is
used instead.

izzyondroid is mechanically identical to fdroid (both go through fdroidcl),
but through an isolated, IzzyOnDroid-only fdroidcl config under
${CACHE_ROOT}/fdroidcl-izzyondroid/ -- not your regular fdroidcl config --
so it never leaks IzzyOnDroid results into a plain \`store: fdroid\` and
vice versa. Set up once automatically on first use.

APKs downloaded from gplay/github/url are cached under ${CACHE_ROOT}/<package-id>/
so repeated installs don't re-download (see --force-download). fdroid and
izzyondroid apps are cached by fdroidcl itself; local apps aren't cached
(nothing to cache). Module zips (source: github/url) are cached the same
way, under ${CACHE_ROOT}/modules/<module-id>/.

\`apply\` also installs any configured modules that aren't already
present (github/url/local, same as apps), after a plan+confirm step just
like apps get. \`modules\` itself stays read-only (drift reporting only).
Neither ever enables/disables/uninstalls a module, and module state
changes only take effect on next boot for both frameworks -- declaroid
never reboots a device on its own unless --reboot is given, so a "reboot
required" reminder is printed instead after any module install (--reboot
turns that reminder into an actual reboot of the targeted device(s)).
Framework detection (when
root.framework isn't set) probes the device directly for the apd/magisk
CLI, not for either app's package id -- Magisk supports hiding/
repackaging its own app specifically to evade that kind of check, so it
isn't a reliable signal.

\`apply\` also seeds any configured obtainium: entries that Obtainium
(dev.imranr.obtainium or dev.imranr.obtainium.fdroid, whichever is
installed) isn't already tracking, by writing a minimal JSON file directly
into its scoped-storage app_data dir -- the same format Obtainium writes
for itself, not a full vendored copy of its internal state. Root is used
when available (a slightly more precise write, chowned to the app's own
exact UID) but is not actually required -- plain adb shell is, by stock
Android default, already a member of the same group that owns this
directory, confirmed live against a real non-rooted device. It's an error
(apply exits non-zero) if obtainium: entries are configured yet neither
Obtainium package is actually installed on the device, since that's a
real misconfiguration rather than an expected limitation. Already-tracked
entries are left untouched (no update/force-refetch), and there is no way
to force Obtainium itself to fetch metadata for a newly-seeded entry
immediately -- it only happens the next time Obtainium is opened or its
own ~15 minute background check runs.

Table output (devices, diff, modules) is rendered with tsvtool if it's on
\$PATH (https://github.com/pschmitt/tsvtool), otherwise with column -t.
EOF
}

check_deps() {
  local bin

  for bin in "$@"
  do
    if ! command -v "$bin" >/dev/null 2>&1
    then
      log_error "Missing required binary: $bin"
      return 1
    fi
  done
}

config_stores() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.store // "gplay") as $d | [.apps[] | (.store // $d)] | unique | .[]' "$config"
}

list_device_lines() {
  adb devices -l | awk 'NR>1 && $2=="device" {print}'
}

build_searchable() {
  local line="$1"
  local serial="${line%% *}"
  local usb="" product="" model="" codename=""

  [[ "$line" =~ usb:([^[:space:]]+) ]] && usb="${BASH_REMATCH[1]}"
  [[ "$line" =~ product:([^[:space:]]+) ]] && product="${BASH_REMATCH[1]}"
  [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
  [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"

  printf '%s %s %s %s %s\n' "$serial" "$usb" "$product" "$model" "$codename"
}

format_device_line() {
  local line="$1"
  local serial="${line%% *}"
  local model="" codename=""

  [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
  [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"

  if [[ -n "$model" || -n "$codename" ]]
  then
    printf '%s (%s/%s)\n' "$serial" "${model:-?}" "${codename:-?}"
  else
    printf '%s\n' "$serial"
  fi
}

# Pretty-prints TSV (with a header row) read from stdin. Uses tsvtool if it's
# on PATH (https://github.com/pschmitt/tsvtool), otherwise falls back to
# column -t with a bolded header, otherwise just passes the TSV through.
render_table() {
  local data
  data="$(cat)"

  if [[ -z "$data" ]]
  then
    return 0
  fi

  if command -v tsvtool >/dev/null 2>&1
  then
    # --keep-escape-sequences: tsvtool strips ANSI/OSC 8 escape codes out of
    # its *input* by default (checked its source: `strip_ansi` runs unless
    # this flag is passed), which silently ate `search`'s OSC 8 hyperlinks
    # before they ever reached the terminal. Harmless to pass unconditionally
    # here -- devices/diff have nothing pre-embedded for tsvtool to strip in
    # the first place (they colorize via colorize_word *after* render_table
    # returns, not before), so this only ever matters for search.
    local -a args=(pretty --keep-escape-sequences)
    [[ -z "$C_RESET" ]] && args+=(--no-color)
    printf '%s\n' "$data" | tsvtool "${args[@]}"
    return 0
  fi

  if command -v column >/dev/null 2>&1
  then
    local -a rendered
    mapfile -t rendered < <(printf '%s\n' "$data" | column -t -s $'\t')

    if [[ ${#rendered[@]} -gt 0 ]]
    then
      printf '%s%s%s\n' "$C_BOLD" "${rendered[0]}" "$C_RESET"
      if [[ ${#rendered[@]} -gt 1 ]]
      then
        printf '%s\n' "${rendered[@]:1}"
      fi
    fi
    return 0
  fi

  printf '%s\n' "$data"
}

# Colorizes a whole-word match in already-rendered (aligned) text, read from
# stdin. Safe to run on tsvtool's own colored output too: if the word is
# already wrapped in ANSI codes there, the whitespace-boundary match simply
# won't fire, so this is a no-op rather than a corruption in that case.
colorize_word() {
  local word="$1"
  local color="$2"

  if [[ -z "$color" ]]
  then
    cat
    return 0
  fi

  sed -E "s/(^|[[:space:]])(${word})([[:space:]]|\$)/\\1${color}\\2${C_RESET}\\3/"
}

prompt_pick_device() {
  local -a lines=("$@")

  if [[ ! -t 0 ]]
  then
    log_error "Multiple devices connected and no --device/\$TARGET_DEVICE given; stdin is not a terminal to prompt"
    return 1
  fi

  {
    printf '%sMultiple devices connected, pick one:%s\n' "$C_BOLD" "$C_RESET"
    local i
    for i in "${!lines[@]}"
    do
      printf '  %s[%d]%s %s\n' "$C_CYAN" "$((i + 1))" "$C_RESET" "$(format_device_line "${lines[$i]}")"
    done
  } >&2

  local choice
  while true
  do
    read -rp "Device number: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#lines[@]} ))
    then
      printf '%s\n' "${lines[$((choice - 1))]%% *}"
      return 0
    fi
    log_error "Invalid choice: $choice"
  done
}

resolve_devices() {
  local cli_device="$1"
  local config="$2"
  local bulk="$3"
  local query=""

  if [[ -n "$cli_device" ]]
  then
    query="$cli_device"
  elif [[ -n "${TARGET_DEVICE:-}" ]]
  then
    query="$TARGET_DEVICE"
  elif [[ -n "$config" && -f "$config" ]]
  then
    local from_yaml
    from_yaml="$(yq -r '.device' "$config")"
    if [[ -n "$from_yaml" && "$from_yaml" != "null" ]]
    then
      query="$from_yaml"
    fi
  fi

  local start_cmd=""
  if [[ -n "$config" && -f "$config" ]]
  then
    start_cmd="$(yq -r '.adb.start_cmd // ""' "$config")"
    [[ "$start_cmd" == "null" ]] && start_cmd=""
  fi

  # Tries discovery/matching as-is first; if that comes up empty and
  # `adb.start_cmd` is configured, runs it (e.g. `zhj adb::connect
  # px5.lan`) to bring the connection up and retries exactly once more --
  # never loops beyond that, so a start_cmd that doesn't actually fix
  # anything fails the same way it would without one, just after one extra
  # attempt.
  local -a lines matched=()
  local attempt
  for attempt in 1 2
  do
    mapfile -t lines < <(list_device_lines)
    matched=()

    if [[ ${#lines[@]} -gt 0 ]]
    then
      if [[ -n "$query" ]]
      then
        local line searchable
        for line in "${lines[@]}"
        do
          searchable="$(build_searchable "$line")"
          if [[ "${searchable,,}" == *"${query,,}"* ]]
          then
            matched+=("$line")
          fi
        done
      else
        matched=("${lines[@]}")
      fi
    fi

    [[ ${#matched[@]} -gt 0 ]] && break
    [[ "$attempt" -eq 2 || -z "$start_cmd" ]] && break

    log_step "No matching adb device found, running adb.start_cmd"
    # resolve_devices's own output is captured via $(...) by every caller
    # (see AGENTS.md's "log to stderr, data to stdout" rule) -- start_cmd is
    # an arbitrary, uncontrolled shell command that may print anything to
    # stdout (confirmed with a real `zhj adb::connect` invocation, whose
    # Tasker/HA call prints a stray JSON `[]` to stdout), so it must be
    # redirected to stderr here or it silently corrupts the device list
    # this function returns.
    bash -c "$start_cmd" >&2
  done

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_error "No adb devices connected"
    return 1
  fi

  if [[ -n "$query" && ${#matched[@]} -eq 0 ]]
  then
    log_error "No connected device matches '$query'"
    return 1
  fi

  if [[ ${#matched[@]} -eq 1 ]]
  then
    printf '%s\n' "${matched[0]%% *}"
    return 0
  fi

  if [[ -n "$bulk" ]]
  then
    log_step "${#matched[@]} device(s) matched, targeting all of them (--bulk)"
    local m
    for m in "${matched[@]}"
    do
      printf '%s\n' "${m%% *}"
    done
    return 0
  fi

  if [[ -z "$query" ]]
  then
    prompt_pick_device "${matched[@]}"
    return $?
  fi

  {
    printf "%sMultiple devices match '%s':%s\\n" "$C_BOLD" "$query" "$C_RESET"
    local m
    for m in "${matched[@]}"
    do
      printf '  %s\n' "$(format_device_line "$m")"
    done
    printf 'Use --bulk/--all-devices/--all to target all of them, or refine the match.\n'
  } >&2
  return 1
}

# The teardown mirror of adb.start_cmd: if the config sets `adb.auto_stop:
# true`, runs `adb.stop_cmd` (also an arbitrary shell command, via `bash
# -c`) once a command's real device work is done -- e.g. to disconnect
# wireless adb again after `apply` finishes. No-op if either isn't set.
# Deliberately best-effort/fire-and-forget: a failing stop_cmd only logs,
# it never changes the calling command's own exit status -- tearing down
# the connection is cleanup, not something worth failing an otherwise-
# successful apply/uninstall/diff/modules/generate-config run over.
# Respects dry_run (the caller's own $DRY_RUN, passed explicitly since this
# isn't itself part of the CURRENT_*/DEVICE_SERIAL dynamic-scope
# convention) the same way start_cmd's own retry does: preview only, don't
# actually run it.
maybe_run_adb_stop_cmd() {
  local config="$1"
  local dry_run="$2"

  [[ -n "$config" && -f "$config" ]] || return 0

  local auto_stop
  auto_stop="$(yq -r '.adb.auto_stop == true' "$config")"
  [[ "$auto_stop" == true ]] || return 0

  local stop_cmd
  stop_cmd="$(yq -r '.adb.stop_cmd // ""' "$config")"
  [[ "$stop_cmd" == "null" ]] && stop_cmd=""
  [[ -n "$stop_cmd" ]] || return 0

  if [[ -n "$dry_run" ]]
  then
    printf '  would run adb.stop_cmd\n' >&2
    return 0
  fi

  log_step "Running adb.stop_cmd"
  # See resolve_devices's start_cmd comment -- stdout redirected to stderr
  # for the same reason, even though this function's own return value
  # isn't captured by any caller (nothing downstream reads it), purely so
  # a future caller that *does* capture output can't be bitten by the same
  # class of bug.
  bash -c "$stop_cmd" >&2
}

is_installed() {
  local device="$1"
  local pkg="$2"

  adb -s "$device" shell pm list packages "$pkg" </dev/null 2>/dev/null \
    | tr -d '\r' \
    | grep -qx "package:$pkg"
}

# Same idea as is_installed, but scoped to disabled packages only (`pm list
# packages -d`) -- a disabled package is still "installed" per is_installed
# above (that query has no -d/-e filter), this just distinguishes the
# enabled/disabled sub-state for state.disabled: convergence.
is_pkg_disabled() {
  local device="$1"
  local pkg="$2"

  adb -s "$device" shell pm list packages -d "$pkg" </dev/null 2>/dev/null \
    | tr -d '\r' \
    | grep -qx "package:$pkg"
}

# Best-effort: prints the device's current user id (`am get-current-user`,
# e.g. "0" for the primary/personal profile) or nothing if it can't be
# determined (older Android without multi-user support, a transient adb
# hiccup, ...). Callers should treat empty as "don't pass --user at all"
# rather than an error -- see install_apk_files's comment for why this
# matters on devices with a secondary/managed profile.
resolve_target_user() {
  local device="$1"
  local user

  user="$(adb -s "$device" shell am get-current-user </dev/null 2>/dev/null | tr -d '\r\n')"

  if [[ "$user" =~ ^[0-9]+$ ]]
  then
    printf '%s\n' "$user"
  fi
}

# Reads the config's top-level `profiles:` list (an array of {name, id},
# e.g. so `profile: work` in an app entry can mean id 10) into
# PROFILE_ALIASES. A config without a `profiles:` section just gets an
# empty map, which is fine: effective_target_user falls back to using
# CURRENT_PROFILE literally (a bare id, "all", or "current") in that case.
load_profile_aliases() {
  local config="$1"
  PROFILE_ALIASES=()

  local -a lines
  mapfile -t lines < <(yq -r '(.profiles // [])[] | [.name, .id] | join("§")' "$config")

  local line name id
  for line in "${lines[@]}"
  do
    [[ -z "$line" ]] && continue
    IFS='§' read -r name id <<< "$line"
    [[ -n "$name" ]] && PROFILE_ALIASES["$name"]="$id"
  done
}

# The --user value to actually pass to adb install/install-multiple: the
# per-app CURRENT_PROFILE from config wins if set -- resolved through
# PROFILE_ALIASES first (so `profile: work` becomes "10"), falling back to
# using it literally if it's not an alias (a bare id like `profile: 10`
# doesn't require a `profiles:` section at all, nor does "all"/"current").
# If CURRENT_PROFILE is unset entirely, falls back to the auto-detected
# current profile (TARGET_USER, set once per device in cmd_apply). Never
# defaults to "all" on its own -- installing to every profile has to be an
# explicit, per-app opt-in via `profile: all` in the config, not something
# that happens by not configuring anything.
effective_target_user() {
  local profile="${CURRENT_PROFILE:-}"

  if [[ -n "$profile" && -n "${PROFILE_ALIASES[$profile]:-}" ]]
  then
    profile="${PROFILE_ALIASES[$profile]}"
  fi

  if [[ -n "$profile" ]]
  then
    printf '%s\n' "$profile"
  else
    printf '%s\n' "${TARGET_USER:-}"
  fi
}

cache_dir_for() {
  local pkg="$1"

  printf '%s/%s\n' "$CACHE_ROOT" "$pkg"
}

has_apk_files() {
  local dir="$1"
  local -a existing=("$dir"/*.apk)

  [[ -e "${existing[0]}" ]]
}

fetch_app() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$FORCE_DOWNLOAD" ]] && has_apk_files "$cache_dir"
  then
    log_step "Using cached download in $cache_dir"
    printf '%s\n' "$cache_dir"
    return 0
  fi

  mkdir -p "$cache_dir"

  if ! gplaydl download "$CURRENT_PKG" -o "$cache_dir" >&2
  then
    log_error "Failed to download $CURRENT_PKG"
    return 1
  fi

  printf '%s\n' "$cache_dir"
}

# Takes an installer attribution package id (may be empty -- see below) and
# a list of APK file paths (computed data, not per-app config, unlike the
# CURRENT_*/DEVICE_SERIAL/etc convention used elsewhere), dedupes the files
# by checksum, and installs the survivors.
#
# `adb install -i <id> -r <file>` sets the installer attribution (visible
# later via `pm list packages -i`, and read back by
# store_for_installer/generate-config) -- but only if <id> is a real,
# currently-installed package; Android silently drops the attribution
# (installer ends up null) for a made-up id, tested against a real device
# with a synthetic "declaroid.store.whatever" string. That rules out
# attributing github/local installs to declaroid itself: there's no
# existing installed package we could truthfully claim to be. gplay is the
# one case this is worth doing, since com.android.vending genuinely is
# installed on any real device -- `installer` is only ever passed as
# "com.android.vending" or "" by callers, never a synthetic id.
#
# Separately: `adb install-multiple -i <id> -r <files...>` was tested and
# reliably *hangs* instead of erroring, regardless of flag order, even with
# a real installer id. So -i is only ever used for the single-APK case,
# routed through plain `install`; a real split install always goes through
# `install-multiple` with no installer attribution at all (matching prior
# behavior). Don't add -i to the install-multiple branch without re-testing
# against a real device first.
#
# --user "$TARGET_USER" is passed to both branches when set (see
# resolve_target_user): on a device with a secondary/managed profile (a
# Work Profile, Island, etc), `adb install`/`install-multiple` without
# --user were observed installing into an unpredictable profile -- not
# consistently "all profiles", not consistently the current one, and not
# even consistent between `install` and `install-multiple` on the same
# device. Passing --user explicitly makes this deterministic.
install_apk_files() {
  local installer="$1"
  shift
  local -a files=("$@")
  local -A seen_hashes
  local -a keep_files
  local f hash base

  for f in "${files[@]}"
  do
    [[ -e "$f" ]] || continue
    hash="$(sha256sum "$f" | cut -d' ' -f1)"
    base="$(basename "$f")"

    if [[ -n "${seen_hashes[$hash]:-}" ]]
    then
      log_warn "Skipping duplicate split $base (identical to ${seen_hashes[$hash]})"
      continue
    fi

    seen_hashes[$hash]="$base"
    keep_files+=("$f")
  done

  if [[ ${#keep_files[@]} -eq 0 ]]
  then
    log_error "No APK files to install"
    return 1
  fi

  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(--user "$user_val")

  local -a grant_args=()
  [[ -n "${GRANT_PERMISSIONS:-}" ]] && grant_args=(-g)

  if [[ ${#keep_files[@]} -eq 1 && -n "$installer" ]]
  then
    adb -s "$DEVICE_SERIAL" install -r "${user_args[@]}" "${grant_args[@]}" -i "$installer" "${keep_files[0]}"
  else
    adb -s "$DEVICE_SERIAL" install-multiple -r "${user_args[@]}" "${grant_args[@]}" "${keep_files[@]}"
  fi
}

install_splits() {
  local installer="$1"
  local dir="$2"
  local -a files
  local -a obb_files

  mapfile -t files < <(find "$dir" -maxdepth 1 -iname '*.apk' | sort)

  if [[ ${#files[@]} -eq 0 ]]
  then
    log_error "No APK files found in $dir"
    return 1
  fi

  if ! install_apk_files "$installer" "${files[@]}"
  then
    return 1
  fi

  mapfile -t obb_files < <(find "$dir" -maxdepth 1 -iname '*.obb')
  if [[ ${#obb_files[@]} -gt 0 ]]
  then
    log_warn "${#obb_files[@]} OBB/expansion file(s) are cached but not pushed automatically:"
    printf '  %s\n' "${obb_files[@]}"
  fi
}

install_gplay() {
  local cache_dir

  if ! cache_dir="$(fetch_app)"
  then
    return 1
  fi

  install_splits com.android.vending "$cache_dir"
}

# fdroidcl does its own `adb install` internally with no installer flag, so
# fdroid-sourced apps always end up with installer=null -- nothing declaroid
# can do about that without patching fdroidcl itself. It does have its own
# -user flag though (defaulting to the current user itself if omitted), so
# profile targeting still works. It has no -g/grant-permissions equivalent
# at all (checked `fdroidcl install --help`) -- grant_permissions:/-g is a
# no-op for store: fdroid/izzyondroid, documented as a known limitation
# rather than silently ignored.
install_fdroid() {
  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(-user "$user_val")
  ANDROID_SERIAL="$DEVICE_SERIAL" fdroidcl install "${user_args[@]}" "$CURRENT_PKG"
}

IZZYONDROID_REPO_URL='https://apt.izzysoft.de/fdroid/repo'
IZZYONDROID_XDG_CONFIG_HOME="$CACHE_ROOT/fdroidcl-izzyondroid/config"
IZZYONDROID_XDG_CACHE_HOME="$CACHE_ROOT/fdroidcl-izzyondroid/cache"

# fdroidcl merges every *enabled* repo in its config into one combined
# index -- there's no per-repo scoping in `search`/`show`/`install` at all
# (checked: no --repo flag anywhere), and `fdroidcl repo add` isn't
# idempotent, it permanently mutates whichever config it targets. Doing
# that against the user's real ~/.config/fdroidcl would leak IzzyOnDroid
# into every future *plain* `store: fdroid` search/install too -- not a
# hypothetical, this actually happened once during testing here and had to
# be undone by hand. Instead, all IzzyOnDroid-related fdroidcl calls run
# through this wrapper, which points XDG_CONFIG_HOME/XDG_CACHE_HOME at a
# declaroid-managed directory (fdroidcl reads those directly, confirmed by
# testing: overriding bare $HOME alone does *not* redirect it, since
# XDG_CONFIG_HOME/XDG_CACHE_HOME were already set in the environment and
# take priority) containing *only* the IzzyOnDroid repo. That isolation is
# a second win beyond just not polluting the real config: with nothing
# else enabled in it, search/show/install against this wrapper are
# naturally scoped to just IzzyOnDroid for free, no per-result `fdroidcl
# show` filtering needed to tell IzzyOnDroid matches apart from
# everyone else's.
#
# `fdroidcl setup` looks related to repo management at a glance ("mass
# installs ... excellent for backups") but is a different feature entirely
# -- named groups of apps+repos for bulk provisioning (fdroidcl's own
# answer to what declaroid already does), and its `setup add-repo` only
# *references* an already-registered repo by name, it doesn't add a new
# repo URL. There's no shortcut around `fdroidcl repo add` for this.
izzyondroid_fdroidcl() {
  XDG_CONFIG_HOME="$IZZYONDROID_XDG_CONFIG_HOME" XDG_CACHE_HOME="$IZZYONDROID_XDG_CACHE_HOME" fdroidcl "$@"
}

ensure_izzyondroid_repo() {
  mkdir -p "$IZZYONDROID_XDG_CONFIG_HOME" "$IZZYONDROID_XDG_CACHE_HOME"

  if ! izzyondroid_fdroidcl repo 2>/dev/null | grep -qx 'Name: izzyondroid'
  then
    log_step "Setting up an isolated fdroidcl config for IzzyOnDroid"
    # A fresh config comes with f-droid/f-droid-archive pre-enabled by
    # default -- remove them so this isolated instance only ever knows
    # about IzzyOnDroid (true single-repo scoping, not merely "enabled
    # alongside the others").
    izzyondroid_fdroidcl repo remove f-droid >/dev/null 2>&1 || true
    izzyondroid_fdroidcl repo remove f-droid-archive >/dev/null 2>&1 || true
    izzyondroid_fdroidcl repo add izzyondroid "$IZZYONDROID_REPO_URL"
    # A freshly-added repo has no cached index at all -- fetch it once,
    # right away, so the very first search/install right after registering
    # doesn't come up empty.
    log_step "Fetching the IzzyOnDroid index (first time only)"
    izzyondroid_fdroidcl update
  fi
}

# Mechanically like install_fdroid, but through the isolated wrapper --
# ANDROID_SERIAL/-user targeting work exactly the same way, just with
# XDG_CONFIG_HOME/XDG_CACHE_HOME also redirected.
install_izzyondroid() {
  ensure_izzyondroid_repo

  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(-user "$user_val")
  ANDROID_SERIAL="$DEVICE_SERIAL" izzyondroid_fdroidcl install "${user_args[@]}" "$CURRENT_PKG"
}

# Downloads $pkg via `fdroidcl download` (or, when $izzy is non-empty, the
# isolated IzzyOnDroid wrapper) -- fdroidcl's own cache, not declaroid's
# ${CACHE_ROOT}, and no adb/device involvement at all (confirmed: fdroidcl's
# own `download` command works fine with nothing connected, unlike `install`
# -- it only tries to detect a device to pick the *best-matching* APK
# variant, and swallows the error if none is found). Used by `download`,
# which never installs anything.
#
# `fdroidcl download`'s own progress bar goes to *its* stdout, not stderr
# (confirmed empirically), same class of noise as gplaydl's -- and unlike
# fetch_app (which never needs to read gplaydl's stdout at all), the actual
# data this function needs -- fdroidcl's own final "APK available in
# <path>" line -- is *also* on that same stdout, mixed in with the
# progress noise. Both streams are fully captured (2>&1) and parsed
# afterward rather than shown live -- **do not** be tempted to
# `| tee /dev/stderr` here for a live progress bar: confirmed as a real,
# reproducible corruption bug when the *whole script's* own stderr is
# itself redirected to a regular file (any non-interactive/logged/piped
# invocation, not just tests) -- `tee`'s `open("/dev/stderr")` resolves to
# a *new*, independently-offset open of the same underlying file rather
# than reusing the shell's existing fd 2, so its writes and the rest of
# the script's own subsequent stderr writes silently overwrite/interleave
# each other's bytes at the OS level. Reproduced with a two-line isolated
# repro (`echo marker >&2; out="$(cmd | tee /dev/stderr)"; echo marker
# >&2`, redirected to a file): the first marker and parts of the piped
# output vanished/scrambled. Plain `2>&1` capture has none of this risk.
# Progress updates are `\r`-separated, not `\n` (confirmed empirically) --
# `tr '\r' '\n'` first, so the final "APK available in ..." line can be
# grepped out on its own regardless.
fetch_fdroid_apk() {
  local pkg="$1"
  local izzy="$2"

  local -a fdroidcl_cmd=(fdroidcl)
  if [[ -n "$izzy" ]]
  then
    ensure_izzyondroid_repo
    fdroidcl_cmd=(izzyondroid_fdroidcl)
  fi

  local output
  if ! output="$("${fdroidcl_cmd[@]}" download "$pkg" 2>&1)"
  then
    log_error "Failed to download $pkg"
    printf '%s\n' "$output" >&2
    return 1
  fi

  local path
  path="$(tr '\r' '\n' <<< "$output" | sed -n 's/^APK available in //p' | tail -1)"

  if [[ -z "$path" || ! -e "$path" ]]
  then
    log_error "Could not determine downloaded APK path for $pkg"
    return 1
  fi

  printf '%s\n' "$path"
}

install_local() {
  local -a apks

  if [[ -z "$CURRENT_PATH" ]]
  then
    log_error "store: local requires a 'path'"
    return 1
  fi

  if [[ -d "$CURRENT_PATH" ]]
  then
    mapfile -t apks < <(find "$CURRENT_PATH" -maxdepth 1 -iname '*.apk' | sort)
  else
    # $CURRENT_PATH may be a plain file path or a glob pattern (e.g.
    # "/dir/*.apk"); routing both through find -name on the parent dir
    # handles either case without word-splitting/quoting hazards, unlike
    # unquoted brace/glob expansion of an arbitrary variable would.
    mapfile -t apks < <(find "$(dirname -- "$CURRENT_PATH")" -maxdepth 1 -name "$(basename -- "$CURRENT_PATH")" | sort)
  fi

  if [[ ${#apks[@]} -eq 0 ]]
  then
    log_error "No APK files found at '$CURRENT_PATH'"
    return 1
  fi

  # No installer attribution here either -- same reason as install_github.
  install_apk_files "" "${apks[@]}"
}

fetch_github_release() {
  local repo="$CURRENT_REPO"
  local asset_pattern="$CURRENT_ASSET"
  local cache_dir="$1"
  local -a curl_args=(--fail --silent --show-error --location)

  if [[ -n "${GITHUB_TOKEN:-}" ]]
  then
    curl_args+=(--header "Authorization: Bearer ${GITHUB_TOKEN}")
  fi

  local release_json
  if release_json="$(curl "${curl_args[@]}" "https://api.github.com/repos/${repo}/releases/latest" 2>/dev/null)"
  then
    log_step "Using latest release for $repo"
  else
    log_warn "No stable release found for $repo, falling back to most recent release (including prereleases)"
    if ! release_json="$(curl "${curl_args[@]}" "https://api.github.com/repos/${repo}/releases" 2>/dev/null | jq -c '.[0]')"
    then
      log_error "Failed to query GitHub releases for $repo"
      return 1
    fi
  fi

  if [[ -z "$release_json" || "$release_json" == "null" ]]
  then
    log_error "No releases found for $repo"
    return 1
  fi

  local -a matches
  mapfile -t matches < <(jq -r --arg pat "$asset_pattern" \
    '.assets[] | select(.name | test($pat)) | [.name, .browser_download_url] | @tsv' \
    <<< "$release_json")

  if [[ ${#matches[@]} -eq 0 ]]
  then
    log_error "No release asset matching '$asset_pattern' found for $repo"
    return 1
  fi

  if [[ ${#matches[@]} -gt 1 ]]
  then
    log_error "Multiple release assets matched '$asset_pattern' for $repo, narrow the 'asset' pattern:"
    local m
    for m in "${matches[@]}"
    do
      printf '  %s\n' "${m%%$'\t'*}"
    done
    return 1
  fi

  local asset_name asset_url
  IFS=$'\t' read -r asset_name asset_url <<< "${matches[0]}"

  log_step "Downloading $asset_name"

  if ! curl "${curl_args[@]}" --output "${cache_dir}/${asset_name}" "$asset_url"
  then
    log_error "Failed to download $asset_name"
    return 1
  fi
}

install_github() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$CURRENT_REPO" ]]
  then
    log_error "$CURRENT_PKG uses store: github but has no 'repo' set"
    return 1
  fi

  if [[ -n "$FORCE_DOWNLOAD" ]] || ! has_apk_files "$cache_dir"
  then
    mkdir -p "$cache_dir"
    rm -f "$cache_dir"/*.apk
    if ! fetch_github_release "$cache_dir"
    then
      return 1
    fi
  else
    log_step "Using cached download in $cache_dir"
  fi

  local -a apks
  mapfile -t apks < <(find "$cache_dir" -maxdepth 1 -iname '*.apk')

  if [[ ${#apks[@]} -ne 1 ]]
  then
    log_error "Expected exactly one cached APK in $cache_dir, found ${#apks[@]}"
    return 1
  fi

  # No -i here: Android silently drops installer attribution unless the
  # claimed installer is a real, currently-installed package (tested --
  # a synthetic "declaroid.store.github" id is just ignored, ending up
  # installer=null same as if we hadn't passed -i at all).
  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(--user "$user_val")
  local -a grant_args=()
  [[ -n "${GRANT_PERMISSIONS:-}" ]] && grant_args=(-g)
  adb -s "$DEVICE_SERIAL" install -r "${user_args[@]}" "${grant_args[@]}" "${apks[0]}"
}

install_url() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$CURRENT_URL" ]]
  then
    log_error "$CURRENT_PKG uses store: url but has no 'url' set"
    return 1
  fi

  if [[ -n "$FORCE_DOWNLOAD" ]] || ! has_apk_files "$cache_dir"
  then
    mkdir -p "$cache_dir"
    rm -f "$cache_dir"/*.apk

    local filename
    filename="$(basename "$CURRENT_URL")"
    [[ "$filename" == *.apk ]] || filename="${CURRENT_PKG}.apk"

    log_step "Downloading $CURRENT_URL"
    if ! curl --fail --silent --show-error --location --output "${cache_dir}/${filename}" "$CURRENT_URL"
    then
      log_error "Failed to download $CURRENT_URL"
      return 1
    fi
  else
    log_step "Using cached download in $cache_dir"
  fi

  local -a apks
  mapfile -t apks < <(find "$cache_dir" -maxdepth 1 -iname '*.apk')

  if [[ ${#apks[@]} -ne 1 ]]
  then
    log_error "Expected exactly one cached APK in $cache_dir, found ${#apks[@]}"
    return 1
  fi

  # No -i: same reasoning as install_github (no real installed package to
  # truthfully attribute this to).
  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(--user "$user_val")
  local -a grant_args=()
  [[ -n "${GRANT_PERMISSIONS:-}" ]] && grant_args=(-g)
  adb -s "$DEVICE_SERIAL" install -r "${user_args[@]}" "${grant_args[@]}" "${apks[0]}"
}

# Module zips are cached separately from app APKs, under their own
# namespace -- module ids and app package ids are different namespaces
# and could theoretically collide (unlikely, but not worth risking).
module_cache_dir_for() {
  printf '%s/modules/%s\n' "$CACHE_ROOT" "$1"
}

has_zip_files() {
  local dir="$1"
  local -a existing=("$dir"/*.zip)

  [[ -e "${existing[0]}" ]]
}

# Emits configured modules as one row per module: id, name (defaulted to
# id), source (defaulted to github), repo, asset (defaulted), url, path --
# joined with U+00A7, same reasoning as app_rows (see its own comment).
module_rows() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.modules // [])[] |
    [.id, (.name // .id), (.source // "github"), (.repo // ""), (.asset // "\\.zip$"), (.url // ""), (.path // "")] | join("§")' "$config"
}

# Same convention as for_each_app -- see its comment. Calls module_fn (a
# zero-arg function) once per configured module, with CURRENT_MODULE_ID/
# CURRENT_MODULE_NAME/CURRENT_MODULE_SOURCE/CURRENT_MODULE_REPO/
# CURRENT_MODULE_ASSET/CURRENT_MODULE_URL/CURRENT_MODULE_PATH set for it to
# read. Uses mapfile + a plain for loop, not a `while read < <(...)`, per
# the ban on that construct elsewhere in this file.
for_each_module() {
  local config="$1"
  local module_fn="$2"
  local failures=0

  local -a rows
  mapfile -t rows < <(module_rows "$config")

  local row
  for row in "${rows[@]}"
  do
    # yq -r emits one blank line, not zero output, for `(.modules // [])[]
    # | ... | join(...)` over an empty/absent modules: list -- confirmed
    # empirically (only appears once join(...) is the final step; a plain
    # `.modules[]` alone correctly produces zero output for zero elements).
    # Without this guard, a modules-less or `modules: []` config would spin
    # up one phantom iteration with every CURRENT_MODULE_* field empty.
    [[ -z "$row" ]] && continue
    IFS='§' read -r CURRENT_MODULE_ID CURRENT_MODULE_NAME CURRENT_MODULE_SOURCE CURRENT_MODULE_REPO CURRENT_MODULE_ASSET CURRENT_MODULE_URL CURRENT_MODULE_PATH <<< "$row"

    if ! "$module_fn"
    then
      log_error "$CURRENT_MODULE_NAME ($CURRENT_MODULE_ID) failed"
      failures=$((failures + 1))
    fi
  done

  if [[ $failures -gt 0 ]]
  then
    log_error "$failures module(s) failed"
    return 1
  fi

  log_ok "All modules processed successfully"
}

# Resolves CURRENT_MODULE_*'s source into a single local zip file path,
# ready to push to the device, and prints that path -- downloading/caching
# under module_cache_dir_for for github/url (mirroring fetch_github_release/
# install_url's own caching), or just locating the file directly for local
# (nothing to cache, it's already on disk, same as install_local). The
# github case reuses fetch_github_release verbatim by shadowing
# CURRENT_REPO/CURRENT_ASSET as locals first -- that function only ever
# reads those two (plus the cache_dir argument), so this is the same
# CURRENT_*-as-dynamic-scope convention already used throughout this file,
# not a hack. Only ever logs to stderr (via the functions it calls) --
# the zip path on stdout is the actual return value callers need.
resolve_module_zip() {
  local cache_dir

  case "$CURRENT_MODULE_SOURCE" in
    github)
      if [[ -z "$CURRENT_MODULE_REPO" ]]
      then
        log_error "$CURRENT_MODULE_ID uses source: github but has no 'repo' set"
        return 1
      fi

      cache_dir="$(module_cache_dir_for "$CURRENT_MODULE_ID")"

      if [[ -n "$FORCE_DOWNLOAD" ]] || ! has_zip_files "$cache_dir"
      then
        mkdir -p "$cache_dir"
        rm -f "$cache_dir"/*.zip

        local CURRENT_REPO="$CURRENT_MODULE_REPO"
        local CURRENT_ASSET="$CURRENT_MODULE_ASSET"
        if ! fetch_github_release "$cache_dir"
        then
          return 1
        fi
      else
        log_step "Using cached download in $cache_dir"
      fi
      ;;
    url)
      if [[ -z "$CURRENT_MODULE_URL" ]]
      then
        log_error "$CURRENT_MODULE_ID uses source: url but has no 'url' set"
        return 1
      fi

      cache_dir="$(module_cache_dir_for "$CURRENT_MODULE_ID")"

      if [[ -n "$FORCE_DOWNLOAD" ]] || ! has_zip_files "$cache_dir"
      then
        mkdir -p "$cache_dir"
        rm -f "$cache_dir"/*.zip

        local filename
        filename="$(basename "$CURRENT_MODULE_URL")"
        [[ "$filename" == *.zip ]] || filename="${CURRENT_MODULE_ID}.zip"

        log_step "Downloading $CURRENT_MODULE_URL"
        if ! curl --fail --silent --show-error --location --output "${cache_dir}/${filename}" "$CURRENT_MODULE_URL"
        then
          log_error "Failed to download $CURRENT_MODULE_URL"
          return 1
        fi
      else
        log_step "Using cached download in $cache_dir"
      fi
      ;;
    local)
      local -a zips

      if [[ -z "$CURRENT_MODULE_PATH" ]]
      then
        log_error "source: local requires a 'path'"
        return 1
      fi

      if [[ -d "$CURRENT_MODULE_PATH" ]]
      then
        mapfile -t zips < <(find "$CURRENT_MODULE_PATH" -maxdepth 1 -iname '*.zip' | sort)
      else
        mapfile -t zips < <(find "$(dirname -- "$CURRENT_MODULE_PATH")" -maxdepth 1 -name "$(basename -- "$CURRENT_MODULE_PATH")" | sort)
      fi

      if [[ ${#zips[@]} -ne 1 ]]
      then
        log_error "Expected exactly one zip file for '$CURRENT_MODULE_PATH', found ${#zips[@]}"
        return 1
      fi

      printf '%s\n' "${zips[0]}"
      return 0
      ;;
    *)
      log_error "Unknown module source '$CURRENT_MODULE_SOURCE' for $CURRENT_MODULE_ID (expected github, url, or local)"
      return 1
      ;;
  esac

  local -a zips
  mapfile -t zips < <(find "$cache_dir" -maxdepth 1 -iname '*.zip')

  if [[ ${#zips[@]} -ne 1 ]]
  then
    log_error "Expected exactly one cached zip in $cache_dir, found ${#zips[@]}"
    return 1
  fi

  printf '%s\n' "${zips[0]}"
}

# True if $2 has a module directory on $1, regardless of enabled/disabled
# state -- same "is it installed at all" semantics as is_installed for
# apps, not "is it currently active".
is_module_installed() {
  local device="$1"
  local module_id="$2"

  [[ -n "$(run_root_shell "$device" "[ -d /data/adb/modules/$module_id ] && echo yes")" ]]
}

# Pushes $2 (a local zip file path) to $1 and runs the framework-specific
# module install command through a root shell. run_root_shell's exit
# status here genuinely reflects the remote apd/magisk command's own exit
# code (confirmed against a real device for both the success and failure
# case -- a bad/non-module zip gave a real non-zero exit and an error
# message on stdout, not silence): the pipeline it runs (`adb shell ... |
# tr -d '\r'`) reports that correctly under this script's `pipefail` even
# though it's piped through tr, since pipefail reports the *last command
# that actually failed*, not just the rightmost stage. Given a 60s
# timeout, longer than run_root_shell's 15s default for quick probes --
# extracting/running a module's install scripts can genuinely take longer
# than a `command -v`/`module list` round trip. Cleans up the pushed temp
# file regardless of outcome.
install_module_zip() {
  local device="$1"
  local zip_path="$2"
  local framework="$3"
  local remote_path output rc=0
  remote_path="/data/local/tmp/declaroid-module-$(basename "$zip_path")"

  if ! adb -s "$device" push "$zip_path" "$remote_path" >/dev/null 2>&1
  then
    log_error "Failed to push $zip_path to $device"
    return 1
  fi

  case "$framework" in
    apatch)
      output="$(run_root_shell "$device" "apd module install $remote_path" 60)" || rc=$?
      ;;
    magisk)
      output="$(run_root_shell "$device" "magisk --install-module $remote_path" 60)" || rc=$?
      ;;
    *)
      log_error "Unknown root framework '$framework' (expected apatch or magisk)"
      rc=1
      ;;
  esac

  adb -s "$device" shell "rm -f $remote_path" >/dev/null 2>&1

  if [[ $rc -ne 0 ]]
  then
    log_error "Module install failed:"
    printf '%s\n' "$output" >&2
    return 1
  fi
}

# Reads its per-module inputs from CURRENT_MODULE_* (set by
# for_each_module's read loop) and its run-wide context from
# DEVICE_SERIAL/DRY_RUN/FORCE_DOWNLOAD/ROOT_FRAMEWORK/VERBOSE (set once per
# device by cmd_apply before calling for_each_module) -- same convention
# as install_app. Increments the run-wide MODULES_INSTALLED_COUNT on a
# genuinely new install (not on skip), so cmd_apply can print a single
# "reboot required" reminder at the end instead of one per module.
install_module_app() {
  local rc=0

  if is_module_installed "$DEVICE_SERIAL" "$CURRENT_MODULE_ID"
  then
    [[ -n "$VERBOSE" ]] && log_skip "$CURRENT_MODULE_NAME ($CURRENT_MODULE_ID) already installed"
    return 0
  fi

  log_step "Installing module $CURRENT_MODULE_NAME ($CURRENT_MODULE_ID) [$CURRENT_MODULE_SOURCE]"

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would install %s via %s\n' "$CURRENT_MODULE_ID" "$CURRENT_MODULE_SOURCE"
    return 0
  fi

  local zip_path
  if ! zip_path="$(resolve_module_zip)"
  then
    return 1
  fi

  if install_module_zip "$DEVICE_SERIAL" "$zip_path" "$ROOT_FRAMEWORK"
  then
    log_ok "$CURRENT_MODULE_NAME ($CURRENT_MODULE_ID) installed"
    MODULES_INSTALLED_COUNT=$((MODULES_INSTALLED_COUNT + 1))
  else
    rc=1
  fi

  return "$rc"
}

# Same idea as build_install_plan, but for modules -- see its comment.
build_module_plan() {
  local config="$1"
  MODULE_PLAN_PENDING=()
  MODULE_PLAN_SKIP_COUNT=0

  local -a rows
  mapfile -t rows < <(module_rows "$config")

  local row id name source rest
  for row in "${rows[@]}"
  do
    # See for_each_module's comment on the same guard.
    [[ -z "$row" ]] && continue
    IFS='§' read -r id name source rest <<< "$row"

    if is_module_installed "$DEVICE_SERIAL" "$id"
    then
      MODULE_PLAN_SKIP_COUNT=$((MODULE_PLAN_SKIP_COUNT + 1))
    else
      MODULE_PLAN_PENDING+=("$name"$'\t'"$id"$'\t'"$source")
    fi
  done
}

# Same idea as print_install_plan, but for modules -- see its comment.
print_module_plan() {
  local device="$1"
  local p name id source

  {
    printf '%sModule install plan for %s:%s %d module(s) to install' \
      "$C_BOLD" "$device" "$C_RESET" "${#MODULE_PLAN_PENDING[@]}"
    if [[ "$MODULE_PLAN_SKIP_COUNT" -gt 0 ]]
    then
      printf ' (%d already installed)' "$MODULE_PLAN_SKIP_COUNT"
    fi
    printf '\n'

    for p in "${MODULE_PLAN_PENDING[@]}"
    do
      IFS=$'\t' read -r name id source <<< "$p"
      printf '  %s (%s) [%s%s%s]\n' "$name" "$id" "$C_CYAN" "$source" "$C_RESET"
    done
  } >&2
}

# Converges the device's enabled/disabled state for CURRENT_PKG to match
# CURRENT_STATE_DISABLED ("true"/"false", from `state.disabled:` in the
# config) via `pm disable-user`/`pm enable` -- picked over `pm archive`
# since archive/unarchive depends on the installer supporting an unarchive
# request, which isn't a safe assumption for github/local/url-sourced apps
# (only really solid for gplay). Symmetric: also re-enables a currently
# disabled app when the config no longer wants it disabled, so flipping
# `state.disabled` back to false/absent converges the device back, not just
# the true direction. Reads/writes CURRENT_NAME/CURRENT_PKG/DEVICE_SERIAL/
# DRY_RUN like install_app's other helpers.
sync_app_disabled_state() {
  local currently_disabled=""
  is_pkg_disabled "$DEVICE_SERIAL" "$CURRENT_PKG" && currently_disabled=1

  if [[ "$CURRENT_STATE_DISABLED" == true ]]
  then
    [[ -n "$currently_disabled" ]] && return 0

    log_step "Disabling $CURRENT_NAME ($CURRENT_PKG)"

    if [[ -n "$DRY_RUN" ]]
    then
      printf '  would disable %s\n' "$CURRENT_PKG"
      return 0
    fi

    if adb -s "$DEVICE_SERIAL" shell pm disable-user "$CURRENT_PKG" </dev/null >/dev/null 2>&1
    then
      log_ok "$CURRENT_NAME ($CURRENT_PKG) disabled"
    else
      log_error "Failed to disable $CURRENT_NAME ($CURRENT_PKG)"
      return 1
    fi
  else
    [[ -z "$currently_disabled" ]] && return 0

    log_step "Enabling $CURRENT_NAME ($CURRENT_PKG)"

    if [[ -n "$DRY_RUN" ]]
    then
      printf '  would enable %s\n' "$CURRENT_PKG"
      return 0
    fi

    if adb -s "$DEVICE_SERIAL" shell pm enable "$CURRENT_PKG" </dev/null >/dev/null 2>&1
    then
      log_ok "$CURRENT_NAME ($CURRENT_PKG) enabled"
    else
      log_error "Failed to enable $CURRENT_NAME ($CURRENT_PKG)"
      return 1
    fi
  fi
}

# Reads its per-app inputs from CURRENT_NAME/CURRENT_PKG/CURRENT_STORE/
# CURRENT_REPO/CURRENT_ASSET/CURRENT_PATH/CURRENT_PROFILE/CURRENT_URL/
# CURRENT_STATE_INSTALLED/CURRENT_STATE_DISABLED (set by for_each_app's read
# loop) and its run-wide context from DEVICE_SERIAL/DRY_RUN/FORCE_DOWNLOAD/
# TARGET_USER (set by cmd_apply before calling for_each_app). See AGENTS.md
# for why -- this replaced a positional-argument chain that kept growing
# every time a store needed one more piece of config.
#
# `state.installed: false` apps are skipped entirely here (return 0
# immediately, no log line) -- they're handled by build_removal_plan/
# cmd_apply's removal pass instead, not this one. Otherwise, once installed
# (or already present), state.disabled: is converged via
# sync_app_disabled_state -- "install it, then disable" is deliberate: a
# disabled app is still a *present* app, just dormant, not "don't bother
# installing it".
install_app() {
  local rc=0

  if [[ "$CURRENT_STATE_INSTALLED" == false ]]
  then
    return 0
  fi

  if is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
  then
    [[ -n "$VERBOSE" ]] && log_skip "$CURRENT_NAME ($CURRENT_PKG) already installed"
  else
    log_step "Installing $CURRENT_NAME ($CURRENT_PKG) [$CURRENT_STORE]"

    if [[ -n "$DRY_RUN" ]]
    then
      printf '  would install %s via %s\n' "$CURRENT_PKG" "$CURRENT_STORE"
    else
      case "$CURRENT_STORE" in
        gplay)
          install_gplay || rc=$?
          ;;
        fdroid)
          install_fdroid || rc=$?
          ;;
        izzyondroid)
          install_izzyondroid || rc=$?
          ;;
        github)
          install_github || rc=$?
          ;;
        local)
          install_local || rc=$?
          ;;
        url)
          install_url || rc=$?
          ;;
        *)
          log_error "Unknown store '$CURRENT_STORE' for $CURRENT_PKG (expected gplay, fdroid, izzyondroid, github, local, or url)"
          rc=1
          ;;
      esac

      if [[ $rc -eq 0 ]]
      then
        log_ok "$CURRENT_NAME ($CURRENT_PKG) installed"
      fi
    fi
  fi

  if [[ $rc -eq 0 ]]
  then
    sync_app_disabled_state || rc=$?
  fi

  return "$rc"
}

# See install_app's comment -- same convention, repo/asset/path are unused
# here (uninstalling doesn't care what store an app came from).
uninstall_app() {
  if ! is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
  then
    log_skip "$CURRENT_NAME ($CURRENT_PKG) not installed"
    return 0
  fi

  log_step "Uninstalling $CURRENT_NAME ($CURRENT_PKG)"

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would uninstall %s\n' "$CURRENT_PKG"
    return 0
  fi

  if adb -s "$DEVICE_SERIAL" uninstall "$CURRENT_PKG"
  then
    log_ok "$CURRENT_NAME ($CURRENT_PKG) uninstalled"
  else
    return 1
  fi
}

# Recursively resolves $config's `imports:` list (paths relative to
# $config's own directory) into IMPORT_FILES -- a flat, ordered list of
# fragment file paths, deepest/earliest dependencies first -- by
# appending to the caller-declared `local -a IMPORT_FILES=()` (same
# dynamic-scope accumulator convention as PLAN_PENDING/REMOVAL_PLAN_PENDING
# elsewhere in this file). This has to be an accumulator, not a "print
# rows, mapfile the output" function like the rest of this file's helpers
# -- capturing a *recursive* self-call via `< <(...)`/`$(...)` would fork
# a subshell per call, and SEEN (also caller-declared, `local -A SEEN=()`)
# needs to survive across the whole recursion to catch a cycle at all.
# Recurses into each import's own `imports:` too, so a shared fragment can
# itself pull in another (a legitimate diamond -- two configs importing
# the same common fragment -- must still work, so this guards by realpath
# rather than a fixed depth cap).
collect_imports() {
  local config="$1"

  local real
  real="$(realpath "$config")"

  if [[ -n "${SEEN[$real]:-}" ]]
  then
    log_error "Cycle detected in imports: at $config"
    return 1
  fi
  SEEN["$real"]=1

  local dir
  dir="$(dirname "$config")"

  local -a raw_imports
  mapfile -t raw_imports < <(yq -r '(.imports // [])[]' "$config")

  local imp resolved_imp
  for imp in "${raw_imports[@]}"
  do
    [[ -z "$imp" ]] && continue

    if [[ "$imp" == /* ]]
    then
      resolved_imp="$imp"
    else
      resolved_imp="$dir/$imp"
    fi

    if [[ ! -f "$resolved_imp" ]]
    then
      log_error "imports: entry not found: $resolved_imp (from $config)"
      return 1
    fi

    collect_imports "$resolved_imp" || return 1
    IMPORT_FILES+=("$resolved_imp")
  done
}

# If $config has no `imports:` at all (the common case), prints $config
# unchanged -- no copy, no temp file. Otherwise merges apps:/modules:/
# profiles:/obtainium: from every resolved import (collect_imports, in
# dependency order) plus $config's own entries (last -- imports contribute
# first, so a device-specific file's own list conceptually reads as "on
# top of the shared ones", though this is pure concatenation, not an
# override/dedup by pkg/id) into a throwaway temp copy, and prints *that*
# path instead. `enforce`/`grant_permissions`/`store`/`obtainium_auto_track`
# additionally cascade in from imports as scalar overrides (config's own
# value wins if set at all, else the last import that sets it) -- see the
# scalar_key loop below. Every other top-level key (device/adb/root/profile)
# is copied verbatim from $config, untouched -- imports never contribute
# to those.
# Every caller (cmd_apply/cmd_uninstall/
# cmd_diff/cmd_modules) reassigns its own local `config` to this function's
# output right after its own config-file-exists check, so every existing
# `yq`/app_rows/module_rows/list_extra_pkgs/etc call site downstream keeps
# treating `$config` as an opaque path -- no other change needed anywhere
# else in the script. `add`/`download` deliberately do NOT call this: `add`
# writes into the real, original file (a merged temp copy would be
# discarded after the run), so its own duplicate-pkg check only ever sees
# that file's own `apps:`, not anything pulled in via `imports:` -- a
# known, documented limitation, not an oversight.
resolve_config() {
  local config="$1"

  local -A SEEN=()
  local -a IMPORT_FILES=()
  collect_imports "$config" || return 1

  if [[ ${#IMPORT_FILES[@]} -eq 0 ]]
  then
    printf '%s\n' "$config"
    return 0
  fi

  local resolved
  resolved="$(mktemp --suffix=.yaml)"
  cp "$config" "$resolved"

  # `yq eval-all '[(.$key // [])[]]' file1 file2 ...` is the confirmed-
  # working idiom for "concatenate this array key across every listed
  # file, in file order" -- yq has no `!include`-style tag support at all
  # (checked `yq --help`), so this is declaroid's own preprocessing, not a
  # yq/YAML-native feature. The merged array is written to its own temp
  # file and pulled back in via `load(strenv(...))` (env-var-scoped,
  # same convention as add_app_to_config's DECLAROID_NAME/DECLAROID_PKG)
  # rather than trying to inline a large array as a literal expression.
  local key merged_file
  for key in apps modules profiles obtainium
  do
    merged_file="$(mktemp --suffix=.yaml)"
    yq eval-all "[(.$key // [])[]]" "${IMPORT_FILES[@]}" "$config" > "$merged_file"
    DECLAROID_MERGED_FILE="$merged_file" yq -i ".$key = load(strenv(DECLAROID_MERGED_FILE))" "$resolved"
    rm -f "$merged_file"
  done

  # A handful of scalar top-level settings use override semantics instead
  # (a device config's own value always wins if it sets the key at all;
  # otherwise the last import in the list that sets it wins) -- this is
  # what lets a shared imports/base.yaml carry defaults like `enforce:
  # true`/`store: gplay`/`obtainium_auto_track: true` for every device
  # that imports it, without every device file having to repeat it.
  # Deliberately only these four keys, not device/adb/root/profile --
  # those stay squarely a per-device concern, never cascaded from an
  # import.
  #
  # The value is round-tripped through its own one-line temp file and
  # `load(strenv(...))`, same mechanism as the list-key merge above, not
  # extracted via `yq -r` and spliced back in as bare text -- confirmed
  # necessary, not just tidier: a bare-text splice works by accident for a
  # boolean (`.enforce = true` is valid yq-expression syntax on its own)
  # but breaks for any string value (`.store = gplay` errors out, "invalid
  # input text" -- yq's expression language, unlike YAML itself, has no
  # bare-unquoted-string literal syntax).
  local scalar_key has_own has_import chosen_file imp_val_file imp
  for scalar_key in enforce grant_permissions store obtainium_auto_track
  do
    has_own="$(yq -r "has(\"$scalar_key\")" "$config")"
    [[ "$has_own" == true ]] && continue

    chosen_file=""
    for imp in "${IMPORT_FILES[@]}"
    do
      has_import="$(yq -r "has(\"$scalar_key\")" "$imp")"
      [[ "$has_import" == true ]] && chosen_file="$imp"
    done
    [[ -z "$chosen_file" ]] && continue

    imp_val_file="$(mktemp --suffix=.yaml)"
    yq eval ".$scalar_key" "$chosen_file" > "$imp_val_file"
    DECLAROID_SCALAR_FILE="$imp_val_file" yq -i ".$scalar_key = load(strenv(DECLAROID_SCALAR_FILE))" "$resolved"
    rm -f "$imp_val_file"
  done

  printf '%s\n' "$resolved"
}

# Emits the configured apps as one row per app: name, pkg, store (defaulted),
# repo, asset (defaulted), path, profile (defaulted), url, state.installed
# (defaulted "true"), state.disabled (defaulted "false") -- joined with
# U+00A7 (SECTION SIGN), not a tab. Several of these fields (repo/asset/
# path/profile/url) are legitimately empty for most apps, and bash's `read`
# collapses consecutive *whitespace* IFS delimiters (tab included)
# regardless of what IFS is set to, silently dropping empty fields and
# shifting everything after them left by one. Using a non-whitespace,
# extremely-unlikely-to-appear-in-real-data separator sidesteps that
# entirely. The two state fields use an explicit `== false`/`== true`
# comparison, not `//` -- `//` treats an explicit `false` the same as an
# absent key (see AGENTS.md's `.root.enabled // ""` entry), which would
# silently discard `state.installed: false`. Shared by for_each_app and
# cmd_diff.
app_rows() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.store // "gplay") as $ds |
    (.profile // "") as $dp |
    .apps[] |
    [.name, .pkg, (.store // $ds), (.repo // ""), (.asset // "\\.apk$"), (.path // ""), (.profile // $dp), (.url // ""), ((.state.installed == false) | not), (.state.disabled == true)] | join("§")' "$config"
}

# Calls app_fn (a zero-arg function; see install_app's comment) once per
# configured app, with CURRENT_NAME/CURRENT_PKG/CURRENT_STORE/CURRENT_REPO/
# CURRENT_ASSET/CURRENT_PATH/CURRENT_PROFILE/CURRENT_URL/
# CURRENT_STATE_INSTALLED/CURRENT_STATE_DISABLED set for it to read.
for_each_app() {
  local config="$1"
  local app_fn="$2"
  local failures=0

  while IFS='§' read -r CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH CURRENT_PROFILE CURRENT_URL CURRENT_STATE_INSTALLED CURRENT_STATE_DISABLED <&3
  do
    # yq -r emits one blank line, not zero output, for `.apps[] | ... |
    # join(...)` over an empty/absent apps: list (same quirk documented on
    # for_each_module) -- skip the phantom all-empty-fields iteration this
    # would otherwise cause.
    [[ -z "$CURRENT_PKG" ]] && continue

    if ! "$app_fn"
    then
      log_error "$CURRENT_NAME ($CURRENT_PKG) failed"
      failures=$((failures + 1))
    fi
  done 3< <(app_rows "$config")

  if [[ $failures -gt 0 ]]
  then
    log_error "$failures app(s) failed"
    return 1
  fi

  log_ok "All apps processed successfully"
}

# Read-only pass over the config: populates PLAN_PENDING (tab-separated
# name/pkg/store rows) with configured apps not yet installed on
# $DEVICE_SERIAL, and PLAN_SKIP_COUNT with how many already are. Apps with
# `state.installed: false` are skipped entirely here (neither pending nor
# counted as a skip) -- they're not desired at all, so they're handled by
# build_removal_plan instead, not this one. Assigns straight into the
# caller's PLAN_PENDING/PLAN_SKIP_COUNT locals (same dynamic-scoping
# convention as CURRENT_*/DEVICE_SERIAL elsewhere) rather than being local
# itself. Never logs anything -- this only builds the plan that
# print_install_plan then shows once, up front; per-app "already installed"
# messages are still install_app's job, during the real pass, gated on
# --verbose there. Uses mapfile + a plain for loop, not a `while read
# < <(...)`, per the ban on that construct elsewhere in this file (see
# AGENTS.md).
build_install_plan() {
  local config="$1"
  PLAN_PENDING=()
  PLAN_SKIP_COUNT=0

  local -a rows
  mapfile -t rows < <(app_rows "$config")

  local row name pkg store _repo _asset _path _profile _url state_installed _state_disabled
  for row in "${rows[@]}"
  do
    # See for_each_app's comment on the same guard.
    [[ -z "$row" ]] && continue
    IFS='§' read -r name pkg store _repo _asset _path _profile _url state_installed _state_disabled <<< "$row"

    [[ "$state_installed" == false ]] && continue

    if is_installed "$DEVICE_SERIAL" "$pkg"
    then
      PLAN_SKIP_COUNT=$((PLAN_SKIP_COUNT + 1))
    else
      PLAN_PENDING+=("$name"$'\t'"$pkg"$'\t'"$store")
    fi
  done
}

# Read-only pass over the config: populates REMOVAL_PLAN_PENDING
# (tab-separated name/pkg rows) with configured apps that have
# `state.installed: false` but are still actually present on
# $DEVICE_SERIAL -- the mirror image of build_install_plan, for the apps
# that are explicitly *not* desired rather than the ones that are.
build_removal_plan() {
  local config="$1"
  REMOVAL_PLAN_PENDING=()

  local -a rows
  mapfile -t rows < <(app_rows "$config")

  local row name pkg _store _repo _asset _path _profile _url state_installed _state_disabled
  for row in "${rows[@]}"
  do
    [[ -z "$row" ]] && continue
    IFS='§' read -r name pkg _store _repo _asset _path _profile _url state_installed _state_disabled <<< "$row"

    if [[ "$state_installed" == false ]] && is_installed "$DEVICE_SERIAL" "$pkg"
    then
      REMOVAL_PLAN_PENDING+=("$name"$'\t'"$pkg")
    fi
  done
}

# Prints the plan built by build_removal_plan for confirmation. Read-only.
print_removal_plan() {
  local device="$1"
  local p name pkg

  {
    printf '%sRemoval plan for %s:%s %d app(s) marked state.installed: false but still present\n' \
      "$C_BOLD" "$device" "$C_RESET" "${#REMOVAL_PLAN_PENDING[@]}"

    for p in "${REMOVAL_PLAN_PENDING[@]}"
    do
      IFS=$'\t' read -r name pkg <<< "$p"
      printf '  %s (%s)\n' "$name" "$pkg"
    done
  } >&2
}

# Prints the plan built by build_install_plan for confirmation. Read-only.
print_install_plan() {
  local device="$1"
  local p name pkg store

  {
    printf '%sInstall plan for %s:%s %d app(s) to install' \
      "$C_BOLD" "$device" "$C_RESET" "${#PLAN_PENDING[@]}"
    if [[ "$PLAN_SKIP_COUNT" -gt 0 ]]
    then
      printf ' (%d already installed)' "$PLAN_SKIP_COUNT"
    fi
    printf '\n'

    for p in "${PLAN_PENDING[@]}"
    do
      IFS=$'\t' read -r name pkg store <<< "$p"
      printf '  %s (%s) [%s%s%s]\n' "$name" "$pkg" "$C_CYAN" "$store" "$C_RESET"
    done
  } >&2
}

cmd_apply() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local DRY_RUN=""
  local FORCE_DOWNLOAD=""
  local VERBOSE=""
  local bulk=""
  local enforce=""
  local GRANT_PERMISSIONS=""
  local do_reboot=""
  local assume_yes=""
  local cli_root_framework=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      -k|--dry-run|--dryrun)
        DRY_RUN=1
        shift
        ;;
      -f|--force-download)
        FORCE_DOWNLOAD=1
        shift
        ;;
      --enforce)
        enforce=1
        shift
        ;;
      -g|--grant|--grant-permissions)
        GRANT_PERMISSIONS=1
        shift
        ;;
      --reboot)
        do_reboot=1
        shift
        ;;
      -y|--yes|--noconfirm|--no-confirm)
        assume_yes=1
        shift
        ;;
      -v|--verbose)
        VERBOSE=1
        shift
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      --root-framework)
        cli_root_framework="$2"
        shift 2
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  case "$cli_root_framework" in
    ""|apatch|magisk)
      ;;
    *)
      log_error "Invalid --root-framework value: $cli_root_framework (expected apatch or magisk)"
      return 2
      ;;
  esac

  check_deps adb yq sha256sum

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local resolved_config
  if ! resolved_config="$(resolve_config "$config")"
  then
    return 2
  fi
  # Immediate expansion is intentional here, not the mistake SC2064
  # usually flags: $resolved_config is a `local` that won't exist in any
  # active scope by the time an EXIT trap actually fires (confirmed
  # empirically -- a single-quoted, truly deferred version threw
  # "resolved_config: unbound variable" under this script's set -u,
  # since traps evaluate in whatever scope is active when they fire, not
  # the scope `trap` was called from). Baking the resolved path in as a
  # literal string now is the whole point.
  # shellcheck disable=SC2064
  [[ "$resolved_config" != "$config" ]] && trap "rm -f '$resolved_config'" EXIT
  config="$resolved_config"

  # `enforce: true` in the config is equivalent to always passing
  # --enforce -- an explicit `== true` comparison, not `//`, since the
  # default (false) is what `//` would coalesce an absent key to anyway,
  # but explicit comparison keeps this consistent with every other
  # optional boolean in this file (see AGENTS.md's `.root.enabled // ""`
  # entry for why `//` is avoided here on principle). The CLI flag and the
  # config key OR together -- either one turning it on is enough.
  if [[ -z "$enforce" ]]
  then
    local config_enforce
    config_enforce="$(yq -r '.enforce == true' "$config")"
    [[ "$config_enforce" == true ]] && enforce=1
  fi

  # Same OR pattern as enforce above. GRANT_PERMISSIONS itself is read by
  # install_apk_files/install_splits, several calls down through
  # for_each_app/install_app -- a `local` here, dynamic-scope visible to
  # everything cmd_apply calls (same convention as DRY_RUN/TARGET_USER,
  # see AGENTS.md), to append `-g` to the actual `adb install`/
  # `install-multiple` invocation.
  if [[ -z "$GRANT_PERMISSIONS" ]]
  then
    local config_grant_permissions
    config_grant_permissions="$(yq -r '.grant_permissions == true' "$config")"
    [[ "$config_grant_permissions" == true ]] && GRANT_PERMISSIONS=1
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  load_profile_aliases "$config"

  local -a stores
  mapfile -t stores < <(config_stores "$config")

  if printf '%s\n' "${stores[@]}" | grep -qx gplay
  then
    check_deps gplaydl
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx fdroid
  then
    check_deps fdroidcl
    log_step "Updating F-Droid index"
    fdroidcl update
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx izzyondroid
  then
    check_deps fdroidcl
    ensure_izzyondroid_repo
    log_step "Updating IzzyOnDroid index"
    izzyondroid_fdroidcl update
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx github
  then
    check_deps curl jq
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx url
  then
    check_deps curl
  fi

  local -a configured_module_ids module_sources
  mapfile -t configured_module_ids < <(yq -r '(.modules // [])[].id' "$config")

  if [[ ${#configured_module_ids[@]} -gt 0 ]]
  then
    mapfile -t module_sources < <(yq -r '(.modules // [])[] | (.source // "github")' "$config" | sort -u)

    if printf '%s\n' "${module_sources[@]}" | grep -qx github
    then
      check_deps curl jq
    fi

    if printf '%s\n' "${module_sources[@]}" | grep -qx url
    then
      check_deps curl
    fi
  fi

  # obtainium_needed also has to account for obtainium_auto_track:/a
  # per-app obtainium: true override -- both can make sync_obtainium_repos
  # have real work to do even with an empty (or absent) obtainium: list of
  # its own. See effective_obtainium_rows.
  local -a configured_obtainium_pkgs
  mapfile -t configured_obtainium_pkgs < <(yq -r '(.obtainium // [])[].pkg' "$config")
  local obtainium_needed=""
  [[ ${#configured_obtainium_pkgs[@]} -gt 0 ]] && obtainium_needed=1
  [[ "$(yq -r '.obtainium_auto_track == true' "$config")" == true ]] && obtainium_needed=1
  [[ "$(yq -r '[.apps[] | select(.obtainium == true)] | length > 0' "$config")" == true ]] && obtainium_needed=1
  [[ -n "$obtainium_needed" ]] && check_deps jq

  local DEVICE_SERIAL TARGET_USER ROOT_FRAMEWORK overall_rc=0
  local -a PLAN_PENDING MODULE_PLAN_PENDING REMOVAL_PLAN_PENDING
  local PLAN_SKIP_COUNT MODULE_PLAN_SKIP_COUNT MODULES_INSTALLED_COUNT=0
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"
    TARGET_USER="$(resolve_target_user "$DEVICE_SERIAL")"

    build_install_plan "$config"

    local proceed=1
    if [[ ${#PLAN_PENDING[@]} -eq 0 ]]
    then
      log_ok "Nothing to install on $DEVICE_SERIAL ($PLAN_SKIP_COUNT already installed)"
    else
      print_install_plan "$DEVICE_SERIAL"

      if [[ -z "$DRY_RUN" && -z "$assume_yes" ]]
      then
        local reply
        read -rp "Install these ${#PLAN_PENDING[@]} app(s) on $DEVICE_SERIAL? [y/N] " reply
        case "$reply" in
          y|Y|yes|YES)
            ;;
          *)
            log_step "Skipping install on $DEVICE_SERIAL"
            proceed=""
            ;;
        esac
      fi
    fi

    # Always runs unless the user explicitly declined the prompt above --
    # install_app also does the state.disabled: convergence (see its
    # comment) for every already-installed app, not just newly-installed
    # ones, so this must run even when PLAN_PENDING is empty (nothing left
    # to *install*, but there may still be an enable/disable to converge).
    if [[ -n "$proceed" ]] && ! for_each_app "$config" install_app
    then
      overall_rc=1
    fi

    build_removal_plan "$config"

    if [[ ${#REMOVAL_PLAN_PENDING[@]} -gt 0 ]]
    then
      print_removal_plan "$DEVICE_SERIAL"

      local removal_proceed=1
      if [[ -z "$DRY_RUN" && -z "$assume_yes" ]]
      then
        local removal_reply
        read -rp "Uninstall these ${#REMOVAL_PLAN_PENDING[@]} app(s) on $DEVICE_SERIAL? [y/N] " removal_reply
        case "$removal_reply" in
          y|Y|yes|YES)
            ;;
          *)
            log_step "Skipping removal on $DEVICE_SERIAL"
            removal_proceed=""
            ;;
        esac
      fi

      if [[ -n "$removal_proceed" ]]
      then
        local removal_row
        for removal_row in "${REMOVAL_PLAN_PENDING[@]}"
        do
          IFS=$'\t' read -r CURRENT_NAME CURRENT_PKG <<< "$removal_row"

          if ! uninstall_app
          then
            overall_rc=1
          fi
        done
      fi
    fi

    if [[ ${#configured_module_ids[@]} -gt 0 ]]
    then
      if ! ROOT_FRAMEWORK="$(resolve_root_framework "$config" "$cli_root_framework" "$DEVICE_SERIAL")"
      then
        log_ok "Root not enabled/detected on $DEVICE_SERIAL, skipping configured module(s)"
      else
        build_module_plan "$config"

        if [[ ${#MODULE_PLAN_PENDING[@]} -eq 0 ]]
        then
          log_ok "Nothing to install on $DEVICE_SERIAL ($MODULE_PLAN_SKIP_COUNT module(s) already installed)"
        else
          print_module_plan "$DEVICE_SERIAL"

          local module_proceed=1
          if [[ -z "$DRY_RUN" && -z "$assume_yes" ]]
          then
            local module_reply
            read -rp "Install these ${#MODULE_PLAN_PENDING[@]} module(s) on $DEVICE_SERIAL? [y/N] " module_reply
            case "$module_reply" in
              y|Y|yes|YES)
                ;;
              *)
                log_step "Skipping module install on $DEVICE_SERIAL"
                module_proceed=""
                ;;
            esac
          fi

          if [[ -n "$module_proceed" ]] && ! for_each_module "$config" install_module_app
          then
            overall_rc=1
          fi
        fi
      fi
    fi

    if [[ -n "$obtainium_needed" ]] && ! sync_obtainium_repos "$config" "$DEVICE_SERIAL" "$cli_root_framework"
    then
      overall_rc=1
    fi

    if [[ -n "$enforce" ]] && ! enforce_config "$config" "$DEVICE_SERIAL" "$DRY_RUN" "$assume_yes"
    then
      overall_rc=1
    fi
  done

  if [[ "$MODULES_INSTALLED_COUNT" -gt 0 ]]
  then
    if [[ -n "$do_reboot" ]]
    then
      local device
      for device in "${devices[@]}"
      do
        if [[ -n "$DRY_RUN" ]]
        then
          printf '  would reboot %s\n' "$device" >&2
        else
          log_step "Rebooting $device"
          adb -s "$device" reboot
        fi
      done
    else
      log_warn "$MODULES_INSTALLED_COUNT module(s) installed -- reboot the device(s) for changes to take effect (or pass --reboot)"
    fi
  fi

  maybe_run_adb_stop_cmd "$config" "$DRY_RUN"

  return "$overall_rc"
}

# `apply --enforce`: uninstalls any device-installed, non-plumbing package
# with no matching `pkg:` entry in the config (see list_extra_pkgs). Prompts
# once for the whole batch on a given device, not once per package -- skip
# the prompt with -y/--yes/--noconfirm/--no-confirm. Respects --dry-run:
# prints what would be removed, uninstalls nothing.
enforce_config() {
  local config="$1"
  local device="$2"
  local dry_run="$3"
  local assume_yes="$4"

  local -a extra_pkgs
  mapfile -t extra_pkgs < <(list_extra_pkgs "$config" "$device")

  if [[ ${#extra_pkgs[@]} -eq 0 ]]
  then
    log_ok "No unconfigured apps found on $device"
    return 0
  fi

  log_step "Found ${#extra_pkgs[@]} unconfigured app(s) on $device:"
  local pkg
  for pkg in "${extra_pkgs[@]}"
  do
    printf '  %s\n' "$pkg" >&2
  done

  if [[ -n "$dry_run" ]]
  then
    printf '  would uninstall %d app(s)\n' "${#extra_pkgs[@]}"
    return 0
  fi

  if [[ -z "$assume_yes" ]]
  then
    local reply
    read -rp "Uninstall these ${#extra_pkgs[@]} app(s) from $device? [y/N] " reply
    case "$reply" in
      y|Y|yes|YES)
        ;;
      *)
        log_step "Skipping enforcement on $device"
        return 0
        ;;
    esac
  fi

  local failures=0
  for pkg in "${extra_pkgs[@]}"
  do
    log_step "Uninstalling $pkg"
    if adb -s "$device" uninstall "$pkg"
    then
      log_ok "$pkg uninstalled"
    else
      log_error "$pkg failed to uninstall"
      failures=$((failures + 1))
    fi
  done

  if [[ $failures -gt 0 ]]
  then
    return 1
  fi
}

