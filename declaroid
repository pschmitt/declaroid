#!/usr/bin/env bash

set -euo pipefail

DEFAULT_CONFIG="${DECLAROID_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/declaroid/apps.yaml}"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/declaroid"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]
then
  C_RESET=$'\e[0m'
  C_BOLD=$'\e[1m'
  C_RED=$'\e[31m'
  C_GREEN=$'\e[32m'
  C_YELLOW=$'\e[33m'
  C_BLUE=$'\e[34m'
  C_CYAN=$'\e[36m'
else
  C_RESET=''
  C_BOLD=''
  C_RED=''
  C_GREEN=''
  C_YELLOW=''
  C_BLUE=''
  C_CYAN=''
fi

log_step() {
  printf '%s==>%s %s\n' "${C_BOLD}${C_BLUE}" "$C_RESET" "$1" >&2
}

log_skip() {
  printf '%s[skip]%s %s\n' "$C_YELLOW" "$C_RESET" "$1" >&2
}

log_ok() {
  printf '%s[ok]%s %s\n' "$C_GREEN" "$C_RESET" "$1" >&2
}

log_warn() {
  printf '%s[warn]%s %s\n' "$C_YELLOW" "$C_RESET" "$1" >&2
}

log_error() {
  printf '%s[error]%s %s\n' "$C_RED" "$C_RESET" "$1" >&2
}

usage() {
  cat <<EOF
${C_BOLD}Usage:${C_RESET} ${C_GREEN}declaroid${C_RESET} COMMAND [OPTIONS]

Declarative Android app provisioning: define apps in YAML, install/uninstall
them onto a device via adb, fetching from Google Play (gplaydl), F-Droid
(fdroidcl), a GitHub repo's release assets, or a local APK file.

${C_BOLD}Commands:${C_RESET}
  ${C_CYAN}install${C_RESET}     Download (if not already cached) and install configured apps
  ${C_CYAN}uninstall${C_RESET}   Uninstall configured apps (no download)
  ${C_CYAN}diff${C_RESET}        Show which configured apps are installed vs missing, no changes made
  ${C_CYAN}devices${C_RESET}, ${C_CYAN}list${C_RESET}
              List connected adb devices (serial, model, codename, connection)
  ${C_CYAN}clear-cache${C_RESET} [PKG...]
              Remove cached APK downloads (all of them, or just PKG(s) given)

${C_BOLD}Options:${C_RESET}
  ${C_YELLOW}-c, --config FILE${C_RESET}       Path to the apps YAML config (default: ${DEFAULT_CONFIG})
  ${C_YELLOW}-d, --device QUERY${C_RESET}      Target device (also settable via \$TARGET_DEVICE)
      ${C_YELLOW}--dry-run${C_RESET}           Print what would happen without downloading/installing/uninstalling
  ${C_YELLOW}-f, --force-download${C_RESET}    (install only) Re-download even if a cached copy exists
  ${C_YELLOW}-y, --yes, --noconfirm, --no-confirm${C_RESET}
                          (uninstall/clear-cache) Skip the confirmation prompt
      ${C_YELLOW}--bulk, --all-devices, --all${C_RESET}
                          Target every device that matches (see below), instead
                          of erroring out on an ambiguous match
  ${C_YELLOW}-h, --help${C_RESET}              Show this help

${C_BOLD}Config resolution order:${C_RESET} --config, \$DECLAROID_CONFIG,
${XDG_CONFIG_HOME:-\$HOME/.config}/declaroid/apps.yaml

${C_BOLD}Device resolution order:${C_RESET} --device, \$TARGET_DEVICE, .device in the config.
The value is matched as a case-insensitive substring against each connected
device's serial, USB path, product, model, and codename (e.g. "redfin",
"clover", an IP, or part of a serial) -- so it doesn't need to be exact. Run
${C_CYAN}declaroid devices${C_RESET} to see what's connected and matchable.
If it matches more than one connected device, declaroid errors out unless
--bulk/--all-devices/--all is given, in which case every match is used.
If nothing resolves at all, you'll be prompted to pick from connected
devices (or, with --bulk, every connected device is used).

${C_BOLD}Config schema:${C_RESET}
  device: <adb serial or substring query>   # optional, see device resolution above
  store: gplay|fdroid|github|local           # optional top-level default, defaults to gplay
  apps:
    - name: <display name>
      pkg: <package id>
      store: gplay|fdroid|github|local  # optional, overrides the top-level default
      repo: <owner>/<repo>          # required when store is github
      asset: <regex>                # (github only) selects the release asset;
                                     # default: '\\.apk\$'. Must match exactly one
                                     # asset -- narrow it for multi-arch/multi-flavor
                                     # releases (e.g. debug vs release, per-ABI apks).
      path: <file, glob, or dir>    # required when store is local; a single apk
                                     # file, a glob matching one or more splits, or
                                     # a directory (every *.apk directly inside it).

github releases are queried via the GitHub API; set \$GITHUB_TOKEN to raise
the unauthenticated rate limit or access private repos. If a repo has no
non-prerelease release, the most recent release (including prereleases) is
used instead.

APKs downloaded from gplay/github are cached under ${CACHE_ROOT}/<package-id>/
so repeated installs don't re-download (see --force-download). fdroid apps
are cached by fdroidcl itself; local apps aren't cached (nothing to cache).

Table output (devices, diff) is rendered with tsvtool if it's on \$PATH
(https://github.com/pschmitt/tsvtool), otherwise with column -t.
EOF
}

check_deps() {
  local bin

  for bin in "$@"
  do
    if ! command -v "$bin" >/dev/null 2>&1
    then
      log_error "Missing required binary: $bin"
      return 1
    fi
  done
}

config_stores() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.store // "gplay") as $d | [.apps[] | (.store // $d)] | unique | .[]' "$config"
}

list_device_lines() {
  adb devices -l | awk 'NR>1 && $2=="device" {print}'
}

build_searchable() {
  local line="$1"
  local serial="${line%% *}"
  local usb="" product="" model="" codename=""

  [[ "$line" =~ usb:([^[:space:]]+) ]] && usb="${BASH_REMATCH[1]}"
  [[ "$line" =~ product:([^[:space:]]+) ]] && product="${BASH_REMATCH[1]}"
  [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
  [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"

  printf '%s %s %s %s %s\n' "$serial" "$usb" "$product" "$model" "$codename"
}

format_device_line() {
  local line="$1"
  local serial="${line%% *}"
  local model="" codename=""

  [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
  [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"

  if [[ -n "$model" || -n "$codename" ]]
  then
    printf '%s (%s/%s)\n' "$serial" "${model:-?}" "${codename:-?}"
  else
    printf '%s\n' "$serial"
  fi
}

# Pretty-prints TSV (with a header row) read from stdin. Uses tsvtool if it's
# on PATH (https://github.com/pschmitt/tsvtool), otherwise falls back to
# column -t with a bolded header, otherwise just passes the TSV through.
render_table() {
  local data
  data="$(cat)"

  if [[ -z "$data" ]]
  then
    return 0
  fi

  if command -v tsvtool >/dev/null 2>&1
  then
    local -a args=(pretty)
    [[ -z "$C_RESET" ]] && args+=(--no-color)
    printf '%s\n' "$data" | tsvtool "${args[@]}"
    return 0
  fi

  if command -v column >/dev/null 2>&1
  then
    local -a rendered
    mapfile -t rendered < <(printf '%s\n' "$data" | column -t -s $'\t')

    if [[ ${#rendered[@]} -gt 0 ]]
    then
      printf '%s%s%s\n' "$C_BOLD" "${rendered[0]}" "$C_RESET"
      if [[ ${#rendered[@]} -gt 1 ]]
      then
        printf '%s\n' "${rendered[@]:1}"
      fi
    fi
    return 0
  fi

  printf '%s\n' "$data"
}

# Colorizes a whole-word match in already-rendered (aligned) text, read from
# stdin. Safe to run on tsvtool's own colored output too: if the word is
# already wrapped in ANSI codes there, the whitespace-boundary match simply
# won't fire, so this is a no-op rather than a corruption in that case.
colorize_word() {
  local word="$1"
  local color="$2"

  if [[ -z "$color" ]]
  then
    cat
    return 0
  fi

  sed -E "s/(^|[[:space:]])(${word})([[:space:]]|\$)/\\1${color}\\2${C_RESET}\\3/"
}

prompt_pick_device() {
  local -a lines=("$@")

  if [[ ! -t 0 ]]
  then
    log_error "Multiple devices connected and no --device/\$TARGET_DEVICE given; stdin is not a terminal to prompt"
    return 1
  fi

  {
    printf '%sMultiple devices connected, pick one:%s\n' "$C_BOLD" "$C_RESET"
    local i
    for i in "${!lines[@]}"
    do
      printf '  %s[%d]%s %s\n' "$C_CYAN" "$((i + 1))" "$C_RESET" "$(format_device_line "${lines[$i]}")"
    done
  } >&2

  local choice
  while true
  do
    read -rp "Device number: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#lines[@]} ))
    then
      printf '%s\n' "${lines[$((choice - 1))]%% *}"
      return 0
    fi
    log_error "Invalid choice: $choice"
  done
}

resolve_devices() {
  local cli_device="$1"
  local config="$2"
  local bulk="$3"
  local query=""

  if [[ -n "$cli_device" ]]
  then
    query="$cli_device"
  elif [[ -n "${TARGET_DEVICE:-}" ]]
  then
    query="$TARGET_DEVICE"
  else
    local from_yaml
    from_yaml="$(yq -r '.device' "$config")"
    if [[ -n "$from_yaml" && "$from_yaml" != "null" ]]
    then
      query="$from_yaml"
    fi
  fi

  local -a lines
  mapfile -t lines < <(list_device_lines)

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_error "No adb devices connected"
    return 1
  fi

  local -a matched=()

  if [[ -n "$query" ]]
  then
    local line searchable
    for line in "${lines[@]}"
    do
      searchable="$(build_searchable "$line")"
      if [[ "${searchable,,}" == *"${query,,}"* ]]
      then
        matched+=("$line")
      fi
    done

    if [[ ${#matched[@]} -eq 0 ]]
    then
      log_error "No connected device matches '$query'"
      return 1
    fi
  else
    matched=("${lines[@]}")
  fi

  if [[ ${#matched[@]} -eq 1 ]]
  then
    printf '%s\n' "${matched[0]%% *}"
    return 0
  fi

  if [[ -n "$bulk" ]]
  then
    log_step "${#matched[@]} device(s) matched, targeting all of them (--bulk)"
    local m
    for m in "${matched[@]}"
    do
      printf '%s\n' "${m%% *}"
    done
    return 0
  fi

  if [[ -z "$query" ]]
  then
    prompt_pick_device "${matched[@]}"
    return $?
  fi

  {
    printf "%sMultiple devices match '%s':%s\\n" "$C_BOLD" "$query" "$C_RESET"
    local m
    for m in "${matched[@]}"
    do
      printf '  %s\n' "$(format_device_line "$m")"
    done
    printf 'Use --bulk/--all-devices/--all to target all of them, or refine the match.\n'
  } >&2
  return 1
}

is_installed() {
  local device="$1"
  local pkg="$2"

  adb -s "$device" shell pm list packages "$pkg" </dev/null 2>/dev/null \
    | tr -d '\r' \
    | grep -qx "package:$pkg"
}

cache_dir_for() {
  local pkg="$1"

  printf '%s/%s\n' "$CACHE_ROOT" "$pkg"
}

has_apk_files() {
  local dir="$1"
  local -a existing=("$dir"/*.apk)

  [[ -e "${existing[0]}" ]]
}

fetch_app() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$FORCE_DOWNLOAD" ]] && has_apk_files "$cache_dir"
  then
    log_step "Using cached download in $cache_dir"
    printf '%s\n' "$cache_dir"
    return 0
  fi

  mkdir -p "$cache_dir"

  if ! gplaydl download "$CURRENT_PKG" -o "$cache_dir" >&2
  then
    log_error "Failed to download $CURRENT_PKG"
    return 1
  fi

  printf '%s\n' "$cache_dir"
}

# Takes a list of APK file paths (a real argument -- computed data, not
# per-app config -- unlike the CURRENT_*/DEVICE_SERIAL/etc convention used
# elsewhere), dedupes them by checksum, and installs the survivors.
install_apk_files() {
  local -a files=("$@")
  local -A seen_hashes
  local -a keep_files
  local f hash base

  for f in "${files[@]}"
  do
    [[ -e "$f" ]] || continue
    hash="$(sha256sum "$f" | cut -d' ' -f1)"
    base="$(basename "$f")"

    if [[ -n "${seen_hashes[$hash]:-}" ]]
    then
      log_warn "Skipping duplicate split $base (identical to ${seen_hashes[$hash]})"
      continue
    fi

    seen_hashes[$hash]="$base"
    keep_files+=("$f")
  done

  if [[ ${#keep_files[@]} -eq 0 ]]
  then
    log_error "No APK files to install"
    return 1
  fi

  adb -s "$DEVICE_SERIAL" install-multiple -r "${keep_files[@]}"
}

install_splits() {
  local dir="$1"
  local -a files
  local -a obb_files

  mapfile -t files < <(find "$dir" -maxdepth 1 -iname '*.apk' | sort)

  if [[ ${#files[@]} -eq 0 ]]
  then
    log_error "No APK files found in $dir"
    return 1
  fi

  if ! install_apk_files "${files[@]}"
  then
    return 1
  fi

  mapfile -t obb_files < <(find "$dir" -maxdepth 1 -iname '*.obb')
  if [[ ${#obb_files[@]} -gt 0 ]]
  then
    log_warn "${#obb_files[@]} OBB/expansion file(s) are cached but not pushed automatically:"
    printf '  %s\n' "${obb_files[@]}"
  fi
}

install_gplay() {
  local cache_dir

  if ! cache_dir="$(fetch_app)"
  then
    return 1
  fi

  install_splits "$cache_dir"
}

install_fdroid() {
  ANDROID_SERIAL="$DEVICE_SERIAL" fdroidcl install "$CURRENT_PKG"
}

install_local() {
  local -a apks

  if [[ -z "$CURRENT_PATH" ]]
  then
    log_error "store: local requires a 'path'"
    return 1
  fi

  if [[ -d "$CURRENT_PATH" ]]
  then
    mapfile -t apks < <(find "$CURRENT_PATH" -maxdepth 1 -iname '*.apk' | sort)
  else
    # $CURRENT_PATH may be a plain file path or a glob pattern (e.g.
    # "/dir/*.apk"); routing both through find -name on the parent dir
    # handles either case without word-splitting/quoting hazards, unlike
    # unquoted brace/glob expansion of an arbitrary variable would.
    mapfile -t apks < <(find "$(dirname -- "$CURRENT_PATH")" -maxdepth 1 -name "$(basename -- "$CURRENT_PATH")" | sort)
  fi

  if [[ ${#apks[@]} -eq 0 ]]
  then
    log_error "No APK files found at '$CURRENT_PATH'"
    return 1
  fi

  install_apk_files "${apks[@]}"
}

fetch_github_release() {
  local repo="$CURRENT_REPO"
  local asset_pattern="$CURRENT_ASSET"
  local cache_dir="$1"
  local -a curl_args=(--fail --silent --show-error --location)

  if [[ -n "${GITHUB_TOKEN:-}" ]]
  then
    curl_args+=(--header "Authorization: Bearer ${GITHUB_TOKEN}")
  fi

  local release_json
  if release_json="$(curl "${curl_args[@]}" "https://api.github.com/repos/${repo}/releases/latest" 2>/dev/null)"
  then
    log_step "Using latest release for $repo"
  else
    log_warn "No stable release found for $repo, falling back to most recent release (including prereleases)"
    if ! release_json="$(curl "${curl_args[@]}" "https://api.github.com/repos/${repo}/releases" 2>/dev/null | jq -c '.[0]')"
    then
      log_error "Failed to query GitHub releases for $repo"
      return 1
    fi
  fi

  if [[ -z "$release_json" || "$release_json" == "null" ]]
  then
    log_error "No releases found for $repo"
    return 1
  fi

  local -a matches
  mapfile -t matches < <(jq -r --arg pat "$asset_pattern" \
    '.assets[] | select(.name | test($pat)) | [.name, .browser_download_url] | @tsv' \
    <<< "$release_json")

  if [[ ${#matches[@]} -eq 0 ]]
  then
    log_error "No release asset matching '$asset_pattern' found for $repo"
    return 1
  fi

  if [[ ${#matches[@]} -gt 1 ]]
  then
    log_error "Multiple release assets matched '$asset_pattern' for $repo, narrow the 'asset' pattern:"
    local m
    for m in "${matches[@]}"
    do
      printf '  %s\n' "${m%%$'\t'*}"
    done
    return 1
  fi

  local asset_name asset_url
  IFS=$'\t' read -r asset_name asset_url <<< "${matches[0]}"

  log_step "Downloading $asset_name"

  if ! curl "${curl_args[@]}" --output "${cache_dir}/${asset_name}" "$asset_url"
  then
    log_error "Failed to download $asset_name"
    return 1
  fi
}

install_github() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$CURRENT_REPO" ]]
  then
    log_error "$CURRENT_PKG uses store: github but has no 'repo' set"
    return 1
  fi

  if [[ -n "$FORCE_DOWNLOAD" ]] || ! has_apk_files "$cache_dir"
  then
    mkdir -p "$cache_dir"
    rm -f "$cache_dir"/*.apk
    if ! fetch_github_release "$cache_dir"
    then
      return 1
    fi
  else
    log_step "Using cached download in $cache_dir"
  fi

  local -a apks
  mapfile -t apks < <(find "$cache_dir" -maxdepth 1 -iname '*.apk')

  if [[ ${#apks[@]} -ne 1 ]]
  then
    log_error "Expected exactly one cached APK in $cache_dir, found ${#apks[@]}"
    return 1
  fi

  adb -s "$DEVICE_SERIAL" install -r "${apks[0]}"
}

# Reads its per-app inputs from CURRENT_NAME/CURRENT_PKG/CURRENT_STORE/
# CURRENT_REPO/CURRENT_ASSET/CURRENT_PATH (set by for_each_app's read loop)
# and its run-wide context from DEVICE_SERIAL/DRY_RUN/FORCE_DOWNLOAD (set by
# cmd_install before calling for_each_app). See AGENTS.md for why -- this
# replaced a positional-argument chain that kept growing every time a store
# needed one more piece of config.
install_app() {
  local rc=0

  if is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
  then
    log_skip "$CURRENT_NAME ($CURRENT_PKG) already installed"
    return 0
  fi

  log_step "Installing $CURRENT_NAME ($CURRENT_PKG) [$CURRENT_STORE]"

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would install %s via %s\n' "$CURRENT_PKG" "$CURRENT_STORE"
    return 0
  fi

  case "$CURRENT_STORE" in
    gplay)
      install_gplay || rc=$?
      ;;
    fdroid)
      install_fdroid || rc=$?
      ;;
    github)
      install_github || rc=$?
      ;;
    local)
      install_local || rc=$?
      ;;
    *)
      log_error "Unknown store '$CURRENT_STORE' for $CURRENT_PKG (expected gplay, fdroid, github, or local)"
      rc=1
      ;;
  esac

  if [[ $rc -eq 0 ]]
  then
    log_ok "$CURRENT_NAME ($CURRENT_PKG) installed"
  fi

  return "$rc"
}

# See install_app's comment -- same convention, repo/asset/path are unused
# here (uninstalling doesn't care what store an app came from).
uninstall_app() {
  if ! is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
  then
    log_skip "$CURRENT_NAME ($CURRENT_PKG) not installed"
    return 0
  fi

  log_step "Uninstalling $CURRENT_NAME ($CURRENT_PKG)"

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would uninstall %s\n' "$CURRENT_PKG"
    return 0
  fi

  if adb -s "$DEVICE_SERIAL" uninstall "$CURRENT_PKG"
  then
    log_ok "$CURRENT_NAME ($CURRENT_PKG) uninstalled"
  else
    return 1
  fi
}

# Emits the configured apps as one row per app: name, pkg, store (defaulted),
# repo, asset (defaulted), path -- joined with U+00A7 (SECTION SIGN), not a
# tab. Several of these fields (repo/asset/path) are legitimately empty for
# most stores, and bash's `read` collapses consecutive *whitespace* IFS
# delimiters (tab included) regardless of what IFS is set to, silently
# dropping empty fields and shifting everything after them left by one. Using
# a non-whitespace, extremely-unlikely-to-appear-in-real-data separator
# sidesteps that entirely. Shared by for_each_app and cmd_diff.
app_rows() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.store // "gplay") as $d |
    .apps[] |
    [.name, .pkg, (.store // $d), (.repo // ""), (.asset // "\\.apk$"), (.path // "")] | join("§")' "$config"
}

# Calls app_fn (a zero-arg function; see install_app's comment) once per
# configured app, with CURRENT_NAME/CURRENT_PKG/CURRENT_STORE/CURRENT_REPO/
# CURRENT_ASSET/CURRENT_PATH set for it to read.
for_each_app() {
  local config="$1"
  local app_fn="$2"
  local failures=0

  while IFS='§' read -r CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH <&3
  do
    if ! "$app_fn"
    then
      log_error "$CURRENT_NAME ($CURRENT_PKG) failed"
      failures=$((failures + 1))
    fi
  done 3< <(app_rows "$config")

  if [[ $failures -gt 0 ]]
  then
    log_error "$failures app(s) failed"
    return 1
  fi

  log_ok "All apps processed successfully"
}

cmd_install() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local DRY_RUN=""
  local FORCE_DOWNLOAD=""
  local bulk=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -f|--force-download)
        FORCE_DOWNLOAD=1
        shift
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb yq sha256sum

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  local -a stores
  mapfile -t stores < <(config_stores "$config")

  if printf '%s\n' "${stores[@]}" | grep -qx gplay
  then
    check_deps gplaydl
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx fdroid
  then
    check_deps fdroidcl
    log_step "Updating F-Droid index"
    fdroidcl update
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx github
  then
    check_deps curl jq
  fi

  local DEVICE_SERIAL overall_rc=0
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"
    if ! for_each_app "$config" install_app
    then
      overall_rc=1
    fi
  done

  return "$overall_rc"
}

cmd_uninstall() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local DRY_RUN=""
  local assume_yes=""
  local bulk=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -y|--yes|--noconfirm|--no-confirm)
        assume_yes=1
        shift
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb yq

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  if [[ -z "$DRY_RUN" && -z "$assume_yes" ]]
  then
    local -a names
    mapfile -t names < <(yq -r '.apps[].name' "$config")
    printf '%sAbout to uninstall %d app(s) from %d device(s):%s\n' "$C_BOLD" "${#names[@]}" "${#devices[@]}" "$C_RESET"
    printf '  apps:    %s\n' "$(IFS=', '; echo "${names[*]}")"
    printf '  devices: %s\n' "$(IFS=', '; echo "${devices[*]}")"

    local reply
    read -rp "Continue? [y/N] " reply
    case "$reply" in
      y|Y|yes|YES)
        ;;
      *)
        log_step "Aborted"
        return 0
        ;;
    esac
  fi

  local DEVICE_SERIAL overall_rc=0
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"
    if ! for_each_app "$config" uninstall_app
    then
      overall_rc=1
    fi
  done

  return "$overall_rc"
}

cmd_clear_cache() {
  local assume_yes=""
  local -a pkgs=()

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -y|--yes|--noconfirm|--no-confirm)
        assume_yes=1
        shift
        ;;
      -*)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
      *)
        pkgs+=("$1")
        shift
        ;;
    esac
  done

  if [[ ! -d "$CACHE_ROOT" ]]
  then
    log_step "Cache is already empty ($CACHE_ROOT)"
    return 0
  fi

  if [[ ${#pkgs[@]} -eq 0 ]]
  then
    if [[ -z "$assume_yes" ]]
    then
      printf '%sThis will remove the entire APK cache at %s%s\n' "$C_BOLD" "$CACHE_ROOT" "$C_RESET"
      local reply
      read -rp "Continue? [y/N] " reply
      case "$reply" in
        y|Y|yes|YES)
          ;;
        *)
          log_step "Aborted"
          return 0
          ;;
      esac
    fi

    rm -rf "$CACHE_ROOT"
    log_ok "Cache cleared: $CACHE_ROOT"
    return 0
  fi

  local pkg dir
  for pkg in "${pkgs[@]}"
  do
    dir="$(cache_dir_for "$pkg")"

    if [[ ! -d "$dir" ]]
    then
      log_skip "$pkg (nothing cached)"
      continue
    fi

    rm -rf "$dir"
    log_ok "$pkg cache cleared"
  done
}

cmd_devices() {
  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb

  local -a lines
  mapfile -t lines < <(list_device_lines)

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_step "No adb devices connected"
    return 0
  fi

  {
    printf 'SERIAL\tMODEL\tCODENAME\tCONNECTION\n'
    local line serial usb model codename connection
    for line in "${lines[@]}"
    do
      serial="${line%% *}"
      usb=""
      model=""
      codename=""
      [[ "$line" =~ usb:([^[:space:]]+) ]] && usb="${BASH_REMATCH[1]}"
      [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
      [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"
      connection="network"
      [[ -n "$usb" ]] && connection="usb:$usb"
      printf '%s\t%s\t%s\t%s\n' "$serial" "${model:-?}" "${codename:-?}" "$connection"
    done
  } | render_table
}

cmd_diff() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local bulk=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb yq

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  local DEVICE_SERIAL CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"

    {
      printf 'NAME\tPKG\tSTORE\tSTATUS\n'
      while IFS='§' read -r CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH <&3
      do
        if is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
        then
          printf '%s\t%s\t%s\tinstalled\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
        else
          printf '%s\t%s\t%s\tmissing\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
        fi
      done 3< <(app_rows "$config")
    } | render_table | colorize_word installed "$C_GREEN" | colorize_word missing "$C_YELLOW"
  done
}

main() {
  if [[ -z "${1:-}" ]]
  then
    usage >&2
    return 2
  fi

  local command="$1"
  shift

  case "$command" in
    -h|--help)
      usage
      return 0
      ;;
    install)
      cmd_install "$@"
      ;;
    uninstall)
      cmd_uninstall "$@"
      ;;
    clear-cache)
      cmd_clear_cache "$@"
      ;;
    devices|list)
      cmd_devices "$@"
      ;;
    diff)
      cmd_diff "$@"
      ;;
    *)
      log_error "Unknown command: $command"
      usage >&2
      return 2
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
  main "$@"
fi

