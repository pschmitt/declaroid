#!/usr/bin/env bash

set -euo pipefail

DEFAULT_CONFIG="${DECLAROID_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/declaroid/apps.yaml}"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/declaroid"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]
then
  C_RESET=$'\e[0m'
  C_BOLD=$'\e[1m'
  C_RED=$'\e[31m'
  C_GREEN=$'\e[32m'
  C_YELLOW=$'\e[33m'
  C_BLUE=$'\e[34m'
  C_CYAN=$'\e[36m'
else
  C_RESET=''
  C_BOLD=''
  C_RED=''
  C_GREEN=''
  C_YELLOW=''
  C_BLUE=''
  C_CYAN=''
fi

log_step() {
  printf '%s==>%s %s\n' "${C_BOLD}${C_BLUE}" "$C_RESET" "$1" >&2
}

log_skip() {
  printf '%s[skip]%s %s\n' "$C_YELLOW" "$C_RESET" "$1" >&2
}

log_ok() {
  printf '%s[ok]%s %s\n' "$C_GREEN" "$C_RESET" "$1" >&2
}

log_warn() {
  printf '%s[warn]%s %s\n' "$C_YELLOW" "$C_RESET" "$1" >&2
}

log_error() {
  printf '%s[error]%s %s\n' "$C_RED" "$C_RESET" "$1" >&2
}

usage() {
  cat <<EOF
${C_BOLD}Usage:${C_RESET} ${C_GREEN}declaroid${C_RESET} COMMAND [OPTIONS]

Declarative Android app provisioning: define apps in YAML, install/uninstall
them onto a device via adb, fetching from Google Play (gplaydl), F-Droid
(fdroidcl), a GitHub repo's release assets, or a local APK file.

${C_BOLD}Commands:${C_RESET}
  ${C_CYAN}install${C_RESET}     Download (if not already cached) and install configured apps
  ${C_CYAN}uninstall${C_RESET}   Uninstall configured apps (no download)
  ${C_CYAN}diff${C_RESET}        Show which configured apps are installed vs missing, no changes made
  ${C_CYAN}devices${C_RESET}, ${C_CYAN}list${C_RESET}
              List connected adb devices (serial, model, codename, connection)
  ${C_CYAN}clear-cache${C_RESET} [PKG...]
              Remove cached APK downloads (all of them, or just PKG(s) given)
  ${C_CYAN}generate-config${C_RESET}
              Print a YAML config seeded from what's installed on a device

${C_BOLD}Options:${C_RESET}
  ${C_YELLOW}-c, --config FILE${C_RESET}       Path to the apps YAML config (default: ${DEFAULT_CONFIG})
  ${C_YELLOW}-d, --device QUERY${C_RESET}      Target device (also settable via \$TARGET_DEVICE)
      ${C_YELLOW}--dry-run${C_RESET}           Print what would happen without downloading/installing/uninstalling
  ${C_YELLOW}-f, --force-download${C_RESET}    (install only) Re-download even if a cached copy exists
  ${C_YELLOW}-y, --yes, --noconfirm, --no-confirm${C_RESET}
                          (uninstall/clear-cache) Skip the confirmation prompt
  ${C_YELLOW}-o, --output FILE${C_RESET}       (generate-config only) Write to FILE instead of stdout
      ${C_YELLOW}--system${C_RESET}            (generate-config only) Include system apps too (default: third-party only)
      ${C_YELLOW}--no-labels, --fast${C_RESET} (generate-config only) Skip resolving app names via aapt2, use the package id instead (faster)
  ${C_YELLOW}-j, --jobs N${C_RESET}          (generate-config only) Resolve up to N app names in parallel (default: 6)
      ${C_YELLOW}--bulk, --all-devices, --all${C_RESET}
                          Target every device that matches (see below), instead
                          of erroring out on an ambiguous match
  ${C_YELLOW}-h, --help${C_RESET}              Show this help

${C_BOLD}Config resolution order:${C_RESET} --config, \$DECLAROID_CONFIG,
${XDG_CONFIG_HOME:-\$HOME/.config}/declaroid/apps.yaml

${C_BOLD}Device resolution order:${C_RESET} --device, \$TARGET_DEVICE, .device in the config.
The value is matched as a case-insensitive substring against each connected
device's serial, USB path, product, model, and codename (e.g. "redfin",
"clover", an IP, or part of a serial) -- so it doesn't need to be exact. Run
${C_CYAN}declaroid devices${C_RESET} to see what's connected and matchable.
If it matches more than one connected device, declaroid errors out unless
--bulk/--all-devices/--all is given, in which case every match is used.
If nothing resolves at all, you'll be prompted to pick from connected
devices (or, with --bulk, every connected device is used).

${C_BOLD}Config schema:${C_RESET}
  device: <adb serial or substring query>   # optional, see device resolution above
  store: gplay|fdroid|github|local           # optional top-level default, defaults to gplay
  profile: <user id>|all|current              # optional top-level default (install only)
  apps:
    - name: <display name>
      pkg: <package id>
      store: gplay|fdroid|github|local  # optional, overrides the top-level default
      repo: <owner>/<repo>          # required when store is github
      asset: <regex>                # (github only) selects the release asset;
                                     # default: '\\.apk\$'. Must match exactly one
                                     # asset -- narrow it for multi-arch/multi-flavor
                                     # releases (e.g. debug vs release, per-ABI apks).
      path: <file, glob, or dir>    # required when store is local; a single apk
                                     # file, a glob matching one or more splits, or
                                     # a directory (every *.apk directly inside it).
      profile: <user id>|all|current  # optional, overrides the top-level default;
                                     # which Android user/profile to install for
                                     # (e.g. a Work Profile). Unset means: use
                                     # whatever the device reports as its current
                                     # profile -- never defaults to "all".

github releases are queried via the GitHub API; set \$GITHUB_TOKEN to raise
the unauthenticated rate limit or access private repos. If a repo has no
non-prerelease release, the most recent release (including prereleases) is
used instead.

APKs downloaded from gplay/github are cached under ${CACHE_ROOT}/<package-id>/
so repeated installs don't re-download (see --force-download). fdroid apps
are cached by fdroidcl itself; local apps aren't cached (nothing to cache).

Table output (devices, diff) is rendered with tsvtool if it's on \$PATH
(https://github.com/pschmitt/tsvtool), otherwise with column -t.
EOF
}

check_deps() {
  local bin

  for bin in "$@"
  do
    if ! command -v "$bin" >/dev/null 2>&1
    then
      log_error "Missing required binary: $bin"
      return 1
    fi
  done
}

config_stores() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.store // "gplay") as $d | [.apps[] | (.store // $d)] | unique | .[]' "$config"
}

list_device_lines() {
  adb devices -l | awk 'NR>1 && $2=="device" {print}'
}

build_searchable() {
  local line="$1"
  local serial="${line%% *}"
  local usb="" product="" model="" codename=""

  [[ "$line" =~ usb:([^[:space:]]+) ]] && usb="${BASH_REMATCH[1]}"
  [[ "$line" =~ product:([^[:space:]]+) ]] && product="${BASH_REMATCH[1]}"
  [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
  [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"

  printf '%s %s %s %s %s\n' "$serial" "$usb" "$product" "$model" "$codename"
}

format_device_line() {
  local line="$1"
  local serial="${line%% *}"
  local model="" codename=""

  [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
  [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"

  if [[ -n "$model" || -n "$codename" ]]
  then
    printf '%s (%s/%s)\n' "$serial" "${model:-?}" "${codename:-?}"
  else
    printf '%s\n' "$serial"
  fi
}

# Pretty-prints TSV (with a header row) read from stdin. Uses tsvtool if it's
# on PATH (https://github.com/pschmitt/tsvtool), otherwise falls back to
# column -t with a bolded header, otherwise just passes the TSV through.
render_table() {
  local data
  data="$(cat)"

  if [[ -z "$data" ]]
  then
    return 0
  fi

  if command -v tsvtool >/dev/null 2>&1
  then
    local -a args=(pretty)
    [[ -z "$C_RESET" ]] && args+=(--no-color)
    printf '%s\n' "$data" | tsvtool "${args[@]}"
    return 0
  fi

  if command -v column >/dev/null 2>&1
  then
    local -a rendered
    mapfile -t rendered < <(printf '%s\n' "$data" | column -t -s $'\t')

    if [[ ${#rendered[@]} -gt 0 ]]
    then
      printf '%s%s%s\n' "$C_BOLD" "${rendered[0]}" "$C_RESET"
      if [[ ${#rendered[@]} -gt 1 ]]
      then
        printf '%s\n' "${rendered[@]:1}"
      fi
    fi
    return 0
  fi

  printf '%s\n' "$data"
}

# Colorizes a whole-word match in already-rendered (aligned) text, read from
# stdin. Safe to run on tsvtool's own colored output too: if the word is
# already wrapped in ANSI codes there, the whitespace-boundary match simply
# won't fire, so this is a no-op rather than a corruption in that case.
colorize_word() {
  local word="$1"
  local color="$2"

  if [[ -z "$color" ]]
  then
    cat
    return 0
  fi

  sed -E "s/(^|[[:space:]])(${word})([[:space:]]|\$)/\\1${color}\\2${C_RESET}\\3/"
}

prompt_pick_device() {
  local -a lines=("$@")

  if [[ ! -t 0 ]]
  then
    log_error "Multiple devices connected and no --device/\$TARGET_DEVICE given; stdin is not a terminal to prompt"
    return 1
  fi

  {
    printf '%sMultiple devices connected, pick one:%s\n' "$C_BOLD" "$C_RESET"
    local i
    for i in "${!lines[@]}"
    do
      printf '  %s[%d]%s %s\n' "$C_CYAN" "$((i + 1))" "$C_RESET" "$(format_device_line "${lines[$i]}")"
    done
  } >&2

  local choice
  while true
  do
    read -rp "Device number: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#lines[@]} ))
    then
      printf '%s\n' "${lines[$((choice - 1))]%% *}"
      return 0
    fi
    log_error "Invalid choice: $choice"
  done
}

resolve_devices() {
  local cli_device="$1"
  local config="$2"
  local bulk="$3"
  local query=""

  if [[ -n "$cli_device" ]]
  then
    query="$cli_device"
  elif [[ -n "${TARGET_DEVICE:-}" ]]
  then
    query="$TARGET_DEVICE"
  elif [[ -n "$config" && -f "$config" ]]
  then
    local from_yaml
    from_yaml="$(yq -r '.device' "$config")"
    if [[ -n "$from_yaml" && "$from_yaml" != "null" ]]
    then
      query="$from_yaml"
    fi
  fi

  local -a lines
  mapfile -t lines < <(list_device_lines)

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_error "No adb devices connected"
    return 1
  fi

  local -a matched=()

  if [[ -n "$query" ]]
  then
    local line searchable
    for line in "${lines[@]}"
    do
      searchable="$(build_searchable "$line")"
      if [[ "${searchable,,}" == *"${query,,}"* ]]
      then
        matched+=("$line")
      fi
    done

    if [[ ${#matched[@]} -eq 0 ]]
    then
      log_error "No connected device matches '$query'"
      return 1
    fi
  else
    matched=("${lines[@]}")
  fi

  if [[ ${#matched[@]} -eq 1 ]]
  then
    printf '%s\n' "${matched[0]%% *}"
    return 0
  fi

  if [[ -n "$bulk" ]]
  then
    log_step "${#matched[@]} device(s) matched, targeting all of them (--bulk)"
    local m
    for m in "${matched[@]}"
    do
      printf '%s\n' "${m%% *}"
    done
    return 0
  fi

  if [[ -z "$query" ]]
  then
    prompt_pick_device "${matched[@]}"
    return $?
  fi

  {
    printf "%sMultiple devices match '%s':%s\\n" "$C_BOLD" "$query" "$C_RESET"
    local m
    for m in "${matched[@]}"
    do
      printf '  %s\n' "$(format_device_line "$m")"
    done
    printf 'Use --bulk/--all-devices/--all to target all of them, or refine the match.\n'
  } >&2
  return 1
}

is_installed() {
  local device="$1"
  local pkg="$2"

  adb -s "$device" shell pm list packages "$pkg" </dev/null 2>/dev/null \
    | tr -d '\r' \
    | grep -qx "package:$pkg"
}

# Best-effort: prints the device's current user id (`am get-current-user`,
# e.g. "0" for the primary/personal profile) or nothing if it can't be
# determined (older Android without multi-user support, a transient adb
# hiccup, ...). Callers should treat empty as "don't pass --user at all"
# rather than an error -- see install_apk_files's comment for why this
# matters on devices with a secondary/managed profile.
resolve_target_user() {
  local device="$1"
  local user

  user="$(adb -s "$device" shell am get-current-user </dev/null 2>/dev/null | tr -d '\r\n')"

  if [[ "$user" =~ ^[0-9]+$ ]]
  then
    printf '%s\n' "$user"
  fi
}

# The --user value to actually pass to adb install/install-multiple: the
# per-app CURRENT_PROFILE from config wins if set (a number, "all", or
# "current" -- all valid adb/pm values, passed through as-is, unvalidated),
# otherwise the auto-detected current profile (TARGET_USER, set once per
# device in cmd_install). Never defaults to "all" on its own -- installing
# to every profile has to be an explicit, per-app opt-in via `profile: all`
# in the config, not something that happens by not configuring anything.
effective_target_user() {
  if [[ -n "${CURRENT_PROFILE:-}" ]]
  then
    printf '%s\n' "$CURRENT_PROFILE"
  else
    printf '%s\n' "${TARGET_USER:-}"
  fi
}

cache_dir_for() {
  local pkg="$1"

  printf '%s/%s\n' "$CACHE_ROOT" "$pkg"
}

has_apk_files() {
  local dir="$1"
  local -a existing=("$dir"/*.apk)

  [[ -e "${existing[0]}" ]]
}

fetch_app() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$FORCE_DOWNLOAD" ]] && has_apk_files "$cache_dir"
  then
    log_step "Using cached download in $cache_dir"
    printf '%s\n' "$cache_dir"
    return 0
  fi

  mkdir -p "$cache_dir"

  if ! gplaydl download "$CURRENT_PKG" -o "$cache_dir" >&2
  then
    log_error "Failed to download $CURRENT_PKG"
    return 1
  fi

  printf '%s\n' "$cache_dir"
}

# Takes an installer attribution package id (may be empty -- see below) and
# a list of APK file paths (computed data, not per-app config, unlike the
# CURRENT_*/DEVICE_SERIAL/etc convention used elsewhere), dedupes the files
# by checksum, and installs the survivors.
#
# `adb install -i <id> -r <file>` sets the installer attribution (visible
# later via `pm list packages -i`, and read back by
# store_for_installer/generate-config) -- but only if <id> is a real,
# currently-installed package; Android silently drops the attribution
# (installer ends up null) for a made-up id, tested against a real device
# with a synthetic "declaroid.store.whatever" string. That rules out
# attributing github/local installs to declaroid itself: there's no
# existing installed package we could truthfully claim to be. gplay is the
# one case this is worth doing, since com.android.vending genuinely is
# installed on any real device -- `installer` is only ever passed as
# "com.android.vending" or "" by callers, never a synthetic id.
#
# Separately: `adb install-multiple -i <id> -r <files...>` was tested and
# reliably *hangs* instead of erroring, regardless of flag order, even with
# a real installer id. So -i is only ever used for the single-APK case,
# routed through plain `install`; a real split install always goes through
# `install-multiple` with no installer attribution at all (matching prior
# behavior). Don't add -i to the install-multiple branch without re-testing
# against a real device first.
#
# --user "$TARGET_USER" is passed to both branches when set (see
# resolve_target_user): on a device with a secondary/managed profile (a
# Work Profile, Island, etc), `adb install`/`install-multiple` without
# --user were observed installing into an unpredictable profile -- not
# consistently "all profiles", not consistently the current one, and not
# even consistent between `install` and `install-multiple` on the same
# device. Passing --user explicitly makes this deterministic.
install_apk_files() {
  local installer="$1"
  shift
  local -a files=("$@")
  local -A seen_hashes
  local -a keep_files
  local f hash base

  for f in "${files[@]}"
  do
    [[ -e "$f" ]] || continue
    hash="$(sha256sum "$f" | cut -d' ' -f1)"
    base="$(basename "$f")"

    if [[ -n "${seen_hashes[$hash]:-}" ]]
    then
      log_warn "Skipping duplicate split $base (identical to ${seen_hashes[$hash]})"
      continue
    fi

    seen_hashes[$hash]="$base"
    keep_files+=("$f")
  done

  if [[ ${#keep_files[@]} -eq 0 ]]
  then
    log_error "No APK files to install"
    return 1
  fi

  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(--user "$user_val")

  if [[ ${#keep_files[@]} -eq 1 && -n "$installer" ]]
  then
    adb -s "$DEVICE_SERIAL" install -r "${user_args[@]}" -i "$installer" "${keep_files[0]}"
  else
    adb -s "$DEVICE_SERIAL" install-multiple -r "${user_args[@]}" "${keep_files[@]}"
  fi
}

install_splits() {
  local installer="$1"
  local dir="$2"
  local -a files
  local -a obb_files

  mapfile -t files < <(find "$dir" -maxdepth 1 -iname '*.apk' | sort)

  if [[ ${#files[@]} -eq 0 ]]
  then
    log_error "No APK files found in $dir"
    return 1
  fi

  if ! install_apk_files "$installer" "${files[@]}"
  then
    return 1
  fi

  mapfile -t obb_files < <(find "$dir" -maxdepth 1 -iname '*.obb')
  if [[ ${#obb_files[@]} -gt 0 ]]
  then
    log_warn "${#obb_files[@]} OBB/expansion file(s) are cached but not pushed automatically:"
    printf '  %s\n' "${obb_files[@]}"
  fi
}

install_gplay() {
  local cache_dir

  if ! cache_dir="$(fetch_app)"
  then
    return 1
  fi

  install_splits com.android.vending "$cache_dir"
}

# fdroidcl does its own `adb install` internally with no installer flag, so
# fdroid-sourced apps always end up with installer=null -- nothing declaroid
# can do about that without patching fdroidcl itself. It does have its own
# -user flag though (defaulting to the current user itself if omitted), so
# profile targeting still works.
install_fdroid() {
  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(-user "$user_val")
  ANDROID_SERIAL="$DEVICE_SERIAL" fdroidcl install "${user_args[@]}" "$CURRENT_PKG"
}

install_local() {
  local -a apks

  if [[ -z "$CURRENT_PATH" ]]
  then
    log_error "store: local requires a 'path'"
    return 1
  fi

  if [[ -d "$CURRENT_PATH" ]]
  then
    mapfile -t apks < <(find "$CURRENT_PATH" -maxdepth 1 -iname '*.apk' | sort)
  else
    # $CURRENT_PATH may be a plain file path or a glob pattern (e.g.
    # "/dir/*.apk"); routing both through find -name on the parent dir
    # handles either case without word-splitting/quoting hazards, unlike
    # unquoted brace/glob expansion of an arbitrary variable would.
    mapfile -t apks < <(find "$(dirname -- "$CURRENT_PATH")" -maxdepth 1 -name "$(basename -- "$CURRENT_PATH")" | sort)
  fi

  if [[ ${#apks[@]} -eq 0 ]]
  then
    log_error "No APK files found at '$CURRENT_PATH'"
    return 1
  fi

  # No installer attribution here either -- same reason as install_github.
  install_apk_files "" "${apks[@]}"
}

fetch_github_release() {
  local repo="$CURRENT_REPO"
  local asset_pattern="$CURRENT_ASSET"
  local cache_dir="$1"
  local -a curl_args=(--fail --silent --show-error --location)

  if [[ -n "${GITHUB_TOKEN:-}" ]]
  then
    curl_args+=(--header "Authorization: Bearer ${GITHUB_TOKEN}")
  fi

  local release_json
  if release_json="$(curl "${curl_args[@]}" "https://api.github.com/repos/${repo}/releases/latest" 2>/dev/null)"
  then
    log_step "Using latest release for $repo"
  else
    log_warn "No stable release found for $repo, falling back to most recent release (including prereleases)"
    if ! release_json="$(curl "${curl_args[@]}" "https://api.github.com/repos/${repo}/releases" 2>/dev/null | jq -c '.[0]')"
    then
      log_error "Failed to query GitHub releases for $repo"
      return 1
    fi
  fi

  if [[ -z "$release_json" || "$release_json" == "null" ]]
  then
    log_error "No releases found for $repo"
    return 1
  fi

  local -a matches
  mapfile -t matches < <(jq -r --arg pat "$asset_pattern" \
    '.assets[] | select(.name | test($pat)) | [.name, .browser_download_url] | @tsv' \
    <<< "$release_json")

  if [[ ${#matches[@]} -eq 0 ]]
  then
    log_error "No release asset matching '$asset_pattern' found for $repo"
    return 1
  fi

  if [[ ${#matches[@]} -gt 1 ]]
  then
    log_error "Multiple release assets matched '$asset_pattern' for $repo, narrow the 'asset' pattern:"
    local m
    for m in "${matches[@]}"
    do
      printf '  %s\n' "${m%%$'\t'*}"
    done
    return 1
  fi

  local asset_name asset_url
  IFS=$'\t' read -r asset_name asset_url <<< "${matches[0]}"

  log_step "Downloading $asset_name"

  if ! curl "${curl_args[@]}" --output "${cache_dir}/${asset_name}" "$asset_url"
  then
    log_error "Failed to download $asset_name"
    return 1
  fi
}

install_github() {
  local cache_dir
  cache_dir="$(cache_dir_for "$CURRENT_PKG")"

  if [[ -z "$CURRENT_REPO" ]]
  then
    log_error "$CURRENT_PKG uses store: github but has no 'repo' set"
    return 1
  fi

  if [[ -n "$FORCE_DOWNLOAD" ]] || ! has_apk_files "$cache_dir"
  then
    mkdir -p "$cache_dir"
    rm -f "$cache_dir"/*.apk
    if ! fetch_github_release "$cache_dir"
    then
      return 1
    fi
  else
    log_step "Using cached download in $cache_dir"
  fi

  local -a apks
  mapfile -t apks < <(find "$cache_dir" -maxdepth 1 -iname '*.apk')

  if [[ ${#apks[@]} -ne 1 ]]
  then
    log_error "Expected exactly one cached APK in $cache_dir, found ${#apks[@]}"
    return 1
  fi

  # No -i here: Android silently drops installer attribution unless the
  # claimed installer is a real, currently-installed package (tested --
  # a synthetic "declaroid.store.github" id is just ignored, ending up
  # installer=null same as if we hadn't passed -i at all).
  local -a user_args=()
  local user_val
  user_val="$(effective_target_user)"
  [[ -n "$user_val" ]] && user_args=(--user "$user_val")
  adb -s "$DEVICE_SERIAL" install -r "${user_args[@]}" "${apks[0]}"
}

# Reads its per-app inputs from CURRENT_NAME/CURRENT_PKG/CURRENT_STORE/
# CURRENT_REPO/CURRENT_ASSET/CURRENT_PATH/CURRENT_PROFILE (set by
# for_each_app's read loop) and its run-wide context from
# DEVICE_SERIAL/DRY_RUN/FORCE_DOWNLOAD/TARGET_USER (set by cmd_install
# before calling for_each_app). See AGENTS.md for why -- this replaced a
# positional-argument chain that kept growing every time a store needed one
# more piece of config.
install_app() {
  local rc=0

  if is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
  then
    log_skip "$CURRENT_NAME ($CURRENT_PKG) already installed"
    return 0
  fi

  log_step "Installing $CURRENT_NAME ($CURRENT_PKG) [$CURRENT_STORE]"

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would install %s via %s\n' "$CURRENT_PKG" "$CURRENT_STORE"
    return 0
  fi

  case "$CURRENT_STORE" in
    gplay)
      install_gplay || rc=$?
      ;;
    fdroid)
      install_fdroid || rc=$?
      ;;
    github)
      install_github || rc=$?
      ;;
    local)
      install_local || rc=$?
      ;;
    *)
      log_error "Unknown store '$CURRENT_STORE' for $CURRENT_PKG (expected gplay, fdroid, github, or local)"
      rc=1
      ;;
  esac

  if [[ $rc -eq 0 ]]
  then
    log_ok "$CURRENT_NAME ($CURRENT_PKG) installed"
  fi

  return "$rc"
}

# See install_app's comment -- same convention, repo/asset/path are unused
# here (uninstalling doesn't care what store an app came from).
uninstall_app() {
  if ! is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
  then
    log_skip "$CURRENT_NAME ($CURRENT_PKG) not installed"
    return 0
  fi

  log_step "Uninstalling $CURRENT_NAME ($CURRENT_PKG)"

  if [[ -n "$DRY_RUN" ]]
  then
    printf '  would uninstall %s\n' "$CURRENT_PKG"
    return 0
  fi

  if adb -s "$DEVICE_SERIAL" uninstall "$CURRENT_PKG"
  then
    log_ok "$CURRENT_NAME ($CURRENT_PKG) uninstalled"
  else
    return 1
  fi
}

# Emits the configured apps as one row per app: name, pkg, store (defaulted),
# repo, asset (defaulted), path, profile (defaulted) -- joined with U+00A7
# (SECTION SIGN), not a tab. Several of these fields (repo/asset/path/
# profile) are legitimately empty for most apps, and bash's `read` collapses
# consecutive *whitespace* IFS delimiters (tab included) regardless of what
# IFS is set to, silently dropping empty fields and shifting everything
# after them left by one. Using a non-whitespace, extremely-unlikely-to-
# appear-in-real-data separator sidesteps that entirely. Shared by
# for_each_app and cmd_diff.
app_rows() {
  local config="$1"

  # shellcheck disable=SC2016
  yq -r '(.store // "gplay") as $ds |
    (.profile // "") as $dp |
    .apps[] |
    [.name, .pkg, (.store // $ds), (.repo // ""), (.asset // "\\.apk$"), (.path // ""), (.profile // $dp)] | join("§")' "$config"
}

# Calls app_fn (a zero-arg function; see install_app's comment) once per
# configured app, with CURRENT_NAME/CURRENT_PKG/CURRENT_STORE/CURRENT_REPO/
# CURRENT_ASSET/CURRENT_PATH/CURRENT_PROFILE set for it to read.
for_each_app() {
  local config="$1"
  local app_fn="$2"
  local failures=0

  while IFS='§' read -r CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH CURRENT_PROFILE <&3
  do
    if ! "$app_fn"
    then
      log_error "$CURRENT_NAME ($CURRENT_PKG) failed"
      failures=$((failures + 1))
    fi
  done 3< <(app_rows "$config")

  if [[ $failures -gt 0 ]]
  then
    log_error "$failures app(s) failed"
    return 1
  fi

  log_ok "All apps processed successfully"
}

cmd_install() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local DRY_RUN=""
  local FORCE_DOWNLOAD=""
  local bulk=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -f|--force-download)
        FORCE_DOWNLOAD=1
        shift
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb yq sha256sum

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  local -a stores
  mapfile -t stores < <(config_stores "$config")

  if printf '%s\n' "${stores[@]}" | grep -qx gplay
  then
    check_deps gplaydl
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx fdroid
  then
    check_deps fdroidcl
    log_step "Updating F-Droid index"
    fdroidcl update
  fi

  if printf '%s\n' "${stores[@]}" | grep -qx github
  then
    check_deps curl jq
  fi

  local DEVICE_SERIAL TARGET_USER overall_rc=0
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"
    TARGET_USER="$(resolve_target_user "$DEVICE_SERIAL")"
    if ! for_each_app "$config" install_app
    then
      overall_rc=1
    fi
  done

  return "$overall_rc"
}

cmd_uninstall() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local DRY_RUN=""
  local assume_yes=""
  local bulk=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -y|--yes|--noconfirm|--no-confirm)
        assume_yes=1
        shift
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb yq

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  if [[ -z "$DRY_RUN" && -z "$assume_yes" ]]
  then
    local -a names
    mapfile -t names < <(yq -r '.apps[].name' "$config")
    printf '%sAbout to uninstall %d app(s) from %d device(s):%s\n' "$C_BOLD" "${#names[@]}" "${#devices[@]}" "$C_RESET"
    printf '  apps:    %s\n' "$(IFS=', '; echo "${names[*]}")"
    printf '  devices: %s\n' "$(IFS=', '; echo "${devices[*]}")"

    local reply
    read -rp "Continue? [y/N] " reply
    case "$reply" in
      y|Y|yes|YES)
        ;;
      *)
        log_step "Aborted"
        return 0
        ;;
    esac
  fi

  local DEVICE_SERIAL overall_rc=0
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"
    if ! for_each_app "$config" uninstall_app
    then
      overall_rc=1
    fi
  done

  return "$overall_rc"
}

cmd_clear_cache() {
  local assume_yes=""
  local -a pkgs=()

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -y|--yes|--noconfirm|--no-confirm)
        assume_yes=1
        shift
        ;;
      -*)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
      *)
        pkgs+=("$1")
        shift
        ;;
    esac
  done

  if [[ ! -d "$CACHE_ROOT" ]]
  then
    log_step "Cache is already empty ($CACHE_ROOT)"
    return 0
  fi

  if [[ ${#pkgs[@]} -eq 0 ]]
  then
    if [[ -z "$assume_yes" ]]
    then
      printf '%sThis will remove the entire APK cache at %s%s\n' "$C_BOLD" "$CACHE_ROOT" "$C_RESET"
      local reply
      read -rp "Continue? [y/N] " reply
      case "$reply" in
        y|Y|yes|YES)
          ;;
        *)
          log_step "Aborted"
          return 0
          ;;
      esac
    fi

    rm -rf "$CACHE_ROOT"
    log_ok "Cache cleared: $CACHE_ROOT"
    return 0
  fi

  local pkg dir
  for pkg in "${pkgs[@]}"
  do
    dir="$(cache_dir_for "$pkg")"

    if [[ ! -d "$dir" ]]
    then
      log_skip "$pkg (nothing cached)"
      continue
    fi

    rm -rf "$dir"
    log_ok "$pkg cache cleared"
  done
}

cmd_devices() {
  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb

  local -a lines
  mapfile -t lines < <(list_device_lines)

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_step "No adb devices connected"
    return 0
  fi

  {
    printf 'SERIAL\tMODEL\tCODENAME\tCONNECTION\n'
    local line serial usb model codename connection
    for line in "${lines[@]}"
    do
      serial="${line%% *}"
      usb=""
      model=""
      codename=""
      [[ "$line" =~ usb:([^[:space:]]+) ]] && usb="${BASH_REMATCH[1]}"
      [[ "$line" =~ model:([^[:space:]]+) ]] && model="${BASH_REMATCH[1]}"
      [[ "$line" =~ device:([^[:space:]]+) ]] && codename="${BASH_REMATCH[1]}"
      connection="network"
      [[ -n "$usb" ]] && connection="usb:$usb"
      printf '%s\t%s\t%s\t%s\n' "$serial" "${model:-?}" "${codename:-?}" "$connection"
    done
  } | render_table
}

cmd_diff() {
  local config="$DEFAULT_CONFIG"
  local cli_device=""
  local bulk=""

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -c|--config)
        config="$2"
        shift 2
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      --bulk|--all-devices|--all)
        bulk=1
        shift
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb yq

  if [[ ! -f "$config" ]]
  then
    log_error "Config file not found: $config"
    return 2
  fi

  local devices_raw
  if ! devices_raw="$(resolve_devices "$cli_device" "$config" "$bulk")"
  then
    return 2
  fi

  local -a devices
  mapfile -t devices <<< "$devices_raw"

  local DEVICE_SERIAL CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH CURRENT_PROFILE
  for DEVICE_SERIAL in "${devices[@]}"
  do
    log_step "Target device: $DEVICE_SERIAL"

    {
      printf 'NAME\tPKG\tSTORE\tSTATUS\n'
      while IFS='§' read -r CURRENT_NAME CURRENT_PKG CURRENT_STORE CURRENT_REPO CURRENT_ASSET CURRENT_PATH CURRENT_PROFILE <&3
      do
        if is_installed "$DEVICE_SERIAL" "$CURRENT_PKG"
        then
          printf '%s\t%s\t%s\tinstalled\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
        else
          printf '%s\t%s\t%s\tmissing\n' "$CURRENT_NAME" "$CURRENT_PKG" "$CURRENT_STORE"
        fi
      done 3< <(app_rows "$config")
    } | render_table | colorize_word installed "$C_GREEN" | colorize_word missing "$C_YELLOW"
  done
}

# `pm list packages -i` reports the installer attribution package, which is
# a decent (if imperfect) signal for where an app actually came from:
#   com.android.vending           -> the Play Store app itself       -> gplay
#   org.fdroid.fdroid             -> the F-Droid client itself       -> fdroid
#   *obtainium*                   -> Obtainium (GitHub-release apps) -> github
#   com.google.android.packageinstaller / com.android.packageinstaller / null
#                                  -> a raw APK was opened/installed directly
#                                     (adb install, a browser download, ...),
#                                     including declaroid-installed github/
#                                     local apps and split (install-multiple)
#                                     gplay apps -- see install_apk_files's
#                                     comment for why those can't set -i
#                                  -> unknown; declaroid can't recover repo/
#                                     asset/path from this alone
store_for_installer() {
  case "$1" in
    com.android.vending)
      printf 'gplay\n'
      ;;
    org.fdroid.fdroid)
      printf 'fdroid\n'
      ;;
    *obtainium*)
      printf 'github\n'
      ;;
    *)
      printf '\n'
      ;;
  esac
}

# Package IDs that are GMS/AOSP system plumbing rather than user-facing
# apps -- these routinely leak into `pm list packages -3` ("third-party")
# because they've been updated via the Play Store at some point, which is
# enough for Android to stop counting them as system packages even though
# they're not something you'd ever want to declaratively "install". This is
# a best-effort denylist, not an exhaustive one -- add to it as needed.
is_system_plumbing_pkg() {
  case "$1" in
    com.android.vending | \
    com.google.android.gms | \
    com.google.android.gsf | \
    com.google.android.gsf.login | \
    com.google.android.webview | \
    com.google.android.trichromelibrary | \
    com.google.android.modulemetadata | \
    com.google.android.safetycore | \
    com.google.android.contactkeys | \
    com.android.providers.contactkeys | \
    com.google.android.apps.work.clouddpc | \
    com.google.android.ims | \
    com.google.android.packageinstaller | \
    com.android.packageinstaller | \
    com.google.android.partnersetup | \
    com.google.android.settings.intelligence | \
    com.google.android.as | \
    com.google.android.printservice.recommendation | \
    com.google.android.tag | \
    com.google.android.feedback | \
    com.google.android.onetimeinitializer | \
    com.google.android.configupdater | \
    com.google.android.ext.services | \
    com.google.android.ext.shared | \
    com.google.android.federatedcompute | \
    com.google.android.odad | \
    com.google.android.captiveportallogin | \
    com.google.android.cellbroadcastreceiver | \
    com.google.android.cellbroadcastservice | \
    com.google.android.networkstack | \
    com.google.android.networkstack.permissionconfig | \
    com.google.android.euicc | \
    com.google.android.hotspot2.osulogin | \
    com.google.android.wfcactivation | \
    com.google.android.apps.accessibility.voiceaccess | \
    com.google.android.apps.healthdata)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# Wraps a string as a double-quoted YAML scalar, escaping backslashes and
# double quotes. Used for `name`, since it's an arbitrary human-readable
# string (unlike `pkg`, which is always a safe bare identifier).
yaml_quote_scalar() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '"%s"\n' "$s"
}

# Cached alongside per-package APK downloads under $CACHE_ROOT/<pkg>/ --
# `declaroid clear-cache [pkg]` already wipes that whole directory, so label
# caching gets cache invalidation for free without any extra bookkeeping.
label_cache_file_for() {
  printf '%s/.label\n' "$(cache_dir_for "$1")"
}

# Pulls a package's base.apk and reads its default (unlocalized)
# application-label via aapt2. Slow (transfers the whole APK -- can be
# 100+ MB) and best-effort: prints nothing and returns non-zero on any
# failure, so callers should fall back to the package id as the name.
# Checks/populates the label cache; see label_cache_file_for.
resolve_app_label() {
  local device="$1"
  local pkg="$2"
  local apk_path tmp_apk label cache_file

  cache_file="$(label_cache_file_for "$pkg")"

  if [[ -s "$cache_file" ]]
  then
    cat "$cache_file"
    return 0
  fi

  apk_path="$(adb -s "$device" shell pm path "$pkg" </dev/null 2>/dev/null | head -1 | tr -d '\r')"
  apk_path="${apk_path#package:}"

  if [[ -z "$apk_path" ]]
  then
    return 1
  fi

  tmp_apk="$(mktemp --suffix=.apk)"

  if ! adb -s "$device" pull "$apk_path" "$tmp_apk" >/dev/null 2>&1
  then
    rm -f "$tmp_apk"
    return 1
  fi

  label="$(aapt2 dump badging "$tmp_apk" 2>/dev/null | grep -m1 "^application-label:")"
  rm -f "$tmp_apk"

  if [[ "$label" =~ ^application-label:\'(.*)\'$ ]]
  then
    label="${BASH_REMATCH[1]}"
    mkdir -p "$(dirname "$cache_file")"
    printf '%s\n' "$label" > "$cache_file"
    printf '%s\n' "$label"
    return 0
  fi

  return 1
}

cmd_generate_config() {
  local cli_device=""
  local output=""
  local include_system=""
  local resolve_names=1
  local jobs=6

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -d|--device)
        cli_device="$2"
        shift 2
        ;;
      -o|--output)
        output="$2"
        shift 2
        ;;
      --system)
        include_system=1
        shift
        ;;
      --no-labels|--fast)
        resolve_names=""
        shift
        ;;
      -j|--jobs)
        jobs="$2"
        shift 2
        ;;
      *)
        log_error "Unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  check_deps adb

  local device
  if ! device="$(resolve_devices "$cli_device" "" "")"
  then
    return 2
  fi

  if [[ -n "$resolve_names" ]] && ! command -v aapt2 >/dev/null 2>&1
  then
    log_warn "aapt2 not found, app names will default to the package id (install aapt2 or pass --no-labels/--fast to silence this)"
    resolve_names=""
  fi

  log_step "Generating config from $device"

  local -a scope_flags=(-3)
  [[ -n "$include_system" ]] && scope_flags=()

  local -a lines
  mapfile -t lines < <(adb -s "$device" shell pm list packages "${scope_flags[@]}" -i </dev/null 2>/dev/null | tr -d '\r' | sort)

  if [[ ${#lines[@]} -eq 0 ]]
  then
    log_error "No packages found on $device"
    return 1
  fi

  # Pre-filter to the packages we'll actually emit, so the parallel label
  # pass below doesn't waste time/bandwidth on denylisted plumbing.
  local -a keep_pkgs=()
  local -A pkg_installer=()
  local line pkg installer
  for line in "${lines[@]}"
  do
    [[ "$line" =~ ^package:([^[:space:]]+)[[:space:]]+installer=(.*)$ ]] || continue
    pkg="${BASH_REMATCH[1]}"
    installer="${BASH_REMATCH[2]}"

    is_system_plumbing_pkg "$pkg" && continue

    keep_pkgs+=("$pkg")
    pkg_installer["$pkg"]="$installer"
  done

  # Resolving names one at a time (one adb pull + one aapt2 call per app,
  # each easily a few seconds) is the slow part of this command, and it's
  # entirely I/O-bound, so it parallelizes well. This pass runs up to $jobs
  # of them concurrently and throws its own output away -- the point is
  # purely to populate resolve_app_label's on-disk cache (see
  # label_cache_file_for) so the sequential pass below that actually builds
  # the YAML gets fast cache hits instead of doing the work twice.
  if [[ -n "$resolve_names" ]]
  then
    log_step "Resolving ${#keep_pkgs[@]} app name(s) (up to $jobs at a time)"
    local running=0
    for pkg in "${keep_pkgs[@]}"
    do
      resolve_app_label "$device" "$pkg" >/dev/null 2>&1 &
      running=$((running + 1))
      if [[ $running -ge $jobs ]]
      then
        # wait -n returns the exit status of whichever job just finished --
        # resolve_app_label failing for a given app is normal/expected, not
        # a script error, so this must not trip `set -e`.
        wait -n || true
        running=$((running - 1))
      fi
    done
    wait
  fi

  local yaml
  yaml="$(
    printf '# Generated by declaroid generate-config from %s\n' "$device"
    if [[ -n "$resolve_names" ]]
    then
      printf '# App names were read from each APK (aapt2); rename any that came out\n'
      printf '# wrong or unhelpful.\n'
    else
      printf '# App names default to the package id -- edit them to something readable.\n'
    fi
    printf '# store is detected from the installer attribution (pm list packages -i):\n'
    printf '#   com.android.vending -> gplay, org.fdroid.fdroid -> fdroid, Obtainium -> github.\n'
    printf '# Entries marked with a "# TODO" are commented out: reinstalling from this\n'
    printf '# config as-is would fail for them (store could not be determined, or a\n'
    printf '# github repo/asset could not be recovered) -- fix them up and uncomment.\n'
    printf 'device: %s\n' "$device"
    printf 'apps:\n'

    local store name resolved todo
    local -a entry_lines
    for pkg in "${keep_pkgs[@]}"
    do
      installer="${pkg_installer[$pkg]}"
      store="$(store_for_installer "$installer")"

      name="$pkg"
      if [[ -n "$resolve_names" ]] && resolved="$(resolve_app_label "$device" "$pkg")" && [[ -n "$resolved" ]]
      then
        name="$resolved"
      fi

      todo=""
      entry_lines=("  - name: $(yaml_quote_scalar "$name")" "    pkg: $pkg")
      case "$store" in
        github)
          entry_lines+=("    store: github" '    repo: ""')
          todo="installed via Obtainium -- set repo/asset by hand, original repo is unknown"
          ;;
        "")
          todo="store unknown (installer=${installer:-none}) -- set store by hand"
          ;;
        *)
          entry_lines+=("    store: $store")
          ;;
      esac

      if [[ -n "$todo" ]]
      then
        printf '  # TODO: %s\n' "$todo"
        local eline
        for eline in "${entry_lines[@]}"
        do
          printf '  # %s\n' "${eline#  }"
        done
      else
        printf '%s\n' "${entry_lines[@]}"
      fi
    done
  )"

  if [[ -n "$output" ]]
  then
    printf '%s\n' "$yaml" > "$output"
    log_ok "Wrote config to $output"
  else
    printf '%s\n' "$yaml"
  fi
}

main() {
  if [[ -z "${1:-}" ]]
  then
    usage >&2
    return 2
  fi

  local command="$1"
  shift

  case "$command" in
    -h|--help)
      usage
      return 0
      ;;
    install)
      cmd_install "$@"
      ;;
    uninstall)
      cmd_uninstall "$@"
      ;;
    clear-cache)
      cmd_clear_cache "$@"
      ;;
    devices|list)
      cmd_devices "$@"
      ;;
    diff)
      cmd_diff "$@"
      ;;
    generate-config)
      cmd_generate_config "$@"
      ;;
    *)
      log_error "Unknown command: $command"
      usage >&2
      return 2
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
  main "$@"
fi

